# OpenWRT Customized RE650 Image
#
# make -j distclean && ./scripts/feeds update -a && ./scripts/feeds install -a
# export TARGET_CFLAGS="-Os"
# export TARGET_LDFLAGS="-Wl,--gc-sections -Wl,-O3 -Wl,-z,now -Wl,-z,relro"
# cp diffconfig-re650 .config && time make -j$(nproc) defconfig download clean world V=s
#

CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_ramips_mt7621_DEVICE_tplink_re650-v2=y

CONFIG_DEVEL=y
# CONFIG_ALL_KMODS is not set
# CONFIG_ALL_NONSHARED is not set
CONFIG_TARGET_PER_DEVICE_ROOTFS=y

# Trim down the image size
# CONFIG_USE_LTO=y
CONFIG_USE_STRIP=y
CONFIG_USE_GC_SECTIONS=y
CONFIG_USE_MKLIBS=y
# CONFIG_KERNEL_KALLSYMS is not set
# CONFIG_KERNEL_DEBUG_INFO is not set
CONFIG_KERNEL_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=1024
CONFIG_TARGET_INITRAMFS_COMPRESSION_ZSTD=y

# Target optimizations
CONFIG_KERNEL_CFLAGS="-Os -ftree-vectorize"

# Trim down packages
CONFIG_EXTRA_GCC_CONFIG_OPTIONS="-Os -ftree-vectorize"

# Busybox tweaks
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_ASH_OPTIMIZE_FOR_SIZE=y

# Add-on programs
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_dawn=y

# WLAN/WPS support
CONFIG_WPA_MSG_MIN_PRIORITY=4
CONFIG_PACKAGE_hostapd-utils=y
CONFIG_PACKAGE_wpad-mesh-mbedtls=y
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set

# BATMAN ADV
CONFIG_PACKAGE_batctl-default=y
CONFIG_PACKAGE_kmod-batman-adv=y
CONFIG_PACKAGE_luci-proto-batman-adv=y

# Bridger
CONFIG_PACKAGE_bridger=y

# SSL certificates
CONFIG_PACKAGE_ca-certificates=y

# Luci
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
# CONFIG_PACKAGE_luci-ssl is not set
# CONFIG_PACKAGE_luci-app-firewall is not set

# ZRAM
CONFIG_KERNEL_SWAP=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lzo=y
CONFIG_PACKAGE_kmod-lib-lz4=y

# Disables
# CONFIG_PACKAGE_opkg is not set
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_ppp-mod-pppoa is not set
# CONFIG_PACKAGE_firewall is not set
# CONFIG_PACKAGE_firewall4 is not set
# CONFIG_PACKAGE_nftables is not set
# CONFIG_PACKAGE_kmod-nft-core is not set
# CONFIG_PACKAGE_iptables is not set
# CONFIG_PACKAGE_dnsmasq is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set
