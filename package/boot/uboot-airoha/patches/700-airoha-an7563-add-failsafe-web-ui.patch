diff --git a/defenvs/an7563_rfb_env b/defenvs/an7563_rfb_env
index 716ddc32..ff9ce266 100644
--- a/defenvs/an7563_rfb_env
+++ b/defenvs/an7563_rfb_env
@@ -2,3 +2,24 @@ loadaddr=0x81800000
 ipaddr=192.168.1.1
 serverip=192.168.1.10
 bootargs=ubi.mtd=ubi root=/dev/ubiblock0_5 rootwait
+
+# Default boot path: read the FIT image directly from the raw 'fip'
+# MTD partition (compatible "denx,fit" on the AN7563 EVB SPI-NAND, no
+# UBI in front of it) into ${loadaddr} and hand off to bootm. The
+# read length 'fitsize' covers the FIT prefix (kernel + dtb, possibly
+# ramdisk); it is bounded by the gap between ${loadaddr} (0x81800000)
+# and CONFIG_TEXT_BASE (0x81E00000) so the fetched blob never
+# overlaps U-Boot itself. Override it via `setenv fitsize 0x...; saveenv`
+# if a larger FIT is flashed.
+#
+# If anything in the chain fails (mtd partition missing, bad FIT,
+# ...), fall through to the failsafe Web UI served by `httpd` on
+# http://${ipaddr}/.
+fitsize=0x500000
+uboot_boot=mtd read fip ${loadaddr} 0x0 ${fitsize} && bootm ${loadaddr}
+bootcmd_failsafe=echo "*** Failsafe Web UI: http://${ipaddr}/ ***"; httpd
+bootcmd=run uboot_boot || run bootcmd_failsafe
+
+# Override the destination MTD partition for failsafe uploads via:
+#   setenv failsafe_part fip; saveenv
+# Default is "fip" (the FIT partition on the AN7563 EVB SPI-NAND).
