diff --git a/board/airoha/an7563/failsafe.c b/board/airoha/an7563/failsafe.c
new file mode 100644
index 00000000..ec9c4de3
--- /dev/null
+++ b/board/airoha/an7563/failsafe.c
@@ -0,0 +1,103 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Author: Ray Liu <ray.xy.liu@gmail.com>
+ *
+ * Airoha AN7563 / AN7552 failsafe Web UI glue.
+ *
+ * Implements the __weak hooks the imported MediaTek failsafe / mtk_httpd
+ * code provides:
+ *
+ *   - httpd_get_upload_buffer_ptr() places the staged firmware blob 32 MiB
+ *     into DRAM, well past CONFIG_TEXT_BASE (0x81E00000) and U-Boot's
+ *     working set on the AN7563 EVB.
+ *   - failsafe_write_image() flashes the staged blob to the MTD partition
+ *     named by env var "failsafe_part" (default: "fip"). Erase + write are
+ *     delegated to the existing "mtd" command so bad-block handling stays
+ *     in one place.
+ *   - failsafe_validate_image() does a minimal sanity check on the image
+ *     size (not bigger than the destination partition).
+ */
+
+#include <command.h>
+#include <env.h>
+#include <errno.h>
+#include <mtd.h>
+#include <linux/mtd/mtd.h>
+#include <vsprintf.h>
+#include <asm/global_data.h>
+
+DECLARE_GLOBAL_DATA_PTR;
+
+#define AN7563_FAILSAFE_UPLOAD_OFFSET	0x02000000	/* 32 MiB */
+#define AN7563_FAILSAFE_DEFAULT_PART	"fip"
+
+void *httpd_get_upload_buffer_ptr(size_t size)
+{
+	return (void *)(uintptr_t)(gd->ram_base + AN7563_FAILSAFE_UPLOAD_OFFSET);
+}
+
+static const char *failsafe_target_part(void)
+{
+	const char *part = env_get("failsafe_part");
+
+	if (!part || !*part)
+		return AN7563_FAILSAFE_DEFAULT_PART;
+	return part;
+}
+
+int failsafe_validate_image(const void *data, size_t size)
+{
+	const char *part = failsafe_target_part();
+	struct mtd_info *mtd;
+
+	if (!size) {
+		printf("Failsafe: empty image\n");
+		return -EINVAL;
+	}
+
+	mtd_probe_devices();
+
+	mtd = get_mtd_device_nm(part);
+	if (IS_ERR_OR_NULL(mtd)) {
+		printf("Failsafe: MTD partition '%s' not found\n", part);
+		return -ENODEV;
+	}
+
+	if ((u64)size > mtd->size) {
+		printf("Failsafe: image (%zu) exceeds partition '%s' (%llu)\n",
+		       size, part, (unsigned long long)mtd->size);
+		put_mtd_device(mtd);
+		return -EFBIG;
+	}
+
+	put_mtd_device(mtd);
+	return 0;
+}
+
+int failsafe_write_image(const void *data, size_t size)
+{
+	const char *part = failsafe_target_part();
+	char cmd[160];
+	int ret;
+
+	printf("\n*** Failsafe upgrade: %zu (0x%zx) bytes -> MTD '%s' ***\n\n",
+	       size, size, part);
+
+	snprintf(cmd, sizeof(cmd), "mtd erase %s", part);
+	ret = run_command(cmd, 0);
+	if (ret) {
+		printf("Failsafe: erase '%s' failed (ret=%d)\n", part, ret);
+		return -EIO;
+	}
+
+	snprintf(cmd, sizeof(cmd), "mtd write %s 0x%lx 0 0x%lx",
+		 part, (unsigned long)(uintptr_t)data, (unsigned long)size);
+	ret = run_command(cmd, 0);
+	if (ret) {
+		printf("Failsafe: write '%s' failed (ret=%d)\n", part, ret);
+		return -EIO;
+	}
+
+	printf("\n*** Failsafe upgrade completed (MTD '%s') ***\n\n", part);
+	return 0;
+}
