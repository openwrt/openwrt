From 86872a5f64e68958cf8af9f48611837a65fbe41d Mon Sep 17 00:00:00 2001
From: Ray Liu <ray.xy.liu@gmail.com>
Date: Thu, 7 May 2026 22:57:26 +0800
Subject: [PATCH] mtd: spi-nand: add Airoha NAND Bad Block Management Table

Add a U-Boot SPI-NAND plug-in for the dual BBT + BMT layout
expected by the Airoha boot ROM. BBT records factory bad blocks
of the system area and shrinks the visible MTD; BMT records
runtime bad-to-pool remappings on read/write/erase failure. Both
tables live in dedicated pool blocks identified by "BMT" / "RAWB"
signatures plus a checksum, and can be reconstructed from OOB
metadata.

Plugged into spinand_probe() via airoha_bmt_attach(), gated by
the "airoha,bmt" DT property and CONFIG_MTD_NAND_AIROHA_BMT
(default off; per-board opt-in).

Signed-off-by: Ray Liu <ray.xy.liu@gmail.com>
---
 drivers/mtd/nand/Kconfig       |   12 +
 drivers/mtd/nand/Makefile      |    1 +
 drivers/mtd/nand/airoha_bmt.c  | 1176 ++++++++++++++++++++++++++++++++
 drivers/mtd/nand/spi/core.c    |    3 +
 include/linux/mtd/airoha_bmt.h |   21 +
 5 files changed, 1213 insertions(+)
 create mode 100644 drivers/mtd/nand/airoha_bmt.c
 create mode 100644 include/linux/mtd/airoha_bmt.h

--- a/drivers/mtd/nand/Kconfig
+++ b/drivers/mtd/nand/Kconfig
@@ -4,3 +4,15 @@ config MTD_NAND_CORE
 source "drivers/mtd/nand/raw/Kconfig"
 
 source "drivers/mtd/nand/spi/Kconfig"
+
+config MTD_NAND_AIROHA_BMT
+	bool "Support Airoha NAND Bad-block Management Table"
+	depends on MTD_SPI_NAND
+	help
+	  Activate the Airoha-style dual BBT + BMT plug-in for SPI-NAND
+	  devices whose device-tree node carries the "airoha,bmt" boolean
+	  property.  The driver mirrors the bootloader/ATF on-flash table
+	  layout used on parts such as EN7512/EN7521/EN7581 so that the
+	  visible MTD shrinks by the factory bad-block count and runtime
+	  bad blocks are remapped into a dedicated pool at the end of
+	  flash.
--- a/drivers/mtd/nand/Makefile
+++ b/drivers/mtd/nand/Makefile
@@ -5,6 +5,7 @@ nandcore-objs := core.o bbt.o
 obj-$(CONFIG_MTD_NAND_CORE) += nandcore.o
 obj-$(CONFIG_MTD_RAW_NAND) += raw/
 obj-$(CONFIG_MTD_SPI_NAND) += spi/
+obj-$(CONFIG_MTD_NAND_AIROHA_BMT) += airoha_bmt.o
 else
 obj-$(CONFIG_$(PHASE_)NAND_SUPPORT) += raw/
 endif
--- /dev/null
+++ b/drivers/mtd/nand/airoha_bmt.c
@@ -0,0 +1,1110 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Airoha NAND Bad Block Management Table for U-Boot
+ *
+ * Copyright (c) 2026 Ray Liu <ray.xy.liu@gmail.com>
+ *
+ * Stand-alone port of the Linux kernel airoha_bmt driver, tailored for
+ * U-Boot (no MediaTek BMT framework dependency).  Implements the dual
+ * BBT + BMT scheme historically used by Airoha (EcoNet) bootloaders /
+ * ATF on parts such as EN7512/EN7521/EN7581:
+ *
+ *   +------------------+----------------+
+ *   |   System area    |   BMT pool     |
+ *   +------------------+----------------+
+ *   0                  system_blks      total_blks
+ *
+ * - BBT records the factory raw bad blocks of the system area.  The
+ *   visible MTD shrinks accordingly and a "skip-bad" lookup table
+ *   translates logical to physical blocks.
+ * - BMT records runtime remappings (bad_index -> pool_index), added on
+ *   read / write / erase failures.
+ * - Both tables live in dedicated blocks of the pool (BMT scanned from
+ *   the end, BBT scanned from the start), are identified by a "BMT" /
+ *   "RAWB" signature plus a checksum, and can be reconstructed by
+ *   walking the OOB metadata of pool blocks.
+ *
+ * Activated when the SPI-NAND device-tree node carries the
+ * "airoha,bmt" property.  airoha_bmt_attach() is invoked from the
+ * SPI-NAND probe path; it loads (or rebuilds) the on-flash tables,
+ * shrinks the visible MTD and overrides the MTD ops with translating
+ * wrappers that route logical block numbers to their physical
+ * counterparts.
+ */
+
+#include <dm.h>
+#include <dm/ofnode.h>
+#include <errno.h>
+#include <log.h>
+#include <malloc.h>
+#include <linux/bitops.h>
+#include <linux/byteorder/generic.h>
+#include <linux/compat.h>
+#include <linux/err.h>
+#include <linux/kernel.h>
+#include <linux/mtd/airoha_bmt.h>
+#include <linux/mtd/mtd.h>
+#include <linux/printk.h>
+#include <linux/string.h>
+#include <linux/types.h>
+
+#define AIROHA_BMT_SIG		"BMT"
+#define AIROHA_BMT_SIG_LEN	3
+#define AIROHA_BBT_SIG		"RAWB"
+#define AIROHA_BBT_SIG_LEN	4
+
+#define AIROHA_BMT_VERSION	1
+#define AIROHA_BBT_VERSION	1
+
+#define AIROHA_DEFAULT_POOL_PCT	8
+/*
+ * Maximum BMT/BBT entry count baked into the boot ROM's on-flash
+ * table layout for the AN7552 / AN7563 / AN7581 / AN7583 / EN7523 /
+ * EN7563 / EN7581 SPI-NAND lineage. Diverging from this value
+ * misaligns entries[] and breaks cross-stage compatibility.
+ */
+#define AIROHA_MAX_BMT_ENTRIES	250
+#define AIROHA_MAX_BBT_ENTRIES	250
+
+#define AIROHA_OOB_BADIDX_OFFSET 2
+#define AIROHA_OOB_BADIDX_SIZE	 2
+
+struct airoha_bmt_entry {
+	__le16 bad_index;
+	__le16 mapped_index;
+} __packed;
+
+struct airoha_bmt_header {
+	char	signature[AIROHA_BMT_SIG_LEN];
+	u8	version;
+	u8	bad_count;
+	u8	mapped_count;
+	u8	checksum;
+	u8	reserved[13];
+} __packed;
+
+struct airoha_bmt_table {
+	struct airoha_bmt_header header;
+	struct airoha_bmt_entry  entries[AIROHA_MAX_BMT_ENTRIES];
+} __packed;
+
+struct airoha_bbt_header {
+	char	signature[AIROHA_BBT_SIG_LEN];
+	__le32	checksum;
+	u8	version;
+	u8	badblock_count;
+	u8	reserved[2];
+} __packed;
+
+struct airoha_bbt_table {
+	struct airoha_bbt_header header;
+	__le16 entries[AIROHA_MAX_BBT_ENTRIES];
+} __packed;
+
+struct airoha_bmt_ctx {
+	struct mtd_info *mtd;
+
+	int (*orig_read_oob)(struct mtd_info *, loff_t,
+			     struct mtd_oob_ops *);
+	int (*orig_write_oob)(struct mtd_info *, loff_t,
+			      struct mtd_oob_ops *);
+	int (*orig_erase)(struct mtd_info *, struct erase_info *);
+	int (*orig_block_isbad)(struct mtd_info *, loff_t);
+	int (*orig_block_markbad)(struct mtd_info *, loff_t);
+
+	void			*buf;
+	struct airoha_bmt_table	*bmt;
+	struct airoha_bbt_table	*bbt;
+	u16			*pbbt;
+	u8			*data_buf;
+
+	u32 total_blks;
+	u32 system_blks;
+	u32 pool_blks;
+	u32 logic_blks;
+	int bmt_block;
+	int bbt_block;
+
+	u32 pg_size;
+	u32 blk_size;
+	u16 pg_shift;
+	u16 blk_shift;
+	u8  oob_offset;
+};
+
+/*
+ * Single global instance.  U-Boot only ever has one SPI-NAND device on
+ * the boot path so a single attached BMT context is sufficient.
+ */
+static struct airoha_bmt_ctx ctx;
+
+/* -------- Low-level helpers (operate on the original MTD ops) -------- */
+static loff_t block_addr(int block)
+{
+	return (loff_t)block << ctx.blk_shift;
+}
+
+/*
+ * The boot ROM uses two distinct OOB markers for bad blocks:
+ *   oob[0] cleared = factory bad block (BAD_BLOCK_RAW)
+ *   oob[1] cleared = runtime BMT-discovered bad pool block
+ * The standard SPI-NAND _block_isbad / _block_markbad touch both
+ * bytes, which would corrupt the distinction; per-marker helpers
+ * below preserve it. The standard isbad is only used to answer
+ * "is this block usable at all" (either marker means no).
+ */
+
+/* Either marker. Reads oob[0] AND oob[1] explicitly so a pool
+ * block previously marked runtime-bad is not re-used as a remap
+ * target (the stock _block_isbad only consults oob[0]).
+ */
+static bool airoha_isbad_any(int block)
+{
+	u8 fdm[2] = { 0xff, 0xff };
+	struct mtd_oob_ops ops = {
+		.mode	 = MTD_OPS_PLACE_OOB,
+		.ooboffs = 0,
+		.ooblen	 = sizeof(fdm),
+		.oobbuf	 = fdm,
+	};
+	int ret;
+
+	ret = ctx.orig_read_oob(ctx.mtd, block_addr(block), &ops);
+	if (ret < 0 && !mtd_is_bitflip(ret))
+		return true;
+	return fdm[0] != 0xff || fdm[1] != 0xff;
+}
+
+/* Byte-0 only (factory bad-block marker). oob_offset is not applied:
+ * the factory marker lives at the start of the OOB regardless of the
+ * BMT-private oob_offset. */
+static bool airoha_isbad_raw(int block)
+{
+	u8 fdm[1];
+	struct mtd_oob_ops ops = {
+		.mode	 = MTD_OPS_PLACE_OOB,
+		.ooboffs = 0,
+		.ooblen	 = sizeof(fdm),
+		.oobbuf	 = fdm,
+	};
+	int ret;
+
+	ret = ctx.orig_read_oob(ctx.mtd, block_addr(block), &ops);
+	if (ret < 0 && !mtd_is_bitflip(ret))
+		return true;
+	return fdm[0] != 0xff;
+}
+
+static int airoha_mark_raw_bad(int block)
+{
+	u8 fdm[2] = { 0x00, 0xff };
+	struct mtd_oob_ops ops = {
+		.mode	 = MTD_OPS_PLACE_OOB,
+		.ooboffs = 0,
+		.ooblen	 = sizeof(fdm),
+		.oobbuf	 = fdm,
+	};
+	return ctx.orig_write_oob(ctx.mtd, block_addr(block), &ops);
+}
+
+static int airoha_mark_pool_bad(int block)
+{
+	u8 fdm[2] = { 0xff, 0x00 };
+	struct mtd_oob_ops ops = {
+		.mode	 = MTD_OPS_PLACE_OOB,
+		.ooboffs = 0,
+		.ooblen	 = sizeof(fdm),
+		.oobbuf	 = fdm,
+	};
+	return ctx.orig_write_oob(ctx.mtd, block_addr(block), &ops);
+}
+
+/* Compatibility shim: code paths that don't care about which marker is
+ * cleared use this -- e.g. erase-failure markbad in the persist path.
+ * Pool blocks get the GENERATE_LATER marker so subsequent ATF pool_size
+ * calculations stay stable; system blocks get the standard raw marker. */
+static int airoha_markbad(int block)
+{
+	if (block >= (int)ctx.system_blks)
+		return airoha_mark_pool_bad(block);
+	return airoha_mark_raw_bad(block);
+}
+
+static int airoha_erase(int block)
+{
+	struct erase_info instr = {
+		.addr	= block_addr(block),
+		.len	= ctx.blk_size,
+	};
+
+	return ctx.orig_erase(ctx.mtd, &instr);
+}
+
+static int airoha_read_data(int block, void *buf, size_t len)
+{
+	struct mtd_oob_ops ops = {
+		.mode	= MTD_OPS_PLACE_OOB,
+		.ooboffs = ctx.oob_offset,
+		.ooblen	= 0,
+		.oobbuf	= NULL,
+		.datbuf	= buf,
+		.len	= len,
+	};
+
+	return ctx.orig_read_oob(ctx.mtd, block_addr(block), &ops);
+}
+
+static int airoha_write_data(int block, const void *buf, size_t len)
+{
+	struct mtd_oob_ops ops = {
+		.mode	= MTD_OPS_PLACE_OOB,
+		.ooboffs = ctx.oob_offset,
+		.ooblen	= 0,
+		.oobbuf	= NULL,
+		.datbuf	= ctx.data_buf,
+		.len	= ctx.pg_size,
+	};
+
+	memset(ctx.data_buf, 0xff, ctx.pg_size);
+	memcpy(ctx.data_buf, buf, min_t(size_t, len, ctx.pg_size));
+
+	return ctx.orig_write_oob(ctx.mtd, block_addr(block), &ops);
+}
+
+static int airoha_read_oob_idx(int block, u16 *bad_idx)
+{
+	u8 fdm[AIROHA_OOB_BADIDX_OFFSET + AIROHA_OOB_BADIDX_SIZE];
+	struct mtd_oob_ops ops = {
+		.mode	= MTD_OPS_PLACE_OOB,
+		.ooboffs = ctx.oob_offset,
+		.ooblen	= sizeof(fdm),
+		.oobbuf	= fdm,
+	};
+	int ret;
+
+	ret = ctx.orig_read_oob(ctx.mtd, block_addr(block), &ops);
+	if (ret < 0 && !mtd_is_bitflip(ret))
+		return ret;
+
+	*bad_idx = (u16)fdm[AIROHA_OOB_BADIDX_OFFSET] |
+		   ((u16)fdm[AIROHA_OOB_BADIDX_OFFSET + 1] << 8);
+	return 0;
+}
+
+static int airoha_write_oob_idx(int block, u16 bad_idx)
+{
+	u8 fdm[AIROHA_OOB_BADIDX_OFFSET + AIROHA_OOB_BADIDX_SIZE];
+	struct mtd_oob_ops ops = {
+		.mode	= MTD_OPS_PLACE_OOB,
+		.ooboffs = ctx.oob_offset,
+		.ooblen	= sizeof(fdm),
+		.oobbuf	= fdm,
+	};
+
+	memset(fdm, 0xff, sizeof(fdm));
+	fdm[AIROHA_OOB_BADIDX_OFFSET]	  = bad_idx & 0xff;
+	fdm[AIROHA_OOB_BADIDX_OFFSET + 1] = (bad_idx >> 8) & 0xff;
+
+	return ctx.orig_write_oob(ctx.mtd, block_addr(block), &ops);
+}
+
+static int airoha_copy_block(int dest, int src, loff_t max_offset)
+{
+	int pages = ctx.blk_size >> ctx.pg_shift;
+	loff_t src_addr = block_addr(src);
+	loff_t dest_addr = block_addr(dest);
+	loff_t offset = 0;
+	u8 oob[64];
+	int i, ret;
+
+	for (i = 0; i < pages; i++) {
+		struct mtd_oob_ops rd = {
+			.mode	= MTD_OPS_PLACE_OOB,
+			.oobbuf	= oob,
+			.ooblen	= min_t(int, ctx.mtd->oobsize / pages,
+					sizeof(oob)),
+			.datbuf	= ctx.data_buf,
+			.len	= ctx.pg_size,
+		};
+		struct mtd_oob_ops wr = {
+			.mode	= MTD_OPS_PLACE_OOB,
+			.oobbuf	= oob,
+			.datbuf	= ctx.data_buf,
+			.len	= ctx.pg_size,
+		};
+
+		if (offset >= max_offset)
+			break;
+
+		ret = ctx.orig_read_oob(ctx.mtd, src_addr + offset, &rd);
+		if (ret < 0 && !mtd_is_bitflip(ret))
+			return ret;
+		if (!rd.retlen)
+			break;
+
+		ret = ctx.orig_write_oob(ctx.mtd, dest_addr + offset, &wr);
+		if (ret < 0)
+			return ret;
+
+		wr.ooblen = rd.oobretlen;
+		offset += rd.retlen;
+	}
+
+	return 0;
+}
+
+/* -------- Checksum helpers --------
+ *
+ * Byte ranges and integer widths must match the on-flash layout
+ * produced by the boot ROM. The BMT checksum is a u8 sum over the
+ * first pool_size * sizeof(bmt_entry) bytes of the entries table
+ * (NOT the full table); the BBT checksum is a u16 sum over the
+ * entire badblock_table, stored zero-extended into a u32 field.
+ */
+static u8 bmt_calc_checksum(const struct airoha_bmt_table *bmt)
+{
+	const u8 *p = (const u8 *)bmt->entries;
+	u8 sum = bmt->header.version + bmt->header.mapped_count;
+	int i, n = (int)(ctx.pool_blks * sizeof(struct airoha_bmt_entry));
+
+	for (i = 0; i < n; i++)
+		sum += p[i];
+
+	return sum;
+}
+
+static u32 bbt_calc_checksum(const struct airoha_bbt_table *bbt)
+{
+	const u8 *p = (const u8 *)bbt->entries;
+	u16 sum = bbt->header.version + bbt->header.badblock_count;
+	int i;
+
+	for (i = 0; i < (int)sizeof(bbt->entries); i++)
+		sum += p[i];
+
+	return (u32)sum;
+}
+
+/* -------- Table introspection -------- */
+static int bmt_find_by_bad(int phys)
+{
+	int i;
+
+	for (i = 0; i < ctx.bmt->header.mapped_count; i++) {
+		if (le16_to_cpu(ctx.bmt->entries[i].bad_index) == (u16)phys)
+			return i;
+	}
+	return -1;
+}
+
+static int bmt_find_by_mapped(int phys)
+{
+	int i;
+
+	for (i = 0; i < ctx.bmt->header.mapped_count; i++) {
+		if (le16_to_cpu(ctx.bmt->entries[i].mapped_index) == (u16)phys)
+			return i;
+	}
+	return -1;
+}
+
+static bool bbt_contains(int phys)
+{
+	int i;
+
+	for (i = 0; i < ctx.bbt->header.badblock_count; i++) {
+		if (le16_to_cpu(ctx.bbt->entries[i]) == (u16)phys)
+			return true;
+	}
+	return false;
+}
+
+/* -------- Pool-block search -------- */
+static int find_available_pool_block(bool from_end)
+{
+	int start = from_end ? (int)ctx.total_blks - 1 : (int)ctx.system_blks;
+	int dir = from_end ? -1 : 1;
+	int i;
+
+	for (i = 0; i < (int)ctx.pool_blks; i++) {
+		int block = start + dir * i;
+
+		if (block == ctx.bmt_block || block == ctx.bbt_block)
+			continue;
+		if (airoha_isbad_any(block))
+			continue;
+		if (bmt_find_by_mapped(block) >= 0)
+			continue;
+		if (airoha_erase(block)) {
+			airoha_markbad(block);
+			continue;
+		}
+		return block;
+	}
+	return -1;
+}
+
+/* -------- Persisting tables -------- */
+static bool bmt_entries_valid(void)
+{
+	int i;
+
+	for (i = 0; i < ctx.bmt->header.mapped_count; i++) {
+		u16 b = le16_to_cpu(ctx.bmt->entries[i].bad_index);
+		u16 m = le16_to_cpu(ctx.bmt->entries[i].mapped_index);
+
+		if (b >= ctx.total_blks || m >= ctx.total_blks ||
+		    m < ctx.system_blks)
+			return false;
+	}
+	return true;
+}
+
+static bool bbt_entries_valid(void)
+{
+	int i;
+
+	for (i = 0; i < ctx.bbt->header.badblock_count; i++) {
+		if (le16_to_cpu(ctx.bbt->entries[i]) >= ctx.system_blks)
+			return false;
+	}
+	return true;
+}
+
+static int load_bmt(void)
+{
+	int block;
+
+	for (block = (int)ctx.total_blks - 1;
+	     block >= (int)ctx.system_blks; block--) {
+		if (airoha_isbad_any(block))
+			continue;
+		if (airoha_read_data(block, ctx.bmt, sizeof(*ctx.bmt)))
+			continue;
+		if (memcmp(ctx.bmt->header.signature, AIROHA_BMT_SIG,
+			   AIROHA_BMT_SIG_LEN) != 0)
+			continue;
+		if (ctx.bmt->header.checksum != bmt_calc_checksum(ctx.bmt))
+			continue;
+		if (ctx.bmt->header.mapped_count > AIROHA_MAX_BMT_ENTRIES)
+			continue;
+		if (!bmt_entries_valid())
+			continue;
+
+		ctx.bmt_block = block;
+		printf("airoha-bmt: BMT v%u found at block %d (%u entries)\n",
+		       ctx.bmt->header.version, block,
+		       ctx.bmt->header.mapped_count);
+		return 0;
+	}
+
+	memset(ctx.bmt, 0, sizeof(*ctx.bmt));
+	return -ENOENT;
+}
+
+static int load_bbt(void)
+{
+	int block;
+
+	for (block = (int)ctx.system_blks; block < (int)ctx.total_blks;
+	     block++) {
+		if (block == ctx.bmt_block)
+			continue;
+		if (airoha_isbad_any(block))
+			continue;
+		if (airoha_read_data(block, ctx.bbt, sizeof(*ctx.bbt)))
+			continue;
+		if (memcmp(ctx.bbt->header.signature, AIROHA_BBT_SIG,
+			   AIROHA_BBT_SIG_LEN) != 0)
+			continue;
+		if (le32_to_cpu(ctx.bbt->header.checksum) !=
+		    bbt_calc_checksum(ctx.bbt))
+			continue;
+		if (ctx.bbt->header.badblock_count > AIROHA_MAX_BBT_ENTRIES)
+			continue;
+		if (!bbt_entries_valid())
+			continue;
+
+		ctx.bbt_block = block;
+		printf("airoha-bmt: BBT v%u found at block %d (%u bad blocks)\n",
+		       ctx.bbt->header.version, block,
+		       ctx.bbt->header.badblock_count);
+		return 0;
+	}
+
+	memset(ctx.bbt, 0, sizeof(*ctx.bbt));
+	return -ENOENT;
+}
+
+static int airoha_save_bmt(void)
+{
+	int block, ret;
+
+	memcpy(ctx.bmt->header.signature, AIROHA_BMT_SIG, AIROHA_BMT_SIG_LEN);
+	ctx.bmt->header.version = AIROHA_BMT_VERSION;
+	ctx.bmt->header.checksum = bmt_calc_checksum(ctx.bmt);
+
+	if (ctx.bmt_block < 0) {
+		ctx.bmt_block = find_available_pool_block(true);
+		if (ctx.bmt_block < 0)
+			return -ENOSPC;
+	}
+
+	block = ctx.bmt_block;
+retry:
+	if (airoha_erase(block)) {
+		airoha_markbad(block);
+		block = find_available_pool_block(true);
+		if (block < 0)
+			return -ENOSPC;
+		ctx.bmt_block = block;
+		goto retry;
+	}
+
+	ret = airoha_write_data(block, ctx.bmt, sizeof(*ctx.bmt));
+	if (ret) {
+		airoha_markbad(block);
+		block = find_available_pool_block(true);
+		if (block < 0)
+			return -ENOSPC;
+		ctx.bmt_block = block;
+		goto retry;
+	}
+
+	printf("airoha-bmt: BMT written to block %d\n", ctx.bmt_block);
+	return 0;
+}
+
+static int airoha_save_bbt(void)
+{
+	int block, ret;
+
+	memcpy(ctx.bbt->header.signature, AIROHA_BBT_SIG, AIROHA_BBT_SIG_LEN);
+	ctx.bbt->header.version = AIROHA_BBT_VERSION;
+	ctx.bbt->header.checksum = cpu_to_le32(bbt_calc_checksum(ctx.bbt));
+
+	if (ctx.bbt_block < 0) {
+		ctx.bbt_block = find_available_pool_block(false);
+		if (ctx.bbt_block < 0)
+			return -ENOSPC;
+	}
+
+	block = ctx.bbt_block;
+retry:
+	if (airoha_erase(block)) {
+		airoha_markbad(block);
+		block = find_available_pool_block(false);
+		if (block < 0)
+			return -ENOSPC;
+		ctx.bbt_block = block;
+		goto retry;
+	}
+
+	ret = airoha_write_data(block, ctx.bbt, sizeof(*ctx.bbt));
+	if (ret) {
+		airoha_markbad(block);
+		block = find_available_pool_block(false);
+		if (block < 0)
+			return -ENOSPC;
+		ctx.bbt_block = block;
+		goto retry;
+	}
+
+	printf("airoha-bmt: BBT written to block %d\n", ctx.bbt_block);
+	return 0;
+}
+
+/* -------- Reconstruction --------
+ *
+ * reconstruct_bbt() mirrors the ATF preloader's scan_badblock_raw():
+ * we only catalogue system blocks whose oob[0] is cleared (factory
+ * bad) AND that are not already tracked by the BMT.  Counting
+ * BMT-mapped runtime bad blocks here would double-shrink the visible
+ * MTD and shift partition offsets out from under user-space, so the
+ * BBT must contain factory-bad blocks only.  This also requires
+ * reconstruct_bmt() to run before reconstruct_bbt() (enforced in
+ * airoha_bmt_attach()).
+ */
+static void reconstruct_bbt(void)
+{
+	int i, count = 0;
+
+	memset(ctx.bbt, 0, sizeof(*ctx.bbt));
+	for (i = 0; i < (int)ctx.system_blks &&
+	     count < AIROHA_MAX_BBT_ENTRIES; i++) {
+		if (!airoha_isbad_raw(i))
+			continue;
+		if (bmt_find_by_bad(i) >= 0)
+			continue;
+		ctx.bbt->entries[count++] = cpu_to_le16((u16)i);
+	}
+	ctx.bbt->header.badblock_count = count;
+	printf("airoha-bmt: rebuilt BBT, %d raw bad blocks\n", count);
+}
+
+static void reconstruct_bmt(void)
+{
+	int block, count = 0;
+
+	memset(ctx.bmt, 0, sizeof(*ctx.bmt));
+	for (block = (int)ctx.total_blks - 1;
+	     block >= (int)ctx.system_blks &&
+	     count < AIROHA_MAX_BMT_ENTRIES; block--) {
+		u16 bad_idx;
+
+		if (block == ctx.bmt_block || block == ctx.bbt_block)
+			continue;
+		if (airoha_isbad_any(block))
+			continue;
+		if (airoha_read_oob_idx(block, &bad_idx))
+			continue;
+		if (bad_idx == 0xffff || bad_idx >= ctx.system_blks)
+			continue;
+
+		ctx.bmt->entries[count].bad_index    = cpu_to_le16(bad_idx);
+		ctx.bmt->entries[count].mapped_index = cpu_to_le16((u16)block);
+		count++;
+	}
+	ctx.bmt->header.mapped_count = count;
+	printf("airoha-bmt: rebuilt BMT, %d remappings\n", count);
+}
+
+/* -------- pBbt build -------- */
+static void build_pbbt(void)
+{
+	int i, k = 0;
+
+	for (i = 0; i < (int)ctx.system_blks; i++) {
+		if (bbt_contains(i))
+			continue;
+		ctx.pbbt[k++] = (u16)i;
+	}
+	ctx.logic_blks = k;
+}
+
+/* -------- Translation -------- */
+static int translate_via_bbt(int logical)
+{
+	if (logical < 0 || logical >= (int)ctx.logic_blks)
+		return logical;
+	return ctx.pbbt[logical];
+}
+
+static int translate_via_bmt(int phys)
+{
+	int idx = bmt_find_by_bad(phys);
+
+	return idx < 0 ? phys :
+		le16_to_cpu(ctx.bmt->entries[idx].mapped_index);
+}
+
+static int airoha_get_mapping_block(int block)
+{
+	if (block < 0 || block >= (int)ctx.logic_blks)
+		return block;
+	return translate_via_bmt(translate_via_bbt(block));
+}
+
+/* -------- Runtime block remapping -------- */
+static bool airoha_remap_block(u16 block, u16 mapped_block, int copy_len)
+{
+	int new_block, idx;
+	u16 orig_bad;
+
+	new_block = find_available_pool_block(false);
+	if (new_block < 0) {
+		printf("airoha-bmt: BMT pool exhausted\n");
+		return false;
+	}
+
+	if (copy_len > 0)
+		airoha_copy_block(new_block, mapped_block, copy_len);
+
+	idx = bmt_find_by_mapped(mapped_block);
+	if (idx >= 0) {
+		/* `mapped_block` was already a pool replacement for an earlier
+		 * system bad block. Stash that *original* system bad_index in
+		 * the new pool block's OOB so OOB-based reconstruction
+		 * (reconstruct_bmt()) keeps working, and just update the
+		 * existing BMT entry's mapped_index to the new replacement. */
+		orig_bad = le16_to_cpu(ctx.bmt->entries[idx].bad_index);
+		ctx.bmt->entries[idx].mapped_index = cpu_to_le16((u16)new_block);
+	} else {
+		if (ctx.bmt->header.mapped_count >= AIROHA_MAX_BMT_ENTRIES) {
+			printf("airoha-bmt: BMT table full\n");
+			return false;
+		}
+		idx = ctx.bmt->header.mapped_count++;
+		orig_bad = mapped_block;
+		ctx.bmt->entries[idx].bad_index    = cpu_to_le16(mapped_block);
+		ctx.bmt->entries[idx].mapped_index = cpu_to_le16((u16)new_block);
+	}
+
+	airoha_write_oob_idx(new_block, orig_bad);
+	/* Match ATF update_bmt(): mark the failing block with the marker
+	 * appropriate for its area (raw for system, GENERATE_LATER for
+	 * pool).  Using the standard SPI-NAND markbad here would clear
+	 * BOTH oob[0] and oob[1] and silently drift pool_size on every
+	 * boot. */
+	if (mapped_block >= ctx.system_blks)
+		airoha_mark_pool_bad(mapped_block);
+	else
+		airoha_mark_raw_bad(mapped_block);
+
+	if (airoha_save_bmt()) {
+		printf("airoha-bmt: failed to persist BMT\n");
+		return false;
+	}
+
+	printf("airoha-bmt: remapped block %u -> %d\n",
+	       mapped_block, new_block);
+	return true;
+}
+
+/* -------- Translating MTD ops (the "hooked" function pointers) -------- */
+static int airoha_bmt_read(struct mtd_info *mtd, loff_t from,
+			   struct mtd_oob_ops *ops)
+{
+	struct mtd_oob_ops cur_ops = *ops;
+	int retry_count = 0;
+	loff_t cur_from;
+	int ret = 0;
+	int max_bitflips = 0;
+
+	ops->retlen = 0;
+	ops->oobretlen = 0;
+
+	while (ops->retlen < ops->len || ops->oobretlen < ops->ooblen) {
+		int cur_ret;
+		u32 offset = from & (ctx.blk_size - 1);
+		u32 block = from >> ctx.blk_shift;
+		int cur_block;
+
+		cur_block = airoha_get_mapping_block(block);
+		if (cur_block < 0)
+			return -EIO;
+
+		cur_from = ((loff_t)cur_block << ctx.blk_shift) + offset;
+
+		cur_ops.oobretlen = 0;
+		cur_ops.retlen = 0;
+		cur_ops.len = min_t(u32, mtd->erasesize - offset,
+				    ops->len - ops->retlen);
+		cur_ret = ctx.orig_read_oob(mtd, cur_from, &cur_ops);
+		if (cur_ret < 0)
+			ret = cur_ret;
+		else
+			max_bitflips = max_t(int, max_bitflips, cur_ret);
+		if (cur_ret < 0 && !mtd_is_bitflip(cur_ret)) {
+			if (airoha_remap_block(block, cur_block,
+					       mtd->erasesize) &&
+			    retry_count++ < 10)
+				continue;
+			goto out;
+		}
+
+		if (mtd->bitflip_threshold &&
+		    cur_ret >= mtd->bitflip_threshold)
+			airoha_remap_block(block, cur_block, mtd->erasesize);
+
+		ops->retlen += cur_ops.retlen;
+		ops->oobretlen += cur_ops.oobretlen;
+
+		cur_ops.ooboffs = 0;
+		cur_ops.datbuf += cur_ops.retlen;
+		cur_ops.oobbuf += cur_ops.oobretlen;
+		cur_ops.ooblen -= cur_ops.oobretlen;
+
+		if (!cur_ops.len)
+			cur_ops.len = mtd->erasesize - offset;
+
+		from += cur_ops.len;
+		retry_count = 0;
+	}
+
+out:
+	if (ret < 0)
+		return ret;
+	return max_bitflips;
+}
+
+static int airoha_bmt_write(struct mtd_info *mtd, loff_t to,
+			    struct mtd_oob_ops *ops)
+{
+	struct mtd_oob_ops cur_ops = *ops;
+	int retry_count = 0;
+	loff_t cur_to;
+	int ret;
+
+	ops->retlen = 0;
+	ops->oobretlen = 0;
+
+	while (ops->retlen < ops->len || ops->oobretlen < ops->ooblen) {
+		u32 offset = to & (ctx.blk_size - 1);
+		u32 block = to >> ctx.blk_shift;
+		int cur_block;
+
+		cur_block = airoha_get_mapping_block(block);
+		if (cur_block < 0)
+			return -EIO;
+
+		cur_to = ((loff_t)cur_block << ctx.blk_shift) + offset;
+
+		cur_ops.oobretlen = 0;
+		cur_ops.retlen = 0;
+		cur_ops.len = min_t(u32, ctx.blk_size - offset,
+				    ops->len - ops->retlen);
+		ret = ctx.orig_write_oob(mtd, cur_to, &cur_ops);
+		if (ret < 0) {
+			if (airoha_remap_block(block, cur_block, offset) &&
+			    retry_count++ < 10)
+				continue;
+			return ret;
+		}
+
+		ops->retlen += cur_ops.retlen;
+		ops->oobretlen += cur_ops.oobretlen;
+
+		cur_ops.ooboffs = 0;
+		cur_ops.datbuf += cur_ops.retlen;
+		cur_ops.oobbuf += cur_ops.oobretlen;
+		cur_ops.ooblen -= cur_ops.oobretlen;
+
+		if (!cur_ops.len)
+			cur_ops.len = mtd->erasesize - offset;
+
+		to += cur_ops.len;
+		retry_count = 0;
+	}
+
+	return 0;
+}
+
+static int airoha_bmt_mtd_erase(struct mtd_info *mtd, struct erase_info *instr)
+{
+	struct erase_info mapped = {
+		.len = ctx.blk_size,
+	};
+	int retry_count = 0;
+	u64 start_addr, end_addr;
+	int ret = 0;
+	u16 orig_block;
+	int block;
+
+	start_addr = instr->addr & (~mtd->erasesize_mask);
+	end_addr = instr->addr + instr->len;
+
+	while (start_addr < end_addr) {
+		orig_block = start_addr >> ctx.blk_shift;
+		block = airoha_get_mapping_block(orig_block);
+		if (block < 0)
+			return -EIO;
+		mapped.addr = (loff_t)block << ctx.blk_shift;
+		ret = ctx.orig_erase(mtd, &mapped);
+		if (ret) {
+			if (airoha_remap_block(orig_block, block, 0) &&
+			    retry_count++ < 10)
+				continue;
+			instr->fail_addr = start_addr;
+			break;
+		}
+		start_addr += mtd->erasesize;
+		retry_count = 0;
+	}
+
+	return ret;
+}
+
+static int airoha_bmt_block_isbad(struct mtd_info *mtd, loff_t ofs)
+{
+	int retry_count = 0;
+	u16 orig_block = ofs >> ctx.blk_shift;
+	u16 block;
+	int ret;
+
+retry:
+	block = airoha_get_mapping_block(orig_block);
+	ret = ctx.orig_block_isbad(mtd, (loff_t)block << ctx.blk_shift);
+	if (ret) {
+		if (airoha_remap_block(orig_block, block, ctx.blk_size) &&
+		    retry_count++ < 10)
+			goto retry;
+	}
+	return ret;
+}
+
+static int airoha_bmt_block_markbad(struct mtd_info *mtd, loff_t ofs)
+{
+	u16 orig_block = ofs >> ctx.blk_shift;
+	int block;
+
+	block = airoha_get_mapping_block(orig_block);
+	if (block < 0)
+		return -EIO;
+
+	airoha_remap_block(orig_block, block, ctx.blk_size);
+
+	return ctx.orig_block_markbad(mtd, (loff_t)block << ctx.blk_shift);
+}
+
+/* -------- Pool size calculation --------
+ *
+ * Walk backwards from the last block of flash, counting GOOD blocks
+ * (oob[0] only) until 8% of total_blks is reached, then return
+ * total_blks - last_walked_block. Checking only oob[0] keeps the
+ * answer stable across boots; consulting oob[1] would let runtime
+ * GENERATE_LATER pool blocks drift pool_size and invalidate the BMT
+ * checksum scope.
+ */
+static u32 airoha_calc_pool_size(void)
+{
+	u32 need = (ctx.total_blks * AIROHA_DEFAULT_POOL_PCT) / 100;
+	u32 valid = 0;
+	int blk = (int)ctx.total_blks - 1;
+
+	if (need < 1)
+		need = 1;
+	for (; blk > 0; blk--) {
+		if (airoha_isbad_raw(blk))
+			continue;
+		if (++valid == need)
+			break;
+	}
+	return ctx.total_blks - blk;
+}
+
+/* -------- Public attach / detach API -------- */
+int airoha_bmt_attach(struct mtd_info *mtd)
+{
+	ofnode np;
+	u32 pool_size = 0;
+	u32 oob_offset = 0;
+	size_t total_buf;
+
+	if (!mtd)
+		return 0;
+
+	np = mtd_get_ofnode(mtd);
+	if (!ofnode_valid(np))
+		return 0;
+	if (!ofnode_read_bool(np, "airoha,bmt"))
+		return 0;
+
+	if (ctx.mtd) {
+		printf("airoha-bmt: another device already attached\n");
+		return -ENOSPC;
+	}
+
+	memset(&ctx, 0, sizeof(ctx));
+	ctx.mtd       = mtd;
+	ctx.bmt_block = -1;
+	ctx.bbt_block = -1;
+	ctx.blk_size  = mtd->erasesize;
+	ctx.blk_shift = ffs(ctx.blk_size) - 1;
+	ctx.pg_size   = mtd->writesize;
+	ctx.pg_shift  = ffs(ctx.pg_size) - 1;
+	ctx.total_blks = mtd->size >> ctx.blk_shift;
+
+	if (!ofnode_read_u32(np, "airoha,bmt-oob-offset", &oob_offset))
+		ctx.oob_offset = oob_offset & 0xff;
+
+	/* Save the original (un-hooked) MTD ops *before* computing
+	 * pool_size: airoha_calc_pool_size() reads OOB on every block via
+	 * ctx.orig_read_oob, which must already be bound to the SPI-NAND
+	 * core's spinand_mtd_read.  Hooking happens at the very end of
+	 * airoha_bmt_attach(). */
+	ctx.orig_read_oob	= mtd->_read_oob;
+	ctx.orig_write_oob	= mtd->_write_oob;
+	ctx.orig_erase		= mtd->_erase;
+	ctx.orig_block_isbad	= mtd->_block_isbad;
+	ctx.orig_block_markbad	= mtd->_block_markbad;
+
+	if (ofnode_read_u32(np, "airoha,bmt-pool-size", &pool_size) ||
+	    pool_size == 0)
+		pool_size = airoha_calc_pool_size();
+	if (pool_size < 8)
+		pool_size = 8;
+	/* Hard cap at AIROHA_MAX_BMT_ENTRIES so the BMT checksum scope
+	 * (pool_size * sizeof(entry)) stays inside the on-flash buffer
+	 * the boot ROM expects. */
+	if (pool_size > AIROHA_MAX_BMT_ENTRIES)
+		pool_size = AIROHA_MAX_BMT_ENTRIES;
+	if (pool_size >= ctx.total_blks / 2)
+		pool_size = ctx.total_blks / 8;
+
+	ctx.pool_blks   = pool_size;
+	ctx.system_blks = ctx.total_blks - pool_size;
+
+	/* Allocate the BMT/BBT tables and pBbt index together, but keep
+	 * data_buf in its own kzalloc() so it gets natural sizeof(void *)
+	 * alignment. Embedding data_buf at e.g. `pbbt + system_blks`
+	 * would land it on a 4-byte boundary (sizeof(airoha_bmt_table) =
+	 * 532 is 4 mod 8) and force the spi-mem core to bounce-buffer
+	 * every NAND access.
+	 */
+	total_buf = sizeof(*ctx.bmt) + sizeof(*ctx.bbt) +
+		    ctx.system_blks * sizeof(u16);
+	ctx.buf = kzalloc(total_buf, GFP_KERNEL);
+	if (!ctx.buf) {
+		ctx.mtd = NULL;
+		return -ENOMEM;
+	}
+	ctx.data_buf = kzalloc(ctx.pg_size + mtd->oobsize, GFP_KERNEL);
+	if (!ctx.data_buf) {
+		kfree(ctx.buf);
+		ctx.buf = NULL;
+		ctx.mtd = NULL;
+		return -ENOMEM;
+	}
+
+	ctx.bmt  = (struct airoha_bmt_table *)ctx.buf;
+	ctx.bbt  = (struct airoha_bbt_table *)
+			((u8 *)ctx.buf + sizeof(*ctx.bmt));
+	ctx.pbbt = (u16 *)((u8 *)ctx.buf + sizeof(*ctx.bmt) +
+			   sizeof(*ctx.bbt));
+
+	/* Load BMT first so reconstruct_bbt() can exclude blocks already
+	 * tracked by the BMT (matching ATF's is_badblock_raw() filter). */
+	if (load_bmt())
+		reconstruct_bmt();
+	if (load_bbt())
+		reconstruct_bbt();
+
+	build_pbbt();
+
+	mtd->size = (u64)ctx.logic_blks << ctx.blk_shift;
+
+	if (ctx.bmt_block < 0)
+		airoha_save_bmt();
+	if (ctx.bbt_block < 0)
+		airoha_save_bbt();
+
+	mtd->_read_oob		= airoha_bmt_read;
+	mtd->_write_oob		= airoha_bmt_write;
+	mtd->_erase		= airoha_bmt_mtd_erase;
+	mtd->_block_isbad	= airoha_bmt_block_isbad;
+	mtd->_block_markbad	= airoha_bmt_block_markbad;
+
+	printf("airoha-bmt: total=%u system=%u pool=%u logic=%u BBT@%d BMT@%d\n",
+	       ctx.total_blks, ctx.system_blks, ctx.pool_blks, ctx.logic_blks,
+	       ctx.bbt_block, ctx.bmt_block);
+
+	return 0;
+}
+
+void airoha_bmt_detach(struct mtd_info *mtd)
+{
+	if (!mtd || ctx.mtd != mtd)
+		return;
+
+	mtd->_read_oob		= ctx.orig_read_oob;
+	mtd->_write_oob		= ctx.orig_write_oob;
+	mtd->_erase		= ctx.orig_erase;
+	mtd->_block_isbad	= ctx.orig_block_isbad;
+	mtd->_block_markbad	= ctx.orig_block_markbad;
+	mtd->size = (u64)ctx.total_blks << ctx.blk_shift;
+
+	kfree(ctx.data_buf);
+	kfree(ctx.buf);
+	memset(&ctx, 0, sizeof(ctx));
+}
