diff --git a/defenvs/en7523-tplink-ex530v_v1_env b/defenvs/en7523-tplink-ex530v_v1_env
new file mode 100644
index 00000000000..21c39f65a52
--- /dev/null
+++ b/defenvs/en7523-tplink-ex530v_v1_env
@@ -0,0 +1,36 @@
+loadaddr=0x86a00000
+ipaddr=192.168.1.1
+serverip=192.168.1.10
+bootloaderfile=openwrt-airoha-en7523-tplink_xx230v_v1-uboot-bootloader.bin
+bootfile=openwrt-airoha-en7523-tplink_xx230v_v1-initramfs-kernel.bin
+firfile=openwrt-airoha-en7523-tplink_xx230v_v1-squashfs-sysupgrade.bin
+bootled_pwr=green:power
+ubi_read_openwrt=ubi read $loadaddr fit && iminfo $loadaddr
+boot_openwrt=led $bootled_pwr on ; run ubi_read_openwrt && bootm $loadaddr#$bootconf ; led $bootled_pwr off
+boot_ubi=ubi part ubi && run boot_openwrt
+boot_tftp=tftpboot $loadaddr $bootfile && bootm $loadaddr#$bootconf
+install_bootloader=tftpboot $loadaddr $bootloaderfile && mtd write spi-nand0 $loadaddr 0x0 $filesize
+firm_install=tftpboot $loadaddr $firfile && ubi write $loadaddr fit 0x$filesize
+xx230_ubi_part=setenv art_size 0x1a0000 && run format_ubi_part
+xx530_ubi_part=setenv art_size 0x2a0000 && run format_ubi_part
+format_ubi_part=mtd read spi-nand0 $loadaddr 0xa0000 $art_size && \
+ mtd erase ubi && \
+ ubi part ubi && \
+ ubi create ubootenv 0x1f000 && \
+ ubi create ubootenv2 0x1f000 && \
+ ubi create art $art_size && \
+ ubi write $loadaddr art $art_size && \
+ ubi create firmware
+bootconf=config-1
+bootcmd=run boot_ubi
+bootdelay=3
+bootmenu_confirm_return=askenv - Press ENTER to return to menu ; bootmenu 20
+bootmenu_default=0
+bootmenu_delay=3
+bootmenu_title=      34m( ( ( mOpenWrt34m ) ) )
+bootmenu_0=Run default boot command.=run boot_openwrt
+bootmenu_1=Boot system via TFTP.=run boot_tftp ; run bootmenu_confirm_return
+bootmenu_2=Format UBI partition xx230v.=run xx230_ubi_part
+bootmenu_3=Format UBI partition xx530v.=run xx530_ubi_part
+bootmenu_4=Install U-Boot.=run install_bootloader
+bootmenu_5=Reboot.=reset
