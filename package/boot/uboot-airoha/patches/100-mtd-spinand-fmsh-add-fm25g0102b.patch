+#define FM25G01B_STATUS_ECC_1_3_BITFLIPS       (1 << 4)
+#define FM25G01B_STATUS_ECC_4_BITFLIPS         (2 << 4)
+#define FM25G01B_STATUS_ECC_5_BITFLIPS         (3 << 4)
