#!/bin/sh /etc/rc.common
# Photonicat 2 fan control daemon and hardware config

START=99
USE_PROCD=1

start_service() {
	procd_open_instance photonicat-fan
	procd_set_param command /usr/sbin/photonicat-fan
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "photonicat"
}

boot() {
	# Apply CPU governor from UCI config at boot
	. /lib/functions.sh
	config_load photonicat
	local governor
	config_get governor cpu governor "schedutil"
	for policy in /sys/devices/system/cpu/cpufreq/policy*; do
		[ -f "$policy/scaling_governor" ] && \
			echo "$governor" > "$policy/scaling_governor" 2>/dev/null
	done
	start
}
