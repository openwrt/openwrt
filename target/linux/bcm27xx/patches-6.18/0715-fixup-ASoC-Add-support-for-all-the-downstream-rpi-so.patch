From 060fea8f35a11d05a42e26229acd3e0c11d9caf1 Mon Sep 17 00:00:00 2001
From: Phil Elwell <phil@raspberrypi.com>
Date: Tue, 5 May 2026 09:15:38 +0100
Subject: [PATCH] fixup! ASoC: Add support for all the downstream rpi sound
 card drivers

Bump the maximum sample rate to 384kHz. This is technically out of spec,
so caveat emptor.

Fixes: https://github.com/raspberrypi/linux/issues/3835

Signed-off-by: Phil Elwell <phil@raspberrypi.com>
---
 sound/soc/codecs/pcm1794a.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

--- a/sound/soc/codecs/pcm1794a.c
+++ b/sound/soc/codecs/pcm1794a.c
@@ -26,7 +26,7 @@ static struct snd_soc_dai_driver pcm1794
 	.playback = {
 		.channels_min = 2,
 		.channels_max = 2,
-		.rates = SNDRV_PCM_RATE_8000_192000,
+		.rates = SNDRV_PCM_RATE_8000_384000,
 		.formats = SNDRV_PCM_FMTBIT_S16_LE |
 			   SNDRV_PCM_FMTBIT_S24_LE
 	},
