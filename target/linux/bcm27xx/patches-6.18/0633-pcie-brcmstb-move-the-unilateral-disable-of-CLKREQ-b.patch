From df289f8bf714b523075211ab86cdba3c21a6e018 Mon Sep 17 00:00:00 2001
From: Jonathan Bell <jonathan@raspberrypi.com>
Date: Thu, 5 Feb 2026 11:22:51 +0000
Subject: [PATCH] pcie-brcmstb: move the unilateral disable of CLKREQ# before
 link-up

If a platform has a pull-up on CLKREQ# with no endpoint control, then
this could cause link failure in the idle time between PERST# deassert
and brcm_config_clkreq().

Signed-off-by: Jonathan Bell <jonathan@raspberrypi.com>
---
 drivers/pci/controller/pcie-brcmstb.c | 11 ++++++-----
 1 file changed, 6 insertions(+), 5 deletions(-)

--- a/drivers/pci/controller/pcie-brcmstb.c
+++ b/drivers/pci/controller/pcie-brcmstb.c
@@ -1575,7 +1575,7 @@ static void brcm_config_clkreq(struct br
 {
 	static const char err_msg[] = "invalid 'brcm,clkreq-mode' DT string\n";
 	const char *mode = "default";
-	u32 clkreq_cntl;
+	u32 clkreq_cntl = 0;
 	int ret, tmp;
 
 	ret = of_property_read_string(pcie->np, "brcm,clkreq-mode", &mode);
@@ -1584,10 +1584,6 @@ static void brcm_config_clkreq(struct br
 		mode = "safe";
 	}
 
-	/* Start out assuming safe mode (both mode bits cleared) */
-	clkreq_cntl = readl(pcie->base + HARD_DEBUG(pcie));
-	clkreq_cntl &= ~PCIE_CLKREQ_MASK;
-
 	if (strcmp(mode, "no-l1ss") == 0) {
 		/*
 		 * "no-l1ss" -- Provides Clock Power Management, L0s, and
@@ -1784,6 +1780,11 @@ static int brcm_pcie_start_link(struct b
 
 	brcm_pcie_stats_trigger(pcie, 0);
 
+	/* Disable CLKREQ# input prior to link-up */
+	tmp = readl(pcie->base + HARD_DEBUG(pcie));
+	tmp &= ~PCIE_CLKREQ_MASK;
+	writel(tmp, pcie->base + HARD_DEBUG(pcie));
+
 	/* Unassert the fundamental reset */
 	if (pcie->tperst_clk_ms) {
 		/*
