From f2f1e849f4fe4fde70eaa20b136061a1552bf014 Mon Sep 17 00:00:00 2001
From: Phil Elwell <phil@raspberrypi.com>
Date: Wed, 1 Jul 2026 08:35:18 +0100
Subject: [PATCH] overlays: Add nospi10 to the overlay map

nospi10 is only valid on 2712, so mark it as such.

Signed-off-by: Phil Elwell <phil@raspberrypi.com>
---
 arch/arm/boot/dts/overlays/overlay_map.dts | 4 ++++
 1 file changed, 4 insertions(+)

--- a/arch/arm/boot/dts/overlays/overlay_map.dts
+++ b/arch/arm/boot/dts/overlays/overlay_map.dts
@@ -210,6 +210,10 @@
 		deprecated = "use i2c-sensor,mpu6050";
 	};
 
+	nospi10 {
+		bcm2712;
+	};
+
 	pcie-32bit-dma {
 		bcm2711;
 		bcm2712 = "pcie-32bit-dma-pi5";
