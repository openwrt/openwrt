From 01f7332f1cb810f75ba2d39457ac51d3f1e07b4c Mon Sep 17 00:00:00 2001
From: Dom Cobley <popcornmix@gmail.com>
Date: Tue, 19 May 2026 19:23:13 +0100
Subject: [PATCH] clk: rp1: select REGMAP_MMIO

We use regmap mmio so should select it

Signed-off-by: Dom Cobley <popcornmix@gmail.com>
---
 drivers/clk/Kconfig | 1 +
 1 file changed, 1 insertion(+)

--- a/drivers/clk/Kconfig
+++ b/drivers/clk/Kconfig
@@ -90,6 +90,7 @@ config COMMON_CLK_RK808
 config COMMON_CLK_RP1
 	tristate "Raspberry Pi RP1-based clock support"
 	depends on MISC_RP1 || MFD_RP1 || COMPILE_TEST
+	select REGMAP_MMIO
 	default MISC_RP1
 	help
 	  Enable common clock framework support for Raspberry Pi RP1.
