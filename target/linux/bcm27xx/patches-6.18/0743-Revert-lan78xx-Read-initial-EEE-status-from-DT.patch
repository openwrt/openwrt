From 03979737e4dbb8ea688fb5da9eb4f37e0c8aa879 Mon Sep 17 00:00:00 2001
From: Nicolai Buchwitz <nb@tipi-net.de>
Date: Sun, 29 Mar 2026 23:28:19 +0200
Subject: [PATCH] Revert "lan78xx: Read initial EEE status from DT"

This reverts commit 98fb76f556f399cf9e6bbabc2aae0110192a8a91.
---
 drivers/net/usb/lan78xx.c | 23 -----------------------
 1 file changed, 23 deletions(-)

--- a/drivers/net/usb/lan78xx.c
+++ b/drivers/net/usb/lan78xx.c
@@ -2897,29 +2897,6 @@ static int lan78xx_phy_init(struct lan78
 		goto phylink_uninit;
 	}
 
-	if (of_property_read_bool(phydev->mdio.dev.of_node,
-				  "microchip,eee-enabled")) {
-		struct ethtool_keee edata;
-		memset(&edata, 0, sizeof(edata));
-
-		linkmode_set_bit(ETHTOOL_LINK_MODE_1000baseT_Full_BIT,
-			edata.advertised);
-		linkmode_set_bit(ETHTOOL_LINK_MODE_100baseT_Full_BIT,
-			edata.advertised);
-
-		edata.eee_enabled = true;
-		edata.tx_lpi_enabled = true;
-		if (of_property_read_u32(phydev->mdio.dev.of_node,
-					 "microchip,tx-lpi-timer",
-					 &edata.tx_lpi_timer))
-			edata.tx_lpi_timer = 600; /* non-aggressive */
-		rtnl_lock();
-		(void)lan78xx_set_eee(dev->net, &edata);
-		rtnl_unlock();
-
-		phy_support_eee(phydev);
-	}
-
 	ret = lan78xx_configure_leds_from_dt(dev, phydev);
 	if (ret < 0)
 		goto phylink_uninit;
