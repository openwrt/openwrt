 arch/arm64/configs/bcm2711_rt_defconfig | 1 +
 arch/arm64/configs/bcm2712_defconfig    | 1 +
 5 files changed, 5 insertions(+)

diff --git a/arch/arm/configs/bcm2709_defconfig b/arch/arm/configs/bcm2709_defconfig
index eaf62d36314b..059182de80ea 100644
--- a/arch/arm/configs/bcm2709_defconfig
+++ b/arch/arm/configs/bcm2709_defconfig
@@ -983,6 +983,7 @@ CONFIG_DRM_PANEL_RASPBERRYPI_TOUCHSCREEN=m
 CONFIG_DRM_PANEL_SITRONIX_ST7701=m
 CONFIG_DRM_PANEL_SIMPLE=m
 CONFIG_DRM_PANEL_TPO_Y17P=m
+CONFIG_DRM_PANEL_TDO_DSI_V1=m
 CONFIG_DRM_PANEL_WAVESHARE_TOUCHSCREEN=m
 CONFIG_DRM_PANEL_WAVESHARE_TOUCHSCREEN_V2=m
 CONFIG_DRM_DISPLAY_CONNECTOR=m
