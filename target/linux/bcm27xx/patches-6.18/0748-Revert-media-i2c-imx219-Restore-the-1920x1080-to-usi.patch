From 49364b4185deb7daeb39ec38614d42f10d2a814f Mon Sep 17 00:00:00 2001
From: Nick Hollinghurst <nick.hollinghurst@raspberrypi.com>
Date: Fri, 22 May 2026 14:53:35 +0100
Subject: [PATCH] Revert "media: i2c: imx219: Restore the 1920x1080 to using a
 1:1 PAR"

This reverts commit cfa10dd3d123cdfeac37d26411bdee7005306fdb.
---
 drivers/media/i2c/imx219.c | 1 -
 1 file changed, 1 deletion(-)

--- a/drivers/media/i2c/imx219.c
+++ b/drivers/media/i2c/imx219.c
@@ -876,7 +876,6 @@ static int imx219_set_pad_format(struct
 	 */
 	bin_h = min(IMX219_PIXEL_ARRAY_WIDTH / format->width, 2U);
 	bin_v = min(IMX219_PIXEL_ARRAY_HEIGHT / format->height, 2U);
-	binning = min(bin_h, bin_v);
 
 	/* Ensure bin_h and bin_v are same to avoid 1:2 or 2:1 stretching */
 	binning = min(bin_h, bin_v);
