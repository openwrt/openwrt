From ac2010ab872809cefb790183949b11bdf22db647 Mon Sep 17 00:00:00 2001
From: Phil Elwell <phil@raspberrypi.com>
Date: Thu, 4 Jun 2026 11:56:14 +0100
Subject: [PATCH] configs: Enable MT7921 and MT7922 support

Add support for two MediaTek WiFi PCIe/M.2 interfaces.

See: https://github.com/raspberrypi/linux/issues/7415

Signed-off-by: Phil Elwell <phil@raspberrypi.com>
---
 arch/arm64/configs/bcm2711_defconfig    | 1 +
 arch/arm64/configs/bcm2711_rt_defconfig | 1 +
 arch/arm64/configs/bcm2712_defconfig    | 1 +
 3 files changed, 3 insertions(+)

diff --git a/arch/arm64/configs/bcm2711_defconfig b/arch/arm64/configs/bcm2711_defconfig
index 5f579b5dac41..c59f9253dff1 100644
--- a/arch/arm64/configs/bcm2711_defconfig
+++ b/arch/arm64/configs/bcm2711_defconfig
@@ -635,6 +635,7 @@ CONFIG_MWIFIEX_SDIO=m
 CONFIG_MT7601U=m
 CONFIG_MT76x0U=m
 CONFIG_MT76x2U=m
+CONFIG_MT7921E=m
 CONFIG_MT7921U=m
 CONFIG_MT7925E=m
 CONFIG_MT7925U=m
diff --git a/arch/arm64/configs/bcm2711_rt_defconfig b/arch/arm64/configs/bcm2711_rt_defconfig
index 35c5333a38c8..a067775a5a18 100644
--- a/arch/arm64/configs/bcm2711_rt_defconfig
+++ b/arch/arm64/configs/bcm2711_rt_defconfig
@@ -635,6 +635,7 @@ CONFIG_MWIFIEX_SDIO=m
 CONFIG_MT7601U=m
 CONFIG_MT76x0U=m
 CONFIG_MT76x2U=m
+CONFIG_MT7921E=m
 CONFIG_MT7921U=m
 CONFIG_MT7925E=m
 CONFIG_MT7925U=m
diff --git a/arch/arm64/configs/bcm2712_defconfig b/arch/arm64/configs/bcm2712_defconfig
index 593d484defdf..c4fb7babd9a4 100644
--- a/arch/arm64/configs/bcm2712_defconfig
+++ b/arch/arm64/configs/bcm2712_defconfig
@@ -638,6 +638,7 @@ CONFIG_MWIFIEX_SDIO=m
 CONFIG_MT7601U=m
 CONFIG_MT76x0U=m
 CONFIG_MT76x2U=m
+CONFIG_MT7921E=m
 CONFIG_MT7921U=m
 CONFIG_MT7925E=m
 CONFIG_MT7925U=m
-- 
2.54.0

