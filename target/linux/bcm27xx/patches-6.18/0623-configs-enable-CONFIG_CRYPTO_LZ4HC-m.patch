From 241b572371f5dc7ce78b2c7d6abed6572a042d04 Mon Sep 17 00:00:00 2001
From: Leonard Lausen <leonard@lausen.nl>
Date: Sun, 25 Jan 2026 18:27:24 +0000
Subject: [PATCH] configs: enable CONFIG_CRYPTO_LZ4HC=m

The lz4hc module is required to support bcachefs-tools dkms builds.
---
 arch/arm/configs/bcm2709_defconfig      | 1 +
 arch/arm/configs/bcmrpi_defconfig       | 1 +
 arch/arm64/configs/bcm2711_defconfig    | 1 +
 arch/arm64/configs/bcm2711_rt_defconfig | 1 +
 arch/arm64/configs/bcm2712_defconfig    | 1 +
 5 files changed, 5 insertions(+)

diff --git a/arch/arm/configs/bcm2709_defconfig b/arch/arm/configs/bcm2709_defconfig
index 949154f49e0f..9cfdba620803 100644
--- a/arch/arm/configs/bcm2709_defconfig
+++ b/arch/arm/configs/bcm2709_defconfig
@@ -1599,6 +1599,7 @@ CONFIG_CRYPTO_SHA1=m
 CONFIG_CRYPTO_WP512=m
 CONFIG_CRYPTO_XCBC=m
 CONFIG_CRYPTO_LZ4=m
+CONFIG_CRYPTO_LZ4HC=m
 CONFIG_CRYPTO_USER_API_HASH=m
 CONFIG_CRYPTO_USER_API_SKCIPHER=m
 CONFIG_CRYPTO_USER_API_RNG=m
diff --git a/arch/arm/configs/bcmrpi_defconfig b/arch/arm/configs/bcmrpi_defconfig
index e991a4b4a64c..f80cc3569ed6 100644
--- a/arch/arm/configs/bcmrpi_defconfig
+++ b/arch/arm/configs/bcmrpi_defconfig
@@ -1593,6 +1593,7 @@ CONFIG_CRYPTO_SHA1=m
