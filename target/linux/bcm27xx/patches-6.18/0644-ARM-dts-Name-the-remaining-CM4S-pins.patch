From 1979a606304cf2d9c1ce72606309492005af6270 Mon Sep 17 00:00:00 2001
From: Phil Elwell <phil@raspberrypi.com>
Date: Mon, 16 Feb 2026 09:31:53 +0000
Subject: [PATCH] ARM: dts: Name the remaining CM4S pins

CM4S is unusual in that the high GPIOs are not used for RGMII, so give
the GPIOs names.

Signed-off-by: Phil Elwell <phil@raspberrypi.com>
---
 arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4s.dts | 14 +++++++++++++-
 1 file changed, 13 insertions(+), 1 deletion(-)

diff --git a/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4s.dts b/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4s.dts
index badf2a2fc3e9..07627625396a 100644
--- a/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4s.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4s.dts
@@ -74,7 +74,19 @@ &gpio {
 			  "GPIO42",
 			  "GPIO43",
 			  "GPIO44",
-			  "GPIO45";
+			  "GPIO45",
+			  "-", // GPIO46
+			  "-", // GPIO47
+			  "-", // GPIO48
+			  "EMMC_DISABLE_N", // GPIO49
+			  "-", // GPIO50
+			  "-", // GPIO51
+			  "-", // GPIO52
+			  "-", // GPIO53
+			  "-", // GPIO54
+			  "-", // GPIO55
+			  "-", // GPIO56
+			  "GPIO_SEL"; // GPIO57
 };
 
 &hdmi0 {
-- 
2.54.0

