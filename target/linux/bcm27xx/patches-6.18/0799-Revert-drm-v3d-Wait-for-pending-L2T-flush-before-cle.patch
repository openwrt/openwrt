From de7f1638ebdb802cc70e482cd3a014763746f53b Mon Sep 17 00:00:00 2001
From: Dom Cobley <popcornmix@gmail.com>
Date: Fri, 19 Jun 2026 15:33:38 +0100
Subject: [PATCH] Revert "drm/v3d: Wait for pending L2T flush before cleaning
 caches"

This reverts commit a8548398000fce0174e1b1a45ea94e0b43432835.
---
 drivers/gpu/drm/v3d/v3d_gem.c | 8 --------
 1 file changed, 8 deletions(-)

diff --git a/drivers/gpu/drm/v3d/v3d_gem.c b/drivers/gpu/drm/v3d/v3d_gem.c
index 3d771ff45feb..82fda76a2daf 100644
--- a/drivers/gpu/drm/v3d/v3d_gem.c
+++ b/drivers/gpu/drm/v3d/v3d_gem.c
@@ -206,14 +206,6 @@ v3d_clean_caches(struct v3d_dev *v3d)
 
 	trace_v3d_cache_clean_begin(dev);
 
-	/* GFXH-1897: Ensure pending flushes complete before writing L2TCACTL */
-	if (v3d->ver < V3D_GEN_71) {
-		if (wait_for(!(V3D_CORE_READ(core, V3D_CTL_L2TCACTL) &
-			       V3D_L2TCACTL_L2TFLS), 100)) {
-			DRM_ERROR("Timeout waiting for L2T clean\n");
-		}
-	}
-
 	V3D_CORE_WRITE(core, V3D_CTL_L2TCACTL, V3D_L2TCACTL_TMUWCF);
 	if (wait_for(!(V3D_CORE_READ(core, V3D_CTL_L2TCACTL) &
 		       V3D_L2TCACTL_TMUWCF), 100)) {
-- 
2.54.0

