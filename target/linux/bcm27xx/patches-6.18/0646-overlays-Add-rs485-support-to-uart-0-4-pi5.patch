+		rs485_full_duplex = <&frag0>,"rs485-rx-during-tx?";
+		rs485_invert_rts = <&frag0>,"rs485-rts-active-low?";
+		rs485_rts_on_delay = <&frag0>,"rs485-rts-delay:0";
