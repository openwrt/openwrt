 	};
 };
--- a/arch/arm/boot/dts/overlays/uart3-pi5-overlay.dts
+++ b/arch/arm/boot/dts/overlays/uart3-pi5-overlay.dts
@@ -9,10 +9,17 @@
 		frag0: __overlay__ {
 			status = "okay";
 			pinctrl-0 = <&uart3_pins>;
+			rs485-rts-delay = <0 0>;
 		};
 	};
 
