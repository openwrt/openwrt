From a182d5f33956c8666aa0d3a1fc149a28bc6af33e Mon Sep 17 00:00:00 2001
From: Phil Elwell <phil@raspberrypi.com>
Date: Wed, 25 Feb 2026 10:00:52 +0000
Subject: [PATCH] overlays: i2c-sensor: Add sht85 support

Add a parameter to the i2c-sensor overlay to support the SHT85 sensors
from Sensirion.

Signed-off-by: Phil Elwell <phil@raspberrypi.com>
---
 arch/arm/boot/dts/overlays/README                |  3 +++
 .../arm/boot/dts/overlays/i2c-sensor-common.dtsi | 16 ++++++++++++++++
 2 files changed, 19 insertions(+)

--- a/arch/arm/boot/dts/overlays/README
+++ b/arch/arm/boot/dts/overlays/README
@@ -2632,6 +2632,9 @@ Params: addr                    Set the
                                 humidity sensors. Valid addresses 0x44-0x45,
                                 default 0x44
 
+        sht85                   Select the Sensirion SHT85 temperature and
+                                humidity sensors. Fixed address 0x44.
+
         shtc3                   Select the Sensirion SHTC3 temperature and
                                 humidity sensors.
 
--- a/arch/arm/boot/dts/overlays/i2c-sensor-common.dtsi
+++ b/arch/arm/boot/dts/overlays/i2c-sensor-common.dtsi
@@ -893,6 +893,21 @@
 		};
 	};
 
+	fragment@58 {
+		target = <&i2cbus>;
+		__dormant__ {
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "okay";
+
+			sht85: sht85@44 {
+				compatible = "sensirion,sht85";
+				reg = <0x44>;
+				status = "okay";
+			};
+		};
+	};
+
 	fragment@98 {
 		target-path = "/";
 		__dormant__ {
@@ -983,6 +998,7 @@
 		ad7998 = <0>,"+56", <&ad799x>,"compatible=adi,ad7998";
 		ad7999 = <0>,"+56", <&ad799x>,"compatible=adi,ad7999", <&ad799x>,"reg:0=0x29";
 		sts3x = <0>,"+57";
+		sht85 = <0>,"+58";
 
 		addr =	<&bme280>,"reg:0", <&bmp280>,"reg:0", <&tmp102>,"reg:0",
 			<&lm75>,"reg:0", <&hdc100x>,"reg:0", <&sht3x>,"reg:0",
