+	UPISND_PIN_CAP_GPIO            = UPISND_PIN_CAP_GPIO_DIR_INPUT |
+					 UPISND_PIN_CAP_GPIO_DIR_OUTPUT |
+					 UPISND_PIN_CAP_GPIO_PULL_UP |
+					 UPISND_PIN_CAP_GPIO_PULL_DOWN,
+	UPISND_PIN_CAP_ENCODER         = 1 << 4,
+	UPISND_PIN_CAP_ANALOG_IN       = 1 << 5,
