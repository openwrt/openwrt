+static const struct regmap_config hb_uni_regmap = {
+	.reg_bits         = 8,
+	.val_bits         = 8,
+	.max_register     = 0xff,
+	.cache_type       = REGCACHE_RBTREE,
+	.volatile_reg     = hb_uni_volatile_reg,
+	.readable_reg     = hb_uni_readable_reg,
+};
