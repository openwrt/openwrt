+#define VOL_CTL_SINGLE(kname, controls, ktlv) {\
+	.iface = SNDRV_CTL_ELEM_IFACE_MIXER, \
+	.name = kname, \
+	.access = SNDRV_CTL_ELEM_ACCESS_TLV_READ | \
