From 935b63c663817b6fef1b958d4ae6b2e0f004e2c7 Mon Sep 17 00:00:00 2001
From: Dave Stevenson <dave.stevenson@raspberrypi.com>
Date: Tue, 10 Mar 2026 12:15:23 +0000
Subject: [PATCH] clk: bcm2835: Don't avoid PLLC on BCM2711

BCM2711 fixes PLLC, so there's no need to avoid it.

Signed-off-by: Dave Stevenson <dave.stevenson@raspberrypi.com>
---
 drivers/clk/bcm/clk-bcm2835.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

--- a/drivers/clk/bcm/clk-bcm2835.c
+++ b/drivers/clk/bcm/clk-bcm2835.c
@@ -1262,6 +1262,8 @@ static unsigned long bcm2835_clock_choos
 static int bcm2835_clock_determine_rate(struct clk_hw *hw,
 					struct clk_rate_request *req)
 {
+	struct bcm2835_clock *clock = bcm2835_clock_from_hw(hw);
+	struct bcm2835_cprman *cprman = clock->cprman;
 	struct clk_hw *parent, *best_parent = NULL;
 	bool current_parent_is_pllc;
 	unsigned long rate, best_rate = 0;
@@ -1281,13 +1283,17 @@ static int bcm2835_clock_determine_rate(
 			continue;
 
 		/*
+		 * BCM2835 only.
 		 * Don't choose a PLLC-derived clock as our parent
 		 * unless it had been manually set that way.  PLLC's
 		 * frequency gets adjusted by the firmware due to
 		 * over-temp or under-voltage conditions, without
 		 * prior notification to our clock consumer.
+		 * (BCM2711 doesn't do this, therefore it is safe to
+		 * use PLLC)
 		 */
-		if (bcm2835_clk_is_pllc(parent) && !current_parent_is_pllc)
+		if ((cprman->soc & SOC_BCM2835) && bcm2835_clk_is_pllc(parent) &&
+		    !current_parent_is_pllc)
 			continue;
 
 		rate = bcm2835_clock_choose_div_and_prate(hw, i, req->rate,
