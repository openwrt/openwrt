. /lib/functions/uci-defaults.sh
. /lib/functions/system.sh

setup_interfaces()
{
  local board="$1"

  case "$board" in
  airoha,en7523-evb)
    ucidef_set_interface_lan "lan1 lan2 lan3 lan4"
    ;;
  airoha,an7581-evb)
    ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 lan4" "eth1"
    ;;
  airoha,an7583-evb)
    ucidef_set_interface_lan "lan1 lan2 lan3 lan4 eth1"
    ;;
  gemtek,w1700k-ubi)
    ucidef_set_interfaces_lan_wan "lan2 lan3 lan4" "wan"
    ;;
  genexis,arcee | \
  genexis,pixly_r1)
    ucidef_set_interfaces_lan_wan "lan1 lan2" "wan"
    ;;
  genexis,rodimus_r1)
    ucidef_set_interface_lan "lan1"
    ;;
  genexis,e650)
    ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 lan4" "wan"
    ;;
  genexis,laxy | \
  genexis,zephyr)
    ucidef_set_interface_lan "lan1 lan2 lan3"
    ;;
  mikrotik,e60iugs)
    # ucidef_set_interfaces_lan_wan "lan2 lan3 lan4 lan5" "wan sfp"
    ucidef_set_interfaces_lan_wan "lan2 lan3 lan4 lan5" "wan"
    ;;
  nokia,valyrian)
    ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 10g" "wan"
    ;;
  tplink,ex530v-v1)
    ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 lan4" "wan"
    ;;
  tplink,xx230v-v1)
    # Needs write pon driver to use pon0 with wan interface
    ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 lan4" "pon0"
    ;;
  *)
    echo "Unsupported hardware. Network interfaces not initialized"
    ;;
  esac
}

board_config_update
board=$(board_name)
setup_interfaces $board
board_config_flush

exit 0
