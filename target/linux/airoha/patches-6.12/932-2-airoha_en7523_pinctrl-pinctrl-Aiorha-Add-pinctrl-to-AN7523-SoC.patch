From 14192ffbc35e96384498c7bb7d2e589a2dba1539 Mon Sep 17 00:00:00 2001
From: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
Date: Sun, 11 Jan 2026 11:31:59 -0300
Subject: [PATCH] pinctrl: Aiorha: Add pinctrl to AN7523 SoC

Signed-off-by: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
---
 drivers/pinctrl/airoha/Kconfig          |   5 +
 drivers/pinctrl/airoha/Makefile         |   1 +
 drivers/pinctrl/airoha/airoha-common.h  |  22 +-
 drivers/pinctrl/airoha/pinctrl-an7523.c | 596 ++++++++++++++++++++++++
 4 files changed, 623 insertions(+), 1 deletion(-)
 create mode 100644 drivers/pinctrl/airoha/pinctrl-an7523.c

--- a/drivers/pinctrl/airoha/Kconfig
+++ b/drivers/pinctrl/airoha/Kconfig
@@ -13,12 +13,17 @@ config PINCTRL_AIROHA
 	select GPIOLIB
 	select GPIOLIB_IRQCHIP
 	select REGMAP_MMIO
+	imply PINCTRL_AIROHA_AN7523
 	imply PINCTRL_AIROHA_AN7581
 	imply PINCTRL_AIROHA_AN7583
 	help
 	  Say yes here to support pin controller and gpio driver
 	  on Airoha SoC.
 
+config PINCTRL_AIROHA_AN7523
+	tristate "AN7523 pinctrl"
+	depends on PINCTRL_AIROHA
+
 config PINCTRL_AIROHA_AN7581
 	tristate "AN7581 pinctrl"
 	depends on PINCTRL_AIROHA
--- a/drivers/pinctrl/airoha/Makefile
+++ b/drivers/pinctrl/airoha/Makefile
@@ -3,5 +3,6 @@
 # SoC Drivers
 obj-$(CONFIG_PINCTRL_AIROHA)	+= pinctrl-airoha.o
 
+obj-$(CONFIG_PINCTRL_AIROHA_AN7523)	+= pinctrl-an7523.o
 obj-$(CONFIG_PINCTRL_AIROHA_AN7581)	+= pinctrl-an7581.o
 obj-$(CONFIG_PINCTRL_AIROHA_AN7583)	+= pinctrl-an7583.o
\ No newline at end of file
