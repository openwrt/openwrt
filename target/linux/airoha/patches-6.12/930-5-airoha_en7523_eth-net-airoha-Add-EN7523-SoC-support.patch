+	for (i = 0; i < AIROHA_NUM_RX_RING(qdma->eth->soc); i++) {
 		int err;
 
 		if (!(RX_DONE_INT_MASK & BIT(i))) {
@@ -899,7 +964,7 @@ static int airoha_qdma_tx_napi_poll(stru
 		done++;
 
