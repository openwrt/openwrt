From 57cbbe60923dc95b781e7c89cec8c77741ddcc61 Mon Sep 17 00:00:00 2001
From: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
Date: Tue, 18 Nov 2025 23:36:07 -0300
Subject: [PATCH] Airoha thermal: add en7523

Signed-off-by: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
---
 drivers/thermal/airoha_thermal.c | 159 +++++++++++++++++++++++++++++++
 1 file changed, 159 insertions(+)

diff --git a/drivers/thermal/airoha_thermal.c b/drivers/thermal/airoha_thermal.c
index e71548f9c..dd260861e 100644
--- a/drivers/thermal/airoha_thermal.c
+++ b/drivers/thermal/airoha_thermal.c
@@ -24,6 +24,10 @@
 #define   AN7583_MUX_TADC_MASK			GENMASK(3, 1)
 #define AN7583_DOUT_TADC			0x2f0
 
+#define EN7523_PLLRG_PROTECT			0x264
+#define EN7523_MUX_TADC				0x2ec
+#define EN7523_DOUT_TADC			0x2f0
+
 /* PTP_THERMAL regs */
 #define EN7581_TEMPMONCTL0			0x800
 #define   EN7581_SENSE3_EN			BIT(3)
@@ -251,6 +255,7 @@ struct airoha_thermal_priv {
 
 	u32 pllrg_protect;
 	int current_adc;
+	int thermal_efuse_valid;
 
 	struct thermal_zone_device *tz;
 	int init_temp;
@@ -285,6 +290,35 @@ static const unsigned int an7583_thermal_offset[AN7583_ADC_MUX_MAX] = {
 	[AN7583_CPU_TEMP_SENSOR] = 344,
 };
 
+
+static const unsigned int en7523_SLOPE_7523_X100_E2[1] = {
+	1810,
+};
+
+static const unsigned int en7523_SLOPE_7523_X100_E3[1] = {
+	1750,
+};
+
+static const unsigned int en7523_CODE_30_DEFAULT_7523_E2[1] = {
+	34799,
+};
+
+static const unsigned int en7523_CODE_30_DEFAULT_7523_E3[1] = {
+	31662,
+};
+
+static const unsigned int en7523_CODE_30_BIAS_E2QFP[1] = {
+	130,
+};
+
+static const unsigned int en7523_CODE_30_BIAS_E2BGA[1] = {
+	366,
+};
+
+static const unsigned int en7523_CODE_30_BIAS_E3BGA[1] = {
+	346,
+};
+
 static int airoha_get_thermal_ADC(struct airoha_thermal_priv *priv)
 {
 	u32 val;
@@ -658,6 +692,123 @@ static int an7583_thermal_probe(struct platform_device *pdev,
 	return 0;
 }
 
+static const struct reg_field en7523_chip_scu_fields[AIROHA_THERMAL_FIELD_MAX] = {
+	[AIROHA_THERMAL_DOUT_TADC] = REG_FIELD(EN7523_DOUT_TADC, 0, 31),
+	[AIROHA_THERMAL_MUX_TADC] = REG_FIELD(EN7523_MUX_TADC, 0, 7),
+};
+
+static void en7523_set_thermal_mux(struct airoha_thermal_priv *priv)
+{
+	u32 pllrg;
+	regmap_read(priv->chip_scu, EN7523_PLLRG_PROTECT, &pllrg);
+	regmap_write(priv->chip_scu, EN7523_PLLRG_PROTECT,
+		     priv->pllrg_protect);
+	regmap_write(priv->chip_scu, EN7523_MUX_TADC, 0x70);
+	usleep_range(10 * USEC_PER_MSEC, 11 * USEC_PER_MSEC);
+	regmap_write(priv->chip_scu, EN7523_PLLRG_PROTECT, pllrg);
+}
+
+static void en7523_thermal_setup_adc_val(struct device *dev,
+					 struct airoha_thermal_priv *priv)
+{
+	const u32 *slope, *bias, *target_offset_ptr;
+	u32 target_offset_val = 0;
+	u32 offset_efuse;
+	u32 pdid = 3;
+	u32 pkg_type = 3;
+
+	regmap_read(priv->map, EN7581_EFUSE_TEMP_OFFSET_REG, &offset_efuse);
+	priv->thermal_efuse_valid = (offset_efuse == 0) ? 0 : 1;
+
+	slope = en7523_SLOPE_7523_X100_E3;
+	bias = en7523_CODE_30_BIAS_E3BGA;
+	if (priv->thermal_efuse_valid)
+		target_offset_ptr = en7523_CODE_30_DEFAULT_7523_E3;
+
+	if (priv->thermal_efuse_valid)
+		target_offset_val = target_offset_ptr[0];
+
+	priv->default_slope = slope[0];
+	priv->default_offset = target_offset_val + bias[0];
+	priv->init_temp = 300;
+
+	dev_info(dev, "EN7523: IC %s calibrated (pdid:%u, pkg:%u)\n",
+		 priv->thermal_efuse_valid ? "" : "no", pdid, pkg_type);
+	dev_info(dev, "EN7523: Init check code_30:%d, Slope:%d\n",
+		 priv->default_offset, priv->default_slope);
+}
+
+static int en7523_thermal_probe(struct platform_device *pdev,
+				struct airoha_thermal_priv *priv)
+{
+	struct device_node *chip_scu_np;
+	struct device *dev = &pdev->dev;
+	void __iomem *base;
+	int i;
+
+	base = devm_platform_ioremap_resource(pdev, 0);
+	if (IS_ERR(base))
+		return PTR_ERR(base);
+
+	priv->map = devm_regmap_init_mmio(dev, base,
+					  &en7581_thermal_regmap_config);
+	if (IS_ERR(priv->map))
+		return PTR_ERR(priv->map);
+
+	chip_scu_np = of_parse_phandle(dev->of_node, "airoha,chip-scu", 0);
+	if (!chip_scu_np) {
+		dev_err(dev, "Unable to find node 'airoha,chip-scu'\n");
+		return -EINVAL;
+	}
+
+	priv->chip_scu = syscon_node_to_regmap(chip_scu_np);
+	of_node_put(chip_scu_np);
+	if (IS_ERR(priv->chip_scu))
+		return PTR_ERR(priv->chip_scu);
+
+	for (i = 0; i < AIROHA_THERMAL_FIELD_MAX; i++) {
+		struct regmap_field *field;
+		if (i == AIROHA_THERMAL_MUX_SENSOR)
+			continue;
+		if (i == AIROHA_THERMAL_MUX_TADC &&
+		    en7523_chip_scu_fields[i].reg != EN7523_MUX_TADC)
+			continue;
+		field = devm_regmap_field_alloc(dev, priv->chip_scu,
+						en7523_chip_scu_fields[i]);
+		if (IS_ERR(field))
+			return PTR_ERR(field);
+		priv->chip_scu_fields[i] = field;
+	}
+	en7523_thermal_setup_adc_val(dev, priv);
+	return 0;
+}
+
+static int en7523_thermal_get_temp(struct thermal_zone_device *tz, int *temp)
+{
+	struct airoha_thermal_priv *priv = thermal_zone_device_priv(tz);
+	int temp_x10;
+
+	if (priv->thermal_efuse_valid == 0) {
+		u32 iddq_val;
+		regmap_read(priv->map, EN7581_EFUSE_TEMP_CPU_SENSOR_REG, &iddq_val);
+		temp_x10 = 600 + (iddq_val & 0xf) * 8;
+		*temp = temp_x10 * 100;
+	} else {
+		s32 adc_val;
+		en7523_set_thermal_mux(priv);
+		adc_val = airoha_get_thermal_ADC(priv);
+		temp_x10 = 1000 * (adc_val - priv->default_offset) /
+				priv->default_slope + priv->init_temp;
+		*temp = temp_x10 * 100;
+	}
+
+	return 0;
+}
+
+static const struct thermal_zone_device_ops en7523_tz_ops = {
+	.get_temp = en7523_thermal_get_temp,
+};
+
 static int airoha_thermal_probe(struct platform_device *pdev)
 {
 	const struct airoha_thermal_soc_data *soc_data;
@@ -707,9 +858,17 @@ static const struct airoha_thermal_soc_data an7583_data = {
 	.probe = &an7583_thermal_probe,
 };
 
+static const struct airoha_thermal_soc_data en7523_data = {
+	.pllrg_protect = AN7583_SCU_THERMAL_PROTECT_KEY,
+	.thdev_ops = &en7523_tz_ops,
+	.probe = &en7523_thermal_probe,
+	.post_probe = NULL,
+};
+
 static const struct of_device_id airoha_thermal_match[] = {
 	{ .compatible = "airoha,en7581-thermal", .data = &en7581_data },
 	{ .compatible = "airoha,an7583-thermal", .data = &an7583_data },
+	{ .compatible = "airoha,en7523-thermal", .data = &en7523_data },
 	{},
 };
 MODULE_DEVICE_TABLE(of, airoha_thermal_match);
-- 
2.52.0

