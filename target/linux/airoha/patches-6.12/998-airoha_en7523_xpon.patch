diff --git a/drivers/net/pon/airoha/airoha-en7571.c b/drivers/net/pon/airoha/airoha-en7571.c
new file mode 100644
index 000000000..4c588e573
--- /dev/null
+++ b/drivers/net/pon/airoha/airoha-en7571.c
@@ -0,0 +1,771 @@
+#include <linux/types.h>
+
+#include "mtk-pon.h"
+#include "mtk-mt757x-regs.h"
+
+struct mtk_en7571_priv {
+	int ver;
+	int sys_mode;
+};
+
+static bool en7571_detection(struct mtk_pon *pon)
+{
+	struct mtk_en7571_priv *priv = pon->priv;
+	u8 read_data_1 = 0, read_data_2 = 0;
+	unchar ptr[1];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_FT_ADC_CLK_CLR, ptr, 1);
+	read_data_1 = ptr[0];
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_DUMMY_REG, ptr, 1);
+	read_data_2 = ptr[0];
+
+	if ((read_data_1 == 0x03) && (read_data_2 >= 0x03)) {
+		priv->ver = 2;
+		priv->sys_mode = 0;
+		return true;
+	}
+
+	return false;
+}
+
+static inline void en7571_hw_reset(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_DUMMY_REG, ptr, 4);
+	ptr[1] = ptr[1] & 0xfe;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_DUMMY_REG, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_DUMMY_REG, ptr, 4);
+	ptr[1] = (ptr[1] & 0xfe) | 0x01;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_DUMMY_REG, ptr, 4);
+}
+
+static inline void en7571_7571_enable(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_I2C_GLITCH_PROT, ptr, 4);
+	ptr[0] = (ptr[0] & 0xfe) | 0x01;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_I2C_GLITCH_PROT, ptr, 4);
+}
+
+static inline void en7571_PWRADC_calibration(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	int vld = 0;
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_CTRL, ptr, 4);
+	ptr[3] = (ptr[3] & 0xef) | 0x10;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_CTRL, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+	ptr[3] = (ptr[3] & 0xf8) | 0x07;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+	ptr[3] = (ptr[3] & 0x7f) | 0x80;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+	mdelay(20);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+	vld = (ptr[2] & 0x10) >> 4;
+	if (vld == 1) {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+		pon->pwradc_offset = ((ptr[2] << 16) | (ptr[1] << 8) | ptr[0]) &
+				     0xfffff;
+		pon->pwradc_offset = pon->pwradc_offset >> 4;
+		dev_info(pon->dev, "PWRADC offset = 0x%x\n", pon->pwradc_offset);
+	}
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+	ptr[3] = ptr[3] & 0xf8;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_VAL, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_CTRL, ptr, 4);
+	ptr[3] = ptr[3] & 0xef;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_CTRL, ptr, 4);
+}
+
+static inline uint32_t en7571_SVADC_get(struct mtk_pon *pon)
+{
+	unchar ptr[2];
+	uint32_t svadc_value = 0;
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, ((EN7571_ADC_PROBE_CTRL) + 0x001),
+		     ptr, 1);
+	ptr[0] = (ptr[0] & 0xef) | 0x10;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, ((EN7571_ADC_PROBE_CTRL) + 0x001),
+		      ptr, 1);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_ADC_PROBE_VAL, ptr, 2);
+	svadc_value = (ptr[0] | (ptr[1] << 8));
+
+	return svadc_value;
+}
+
+static inline void en7571_RSSI_calibration(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	uint read_data = 0;
+	int RSSI_factor = 0;
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+	ptr[1] = (ptr[1] & 0xef) | RSSI_CAL_EN;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+	ptr[1] = (ptr[1] & 0xbf) | 0x40;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_SVADC_PD, ptr, 1);
+	read_data = ptr[0];
+	ptr[0] = (ptr[0] & 0xe1) | ADC_RSSI_ENABLE;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_SVADC_PD, ptr, 1);
+
+	pon->rssi_vref = en7571_SVADC_get(pon);
+	dev_info(pon->dev, "RSSI_Vref = 0x%x\n", pon->rssi_vref);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+	ptr[1] = ptr[1] & 0xbf;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+
+	pon->rssi_v = en7571_SVADC_get(pon);
+	dev_info(pon->dev, "RSSI_V = 0x%x\n", pon->rssi_v);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+	ptr[1] = ptr[1] & 0xef;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_LA_PWD, ptr, 2);
+
+	ptr[0] = read_data;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_SVADC_PD, ptr, 1);
+
+	if (pon->rssi_v > pon->rssi_vref)
+		// 0.35 approx 35/100
+		RSSI_factor = (pon->adc_slope * (pon->rssi_v - pon->rssi_vref) +
+			       pon->adc_offset) * 100 / 35;
+	else
+		dev_info(pon->dev, "RSSI calibration fail\n");
+
+	dev_info(pon->dev, "RSSI_factor: %d\n", RSSI_factor);
+}
+
+static inline void en7571_PWRADC_enable(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0000), ptr, 1);
+	ptr[0] = ptr[0] & 0xf1;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0000), ptr, 1);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_CTRL, ptr, 4);
+	ptr[3] = ptr[3] & 0xef;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_PWR_ADC_CTRL, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x02B4), ptr, 1);
+	ptr[0] = (ptr[0] & 0xfc) | 0x01;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x02B4), ptr, 1);
+
+	dev_info(pon->dev, "PWRADC ready");
+}
+
+static inline void en7571_eFuse_temperature_get(struct mtk_pon *pon)
+{
+	int a = 0;
+	int b = 0;
+	int read = 0;
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_EFUSE_DATA, ptr, 4);
+	ptr[2] = (ptr[2] & 0xfe) | 0x01;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_EFUSE_DATA, ptr, 4);
+	mdelay(50);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_EFUSE_DATA, ptr, 4);
+	read = ptr[0];
+
+	if (read < 127)
+		pon->efuse_temperature_offset = (read * 3) / 10; // * 0.3
+	else
+		pon->efuse_temperature_offset = (-3) * (256 - read) / 10;
+
+	dev_info(pon->dev, "eFuse value = 0x%x\n", ptr[0]);
+
+	a = pon->efuse_temperature_offset;
+	b = abs((pon->efuse_temperature_offset * 10) % 10);
+	dev_info(pon->dev, "eFuse offset = %d.%d'C\n", a, b);
+}
+
+static inline void en7571_LOS_init(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_LOS_CTRL1, ptr, 4);
+	ptr[0] = (ptr[0] & (0xfe)) | (0x01); // LOS_calibration_trig
+
+	ptr[1] = (ptr[1] & (0xe0)) | (0x1f); // LOS_ain_stable_cnt_setting
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_LOS_CTRL1, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_SVADC_PD, ptr, 4);
+	ptr[3] = (ptr[3] & (0xfb)) | (0x04); // LOS_ADCREV2_enable
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_SVADC_PD, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_SVADC_PD, ptr, 4);
+	ptr[2] = (ptr[2] & (0xbf)) | (0x40); // LOS_ADCREV1_enable
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_SVADC_PD, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_LOS_CTRL2, ptr, 4);
+	ptr[1] = (ptr[1] & (0xe0)) | (0x1f); // LOS_confidence_setting
+
+	ptr[0] = (ptr[0] & (0x80)) | (0x05); // LOS_cnt_setting
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_LOS_CTRL2, ptr, 4);
+}
+
+static inline void en7571_force_mode(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0258), ptr, 4);
+	ptr[3] = (ptr[3] & 0xfc) | 0x03;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0258), ptr, 4);
+}
+
+static inline void en7571_reg_init(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	uint32_t Ibias_min = 0x080;
+	uint32_t Imod_min = 0x032;
+	uint32_t Imax = 0xfff;
+	dev_info(pon->dev, "en7571_reg_init \n");
+
+	// Writing to 0x0220, seems to be related to I2C/Register init, possibly specific to 7571
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0220), ptr, 4);
+	ptr[3] = (ptr[3] & 0xf0) | (Ibias_min >> 8);
+	ptr[2] = (ptr[2] & 0x00) | (Ibias_min & 0xff);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0220), ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0224), ptr, 4);
+	ptr[3] = (ptr[3] & 0xf0) | (Imod_min >> 8);
+	;
+	ptr[2] = (ptr[2] & 0x00) | (Imod_min & 0xff);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0224), ptr, 4);
+
+	ptr[3] = (Imax >> 8);
+	ptr[2] = (Imax & 0xff);
+	ptr[1] = 0x00;
+	ptr[0] = 0x00;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0240), ptr, 4);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0244), ptr, 4);
+
+	// 0x024C -> EN7571_IMOD_MON (P1_PWR_CTRL_CS3 in mt7570)
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_IMOD_MON, ptr, 4);
+
+	ptr[3] = (ptr[3] & 0xf0) | (0x200 >> 8);
+	ptr[2] = (0x200 & 0xff);
+
+	ptr[1] = (ptr[1] & 0xf0) | (0x300 >> 8);
+	ptr[0] = (0x300 & 0xff);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IMOD_MON, ptr, 4);
+
+	// 0x0234
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0234), ptr, 4);
+	ptr[0] = (ptr[0] & 0xfc) | 0x02;
+
+	ptr[3] = (ptr[3] & 0xc0) | 0x3f;
+	ptr[2] = (ptr[2] & 0xc0) | 0x25;
+	ptr[1] = (ptr[1] & 0xc0) | 0x3f;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0234), ptr, 4);
+
+	// 0x0238
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0238), ptr, 4);
+	ptr[2] = (ptr[2] & 0xc0) | 0x25;
+	ptr[1] = (ptr[1] & 0xc0) | 0x3f;
+	ptr[0] = (ptr[0] & 0xc0) | 0x25;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0238), ptr, 4);
+
+	// 0x0248 - EN7571_IMOD_DAC (P1_PWR_CTRL_CS2)
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_IMOD_DAC, ptr, 4);
+	ptr[3] = (ptr[3] & 0xf8) | 0x01;
+	ptr[1] = 0x02;
+	ptr[0] = 0x04;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IMOD_DAC, ptr, 4);
+
+	en7571_force_mode(pon);
+
+	// 0x023C -> EN7571_IBIAS_MON
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_IBIAS_MON, ptr, 4);
+	ptr[1] = (ptr[1] & 0xfc) | (0x007 >> 8);
+	ptr[0] = (0x007 & 0xff);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IBIAS_MON, ptr, 4);
+
+	// 0x022C -> I2C_SCL_SMT in mt7570
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x022C), ptr, 4);
+	ptr[3] = (ptr[3] & 0xc0) | 0x02;
+	ptr[0] = (ptr[0] & 0xf8) | 0x07;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x022C), ptr, 4);
+
+	// 0x0260
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0260), ptr, 4);
+	ptr[3] = (ptr[3] & 0xf8) | 0x03;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0260), ptr, 4);
+
+	// 0x0254 -> ADC_PROBE_STATUS
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_ADC_PROBE_VAL, ptr, 4);
+	ptr[3] = 0x00;
+	ptr[2] = 0x00;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_ADC_PROBE_VAL, ptr, 4);
+
+	// 0x0250 -> P1_PWR_CTRL_LCH
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0250), ptr, 4);
+	ptr[2] = ptr[2] & 0x80;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0250), ptr, 4);
+}
+
+static inline void en7571_load_Tx_cal_data(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	unchar ptr_tmp[2];
+	uint32_t read_data = 0;
+
+	if (get_flash_register(pon, FLASH_IBIAS_INIT) != 0xffffffff) {
+		read_data = get_flash_register(pon, FLASH_IBIAS_INIT) &
+			    0x0fff0000;
+		read_data = read_data >> 16;
+		ptr[0] = read_data;
+		ptr[1] = (read_data >> 8);
+
+		read_data = get_flash_register(pon, FLASH_IBIAS_INIT) &
+			    0x00000fff;
+		ptr[2] = read_data;
+		ptr[3] = (read_data >> 8);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IMOD_MON, ptr, 4);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x027C), ptr, 4);
+		dev_info(pon->dev, "Initial current loaded\n");
+	}
+
+	if (get_flash_register(pon, FLASH_IMOD_INIT) != 0xffffffff) {
+		read_data = get_flash_register(pon, FLASH_IMOD_INIT) &
+			    0x0fff0000;
+		read_data = read_data >> 16;
+		ptr[0] = read_data;
+		ptr[1] = (read_data >> 8);
+
+		read_data = get_flash_register(pon, FLASH_IMOD_INIT) &
+			    0x000003ff;
+		ptr[2] = read_data;
+		ptr[3] = (read_data >> 8);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x025C), ptr, 4);
+		ptr_tmp[0] = ptr[0];
+		ptr_tmp[1] = ptr[1];
+		ptr[0] = ptr[2];
+		ptr[1] = ptr[3];
+		ptr[2] = ptr_tmp[0];
+		ptr[3] = ptr_tmp[1];
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0280), ptr, 4);
+		dev_info(pon->dev, "PWR/ER loaded\n");
+	}
+
+	read_data = get_flash_register(pon, FLASH_P0_P1_TARGET);
+	if (read_data != 0xffffffff) {
+		ptr[0] = ((read_data & 0x0fff0000) >> 16) & 0xFF;
+		ptr[1] = (read_data & 0x0fff0000) >> 24;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IBIAS_DAC, ptr, 2);
+
+		ptr[0] = (read_data & 0x00000fff) & 0xFF;
+		ptr[1] = (read_data & 0x00000fff) >> 8;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IMOD_DAC, ptr, 2);
+		dev_info(pon->dev, "Open loop initial current loaded\n");
+	}
+}
+
+static inline void en7571_TxSD_level_set(struct mtk_pon *pon)
+{
+	int tiaflt_A = 0;
+	uint32_t txsd_offset = 0;
+	int tiasd_B = 0;
+	int read_Pav_D = 0;
+	uint32_t tia_sd = 0;
+	u8 tia_mux_default = 0;
+	unchar ptr[4];
+
+	txsd_offset = (pon->pwradc_offset >> 6);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_TIAMUX, ptr, 1);
+	tia_mux_default = ptr[0];
+	ptr[0] = (ptr[0] & 0xf1) | 0x08;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_TIAMUX, ptr, 1);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, ((EN7571_PWR_ADC_VAL) + (0x03)),
+		     ptr, 1);
+	ptr[0] = (ptr[0] & 0xff) | 0x80;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, ((EN7571_PWR_ADC_VAL) + (0x03)),
+		      ptr, 1);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0204), ptr, 2);
+	tiaflt_A = ((ptr[1] << 8) | ptr[0]) & (0x3ff);
+	tiaflt_A = tiaflt_A - txsd_offset;
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_TIAMUX, ptr, 1);
+	ptr[0] = (ptr[0] & 0xf1) | 0x02;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_TIAMUX, ptr, 1);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_TIASD, ptr, 2);
+	ptr[0] = (ptr[0] & 0x00);
+	ptr[1] = (ptr[1] & 0xfe);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_TIASD, ptr, 2);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, ((EN7571_PWR_ADC_VAL) + (0x03)),
+		     ptr, 1);
+	ptr[0] = (ptr[0] & 0xff) | 0x80;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, ((EN7571_PWR_ADC_VAL) + (0x03)),
+		      ptr, 1);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0204), ptr, 2);
+	tiasd_B = ((ptr[1] << 8) | ptr[0]) & (0x3ff);
+	tiasd_B = tiasd_B - txsd_offset;
+
+	read_Pav_D = ((get_flash_register(pon, FLASH_IMOD_INIT) & 0x0fff0000) >>
+		      18) -
+		     txsd_offset;
+
+	// tia_sd = 0.1 * 2.8 / 1.8 * read_Pav_D + (2.8 / 1.8) * (tiaflt_A - tiasd_B) + 6;
+	// 0.1 * 2.8 / 1.8 ~= 0.1555. 2.8 / 1.8 = 1.555.
+	// Using integer math: 28/180 and 28/18.
+	tia_sd = (28 * read_Pav_D) / 180 +
+		 (28 * (tiaflt_A - tiasd_B)) / 18 + 6;
+
+	dev_info(pon->dev, "TIASD = 0x%x\n", tia_sd);
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_TIASD, ptr, 2);
+	ptr[0] = tia_sd & 0xff;
+	ptr[1] = (tia_sd >> 8) & 0x01;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_TIASD, ptr, 2);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_TIAMUX, ptr, 1);
+	ptr[0] = tia_mux_default;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_TIAMUX, ptr, 1);
+}
+
+static inline void en7571_mpdh_stepsize(struct mtk_pon *pon, int input)
+{
+	unchar ptr[4];
+
+	if (input == 0) {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0234), ptr, 4);
+		ptr[2] = (ptr[2] & 0xc0);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0234), ptr, 4);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0238), ptr, 4);
+		ptr[2] = (ptr[2] & 0xc0);
+		ptr[0] = (ptr[0] & 0xc0);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0238), ptr, 4);
+	} else if (input == 1) {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0234), ptr, 4);
+		ptr[2] = (ptr[2] & 0xc0) | 0x25;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0234), ptr, 4);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0238), ptr, 4);
+		ptr[2] = (ptr[2] & 0xc0) | 0x25;
+		ptr[0] = (ptr[0] & 0xc0) | 0x25;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0238), ptr, 4);
+	}
+}
+
+static inline void en7571_T1delay_setting(struct mtk_pon *pon, int input)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x0008), ptr, 4);
+	if (input == 1) {
+		if (get_flash_register(pon, (0x094)) == 0x07050701) {
+			ptr[0] = (ptr[0] & 0x00) | 0xaa;
+		} else if (get_flash_register(pon, (0x094)) == 0xe7050701) {
+			ptr[0] = (ptr[0] & 0x00) | 0x77;
+		} else if (get_flash_register(pon, (0x094)) == 0xa7050701) {
+			ptr[0] = (ptr[0] & 0x00) | 0x77;
+		}
+	} else if (input == 0) {
+		ptr[0] = (ptr[0] & 0xf0) | 0x0;
+	}
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x0008), ptr, 4);
+}
+
+static inline void en7571_link_reg(struct mtk_pon *pon, int input)
+{
+	unchar ptr[4];
+	if (pon->ver == 2) {
+		if (input == 1) {
+			en7571_mpdh_stepsize(pon, 0);
+			en7571_T1delay_setting(pon, 0);
+		} else if (input == 0) {
+			en7571_mpdh_stepsize(pon, 1);
+			en7571_T1delay_setting(pon, 1);
+		}
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_DUMMY_REG, ptr, 4);
+		ptr[1] = (ptr[1] & 0xfb) | 0x04;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_DUMMY_REG, ptr, 4);
+	} else {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_KT_TUNING, ptr, 3);
+		if (input == 1)
+			ptr[0] = (ptr[0] & 0xfe) | 0x01;
+		else if (input == 0)
+			ptr[0] = (ptr[0] & 0xfe);
+
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_KT_TUNING, ptr, 3);
+		if (input == 1) {
+			en7571_T1delay_setting(pon, 0);
+		} else if (input == 0) {
+			en7571_T1delay_setting(pon, 1);
+		}
+	}
+}
+
+static inline void en7571_DCL_start(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_I2C_GLITCH_PROT, ptr, 4);
+	ptr[1] = (ptr[1] & 0xfe) | 0x01;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_I2C_GLITCH_PROT, ptr, 4);
+}
+
+static inline void en7571_DCL_stop(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_I2C_GLITCH_PROT, ptr, 4);
+	ptr[1] = ptr[1] & 0xfe;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_I2C_GLITCH_PROT, ptr, 4);
+}
+
+static inline void en7571_SingleClosedLoopMode(struct mtk_pon *pon)
+{
+	en7571_DCL_stop(pon);
+	en7571_mpdh_stepsize(pon, 0);
+	en7571_hw_reset(pon);
+	en7571_DCL_start(pon);
+}
+
+static inline void en7571_change_Imod(struct mtk_pon *pon, uint32_t input)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_IMOD_DAC, ptr, 4);
+	ptr[1] = (ptr[1] & 0xf0) | (input >> 8);
+	ptr[0] = (input & 0xff);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IMOD_DAC, ptr, 4);
+}
+
+static inline void en7571_change_Ibias(struct mtk_pon *pon, uint32_t input)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, EN7571_IBIAS_DAC, ptr, 4);
+	ptr[1] = (ptr[1] & 0xf0) | (input >> 8);
+	ptr[0] = (input & 0xff);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, EN7571_IBIAS_DAC, ptr, 4);
+}
+
+static inline void en7571_LUT_Tracking(struct mtk_pon *pon)
+{
+	uint Imod_target = 0;
+	uint Ibias_target = 0;
+
+	int temperature_index = 0;
+
+	// temperature_index = (int)((pon->env_temperature + 40) / 2.5);
+	// decideg: (temp + 400) / 25
+	temperature_index = (pon->env_temperature + 400) / 25;
+
+	if (temperature_index < 0)
+		temperature_index = 0;
+
+	if (pon->scl == 1) {
+	} else if (pon->dol == 1) {
+		Ibias_target = lut_ibias_imod[temperature_index][0];
+		Imod_target = lut_ibias_imod[temperature_index][1];
+		if ((Ibias_target == 0xfff) || (Imod_target == 0xfff))
+			return;
+
+		dev_info(pon->dev, "Target Ibias loaded, 0x%x\n", Ibias_target);
+		dev_info(pon->dev, "Target Imod loaded, 0x%x\n", Imod_target);
+
+		en7571_change_Ibias(pon, Ibias_target);
+		en7571_change_Imod(pon, Imod_target);
+		dev_info(pon->dev, "Using change fcn\n");
+	}
+}
+
+static inline void en7571_OpenLoopMode(struct mtk_pon *pon, int input)
+{
+	unchar ptr[4];
+
+	if (input == 1) {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x013C), ptr, 1);
+		ptr[0] = (ptr[0] & 0xfc) | 0x02;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x013C), ptr, 1);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x014C), ptr, 1);
+		ptr[0] = (ptr[0] & 0xfc) | 0x02;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x014C), ptr, 1);
+	} else if (input == 0) {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x013C), ptr, 1);
+		ptr[0] = (ptr[0] & 0xfc);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x013C), ptr, 1);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, (0x014C), ptr, 1);
+		ptr[0] = (ptr[0] & 0xfc);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, (0x014C), ptr, 1);
+	}
+}
+
+static inline void en7571_config(struct mtk_pon *pon)
+{
+	if (get_flash_register(pon, FLASH_INTERNAL_DDMI) == 0) {
+		pon->internal_ddmi = 0;
+		dev_info(pon->dev, "Internal DDMI Disabled\n");
+	} else {
+		dev_info(pon->dev, "Internal DDMI Enabled\n");
+		if (get_flash_register(pon, FLASH_INTERNAL_DDMI) == 2)
+			pon->fast_ddmi = 1;
+	}
+
+	if (get_flash_register(pon, FLASH_LOOP_MODE) == 1) {
+		pon->scl = 1;
+		en7571_SingleClosedLoopMode(pon);
+		LUT_recover(pon);
+		temperature_get(pon);
+		en7571_LUT_Tracking(pon);
+		dev_info(pon->dev, "Single-closed Loop Mode Enabled\n");
+	} else if (get_flash_register(pon, FLASH_LOOP_MODE) == 2) {
+		pon->dol = 1;
+		en7571_OpenLoopMode(pon, 1);
+		LUT_recover(pon);
+		temperature_get(pon);
+		en7571_LUT_Tracking(pon);
+		dev_info(pon->dev, "Open Loop Mode Enabled\n");
+	} else if (get_flash_register(pon, FLASH_ERC_ENABLE) != 0xffffffff) {
+		pon->erc = 1;
+		dev_info(pon->dev, "ERC Enabled\n");
+	} else {
+		if (get_flash_register(pon, FLASH_KT_ENABLE) == 0xffffffff) {
+			set_flash_register(pon, 0x00060020, FLASH_KT_ENABLE);
+			pon->kt = 1;
+			dev_info(pon->dev, "KT Enabled\n");
+		} else {
+			pon->kt = 1;
+			dev_info(pon->dev, "KT Enabled\n");
+		}
+
+		if (get_flash_register(pon, FLASH_KT_MODE) == 2) {
+			pon->kt = 2;
+			dev_info(pon->dev, "KT Inversed\n");
+		} else if (get_flash_register(pon, FLASH_KT_MODE) == 3) {
+			pon->kt = 3;
+			dev_info(pon->dev, "KT Enhanced\n");
+		}
+	}
+
+	pon->delay1 = 0;
+	pon->delay2 = 600;
+	pon->pav_loop = 1;
+
+	if (get_flash_register(pon, FLASH_CROSS_ENABLE) == 0)
+		pon->cross = 0;
+}
+
+static int en7571_init(struct platform_device *pdev, struct mtk_pon *pon)
+{
+	struct mtk_en7571_priv *priv;
+
+	priv = devm_kzalloc(&pdev->dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+	pon->priv = priv;
+
+	if (!en7571_detection(pon))
+		return dev_err_probe(pon->dev, -ENODEV,
+				     "en7571 PON PHY not detected\n");
+
+	sw_reset(pon);
+	en7571_hw_reset(pon);
+	en7571_7571_enable(pon);
+	en7571_PWRADC_calibration(pon);
+	en7571_PWRADC_enable(pon);
+	ADC_calibration(pon);
+	en7571_RSSI_calibration(pon);
+	en7571_eFuse_temperature_get(pon);
+
+	set_pon_phy_data(pon, PHY_CSR_XPON_SETTING, 0x10f);
+
+	switch (get_flash_register(pon, FLASH_XPON_MODE)) {
+	case 0x07050701:
+		dev_info(pon->dev, "Start GPON Tx Calibration\n");
+		phy_mode_config(pon, PHY_GPON_CONFIG, 1);
+		pon->xpon_mode = PHY_GPON_CONFIG;
+		TGEN(pon, PHY_GPON_CONFIG);
+		APD_initialization(pon);
+		if (get_flash_register(pon, FLASH_T_APD) != 0xffffffff) {
+			{
+				pon->tapd =
+					get_flash_register(pon, FLASH_T_APD);
+				if (pon->tapd < 10) {
+					dev_info(
+						pon->dev,
+						"APD update period is too short, reset to 10s\n");
+					pon->tapd = 10;
+				}
+			}
+			APD_control(pon);
+		}
+
+		break;
+	case 0xe7050701:
+		dev_info(pon->dev, "Start EPON Tx Calibration\n");
+		phy_mode_config(pon, PHY_EPON_CONFIG, 1);
+		pon->xpon_mode = PHY_EPON_CONFIG;
+
+		TGEN(pon, PHY_EPON_CONFIG);
+		break;
+	case 0xa7050701:
+		dev_info(pon->dev, "Start xPON Tx Calibration\n");
+		phy_mode_config(pon, PHY_GPON_CONFIG, 1);
+		pon->xpon_mode = PHY_GPON_CONFIG;
+
+		TGEN(pon, 0xa7050701);
+
+		APD_initialization(pon);
+		if (get_flash_register(pon, FLASH_T_APD) != 0xffffffff) {
+			pon->tapd = get_flash_register(pon, FLASH_T_APD);
+			if (pon->tapd < 10) {
+				dev_info(
+					pon->dev,
+					"APD update period is too short, reset to 10s\n");
+				pon->tapd = 10;
+			}
+		}
+		APD_control(pon);
+		break;
+	default:
+		en7571_LOS_init(pon);
+		pon->internal_ddmi = 0;
+		dev_info(pon->dev, "Internal DDMI Disabled\n");
+		return 0;
+	}
+
+	en7571_reg_init(pon);
+	en7571_load_Tx_cal_data(pon);
+	en7571_TxSD_level_set(pon);
+	RSSI_gain_init(pon);
+	LOS_level_set(pon);
+	RougeONU_clear(pon);
+	safe_circuit_reset(pon);
+	en7571_link_reg(pon, 1);
+	en7571_DCL_start(pon);
+	en7571_config(pon);
+
+	dev_info(pon->dev, "en7571 PON PHY initialized\n");
+	return 0;
+}
+
+const struct mtk_pon_data en7571_pon_data = {
+	.init = en7571_init,
+};
