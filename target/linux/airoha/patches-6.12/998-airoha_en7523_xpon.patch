+int config_mode_7523(struct mtk_pon *pon, enum xpon_phy_mode xpon_mode)
+{
+	uint write_data = 0, read_data = 0;
+
+	switch (xpon_mode) {
+	case PHY_GPON_CONFIG:
+	case PHY_UNKNOWN_CONFIG:
+		dev_info(pon->dev, "Config GPON/UNKNOWN mode\n");
+
+		regmap_read(pon->scu_regmap, CR_NP_WAN_CONF, &read_data);
+		write_data = (read_data & 0xffffff00);
+		regmap_write(pon->scu_regmap, CR_NP_WAN_CONF, write_data);
+		dev_info(pon->dev, "WAN_CONF read=0x%x, write=0x%x", read_data,
+			 write_data);
+		udelay(1);
+
+		set_pon_phy_data(pon, 0x1faf0000 + 0x3028, 0x18001722);
+
+		get_pon_phy_data(pon, 0xbfaf0100 + 0x0024, &read_data);
+		write_data = (read_data | (1 << 31));
+		set_pon_phy_data(pon, 0xbfaf0100 + 0x0024, write_data);
+		udelay(1);
+
+		set_pon_phy_data(pon, 0x1faf0000 + 0x4608, 0x54101801);
+		set_pon_phy_data(pon, 0x1faf0000 + 0x4530, 0x380013);
+
+		get_pon_phy_data(pon, 0x1faf0000 + 0x424C, &read_data);
+		write_data = ((read_data & 0xffffff00) | 0x02);
+		write_data = ((write_data & 0xffff00ff) | 0xb00);
+		set_pon_phy_data(pon, 0x1faf0000 + 0x424C, write_data);
+
+		break;
+	case PHY_EPON_CONFIG:
+		dev_info(pon->dev, "Config EPON mode\n");
+
+		regmap_read(pon->scu_regmap, CR_NP_WAN_CONF, &read_data);
+		write_data = (read_data & 0xffffff00) | 0x01;
+		regmap_write(pon->scu_regmap, CR_NP_WAN_CONF, write_data);
+
+		dev_info(pon->dev, "WAN_CONF read=0x%x, write=0x%x", read_data,
+			 write_data);
+		udelay(1);
+
+		set_pon_phy_data(pon, 0x1faf0000 + 0x3028, 0x18001722);
+
+		get_pon_phy_data(pon, 0xbfaf0100 + 0x0024, &read_data);
+		write_data = (read_data & ~(1 << 31));
+		set_pon_phy_data(pon, 0xbfaf0100 + 0x0024, write_data);
+		udelay(1);
+
+		set_pon_phy_data(pon, 0x1faf0000 + 0x4608, 0x54101801);
+		set_pon_phy_data(pon, 0x1faf0000 + 0x4530, 0x380013);
+
+		get_pon_phy_data(pon, 0x1faf0000 + 0x4200, &read_data);
+		write_data = ((read_data & 0xfffffffe) | 0x01);
+		set_pon_phy_data(pon, 0x1faf0000 + 0x4200, write_data);
+
+		get_pon_phy_data(pon, 0x1faf0000 + 0x424C, &read_data);
+		write_data = ((read_data & 0xffffff00) | 0x02);
+		write_data = ((write_data & 0xffff00ff) | 0x500);
+		set_pon_phy_data(pon, 0x1faf0000 + 0x424C, write_data);
+
+		break;
+	default:
+		dev_info(pon->dev, "Unknown xpon_mode %d\n", xpon_mode);
+		break;
+	}
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4214, &read_data);
+	write_data = ((read_data & 0xffff) | (0x03f00000));
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4214, write_data);
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4124, &read_data);
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4124, read_data | (0x01));
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4120, &read_data);
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4120, (read_data | ((1 << 16))));
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4100, &read_data);
+	write_data = read_data & ~((1 << 28));
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4100, write_data);
+
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4248, 0x2);
+
+	regmap_read(pon->scu_regmap, CR_CHIP_SCU_IOMUX_CTRL_3, &read_data);
+	write_data = (read_data | 0x01);
+	regmap_write(pon->scu_regmap, CR_CHIP_SCU_IOMUX_CTRL_3, write_data);
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4110, &read_data);
+	write_data = ((read_data & 0xfffff000) | 0x101);
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4110, write_data);
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4100, &read_data);
+	write_data = ((read_data & 0xBFFFFFFF) | ((1 << 30)));
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4100, write_data);
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4344, &read_data);
+	write_data = ((read_data & 0xfffffff8) | (0x1));
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4344, write_data);
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4204, &read_data);
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4204, read_data | (0x200 | 0x100));
+	udelay(1);
+
+	get_pon_phy_data(pon, 0x1faf0000 + 0x4204, &read_data);
+	set_pon_phy_data(pon, 0x1faf0000 + 0x4204, read_data & ~(0x200));
+	mdelay(1);
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(config_mode_7523);
+
+static void phy_int_config(struct mtk_pon *pon, uint int_type,
+			   uint pma_int_type)
+{
+	uint write_data = 0, read_data = 0;
+	get_pon_phy_data(pon, 0xbfaf05F0, &read_data);
+	write_data = (read_data & (0xFFFFFF00)) | int_type;
+
+	dev_info(pon->dev, "Phy_Int_Config read_data:0x%.8x\n", read_data);
+	dev_info(pon->dev, "Phy_Int_Config write_data:0x%.8x\n", write_data);
+	set_pon_phy_data(pon, 0xbfaf05F0, write_data);
+
+	get_pon_phy_data(pon, 0x1faf4804, &read_data);
+	write_data = (read_data & (0xFFFFFF00)) | pma_int_type;
+	dev_info(pon->dev, "PMA_PON_INTERRUPT_EN_0 write_data:0x%.8x\n",
+		 write_data);
+	set_pon_phy_data(pon, 0x1faf4804, write_data);
+}
+
+static int phy_cnt_enable(struct mtk_pon *pon, unchar errcnt_en,
+			  unchar bipcnt_en, unchar fmcnt_en)
+{
+	uint write_data = 0, read_data = 0, clear_type = 0;
+
+	get_pon_phy_data(pon, 0xbfaf0200 + 0x0030, &read_data);
+	read_data = read_data & 0xfffffff8;
+
+	if ((errcnt_en == (1)) || (errcnt_en == (0))) {
+		read_data = read_data | errcnt_en;
+		clear_type = clear_type | PHY_ERR_CNT_CLR;
+	}
+	if ((bipcnt_en == (1)) || (bipcnt_en == (0))) {
+		read_data = read_data | (bipcnt_en << 1);
+		clear_type = clear_type | PHY_BIP_CNT_CLR;
+	}
+	if ((fmcnt_en == (1)) || (fmcnt_en == (0))) {
+		read_data = read_data | (fmcnt_en << 2);
+		clear_type = clear_type | PHY_RXFRAME_CNT_CLR;
+	}
+	write_data = read_data;
+	udelay(1);
+	set_pon_phy_data(pon, 0xbfaf0200 + 0x0030, write_data);
+
+	if ((clear_type & PHY_ERR_CNT_CLR) == PHY_ERR_CNT_CLR)
+		set_pon_phy_data(pon, 0xbfaf0200 + 0x0034, (1 << 1));
+	if ((clear_type & PHY_BIP_CNT_CLR) == PHY_BIP_CNT_CLR)
+		set_pon_phy_data(pon, 0xbfaf0200 + 0x0034, (1 << 3));
+	if ((clear_type & PHY_RXFRAME_CNT_CLR) == PHY_RXFRAME_CNT_CLR)
+		set_pon_phy_data(pon, 0xbfaf0200 + 0x0034, (1 << 5));
+
+	if ((clear_type & PHY_TXFRAME_CNT_CLR) == PHY_TXFRAME_CNT_CLR) {
+		get_pon_phy_data(pon, 0xbfaf0400 + 0x0024, &read_data);
+		write_data = read_data | (1 << 2);
+		set_pon_phy_data(pon, 0xbfaf0400 + 0x0024, write_data);
+	}
+
+	if ((clear_type & PHY_EPON_ERR_CNT_CLR) == PHY_EPON_ERR_CNT_CLR)
+		set_pon_phy_data(pon, 0xbfaf0200 + 0x0098, (1 << 4));
+
+	return 0;
+}
+
+static int phy_reset_counter(struct mtk_pon *pon)
+{
+	uint read_data = 0, write_data = 0;
+
+	set_pon_phy_data(pon, 0xbfaf0200 + 0x0034, (1 << 1));
+	set_pon_phy_data(pon, 0xbfaf0200 + 0x0034, (1 << 3));
+	set_pon_phy_data(pon, 0xbfaf0200 + 0x0034, (1 << 5));
+
+	get_pon_phy_data(pon, 0xbfaf0400 + 0x0024, &read_data);
+	write_data = read_data | (1 << 2);
+	set_pon_phy_data(pon, 0xbfaf0400 + 0x0024, write_data);
+
+	set_pon_phy_data(pon, 0xbfaf0200 + 0x0098, (1 << 4));
+	return 0;
+}
+
+static int mtk_reset_phy(struct platform_device *pdev, struct mtk_pon *pon)
+{
+	uint val;
+
+	val = GET_SCU_RST_RG(pon);
+	val |= 0x01;
+	SET_SCU_RST_RG(pon, val);
+	udelay(1);
+
+	val &= ~(0x01);
+	SET_SCU_RST_RG(pon, val);
+
+	return config_mode_7523(pon, PHY_UNKNOWN_CONFIG);
+}
+
+static int mtk_dev_init(struct platform_device *pdev, struct mtk_pon *pon)
+{
+	uint read_data = 0, write_data = 0;
+
+	regmap_read(pon->scu_regmap, CR_CHIP_SCU_IOMUX_CTRL_3, &read_data);
+	write_data = (read_data | 0x01);
+	regmap_write(pon->scu_regmap, CR_CHIP_SCU_IOMUX_CTRL_3, write_data);
+
+	get_pon_phy_data(pon, 0xbfaf0100 + 0x0008, &read_data);
+	read_data = read_data & ~((1 << 2));
+	set_pon_phy_data(pon, 0xbfaf0100 + 0x0008, write_data);
+
+	regmap_read(pon->scu_regmap, CR_NP_SCU_RST_ACC_CHK_BMAP, &read_data);
+	read_data = read_data & ~((1 << 2));
+	regmap_write(pon->scu_regmap, CR_NP_SCU_RST_ACC_CHK_BMAP, read_data);
+
+	regmap_read(pon->scu_regmap, CR_NP_SCU_GPIO_SSR, &read_data);
+	read_data = read_data & ~((1 << 10));
+	regmap_write(pon->scu_regmap, CR_NP_SCU_GPIO_SSR, read_data);
+
+	phy_int_config(pon, (0x40 | 0x20 | 0x02 | 0x01), 0);
+	phy_cnt_enable(pon, (1), (1), (1));
+
+	set_pon_phy_data(pon, 0xbfaf0400 + 0x0004, 0xAAAB5983);
+	phy_reset_counter(pon);
+
+	dev_info(pon->dev, "PON PHY initialized\n");
+	return 0;
+}
+
+static int phy_bit_delay(struct mtk_pon *pon, unchar delay_value)
+{
+	uint write_data = 0;
+	uint read_data = 0;
+	uint flag_7523_asic = 0;
+
+	if (!GET_IS_FPGA(pon)) {
+		flag_7523_asic = 1;
+	}
+
+	if ((delay_value & 0xf8) == 0x00) {
+		if (flag_7523_asic == 1) {
+			get_pon_phy_data(pon, 0x1faf433C, &read_data);
+			write_data = ((read_data & 0xffffff00) | (delay_value));
+			set_pon_phy_data(pon, 0x1faf433C, write_data);
+			get_pon_phy_data(pon, 0x1faf433C, &read_data);
+
+			dev_info(pon->dev, "0x%x=0x%x, delay = %d\n",
+				 0x1faf433C, read_data, read_data & 0x7f);
+		} else {
+			get_pon_phy_data(pon, 0xbfaf0110, &read_data);
+			write_data = (read_data & 0xff87ffff) |
+				     (delay_value << 19) | (1 << 23);
+			set_pon_phy_data(pon, 0xbfaf0110, write_data);
+
+			get_pon_phy_data(pon, 0xbfaf0110, &read_data);
+			dev_info(pon->dev, "0x%x=0x%x, phy_bit_delay %s (%d)\n",
+				 0xbfaf0110, read_data,
+				 (read_data & (1 << 23)) ? "ON" : "off",
+				 (read_data & (~0xff87ffff)) >> 19);
+		}
+		return (0);
+
+	} else {
+		dev_info(pon->dev, "error input : delay_value. \n");
+		return (1);
+	}
+}
+
+static void phy_los_handler(struct mtk_pon *pon)
+{
+	uint phyIntStatus;
+
+	get_pon_phy_data(pon, 0xbfaf05F8, &phyIntStatus);
+	set_pon_phy_data(pon, 0xbfaf05F4, phyIntStatus);
+
+	// if( mt7570_select == 1 )
+	// {
+	//  TEC_switch = 0;
+	//  BiasTracking_switch = 0;
+	// }
+	phy_bit_delay(pon, 0);
+	phy_reset_counter(pon);
+}
+
+static void phy_ready_handler(struct mtk_pon *pon)
+{
+	uint write_data, read_data;
+	get_pon_phy_data(pon, 0x1faf4110, &read_data);
+	write_data = read_data & 0xfffffffe;
+	set_pon_phy_data(pon, 0x1faf4110, write_data);
+	udelay(1);
+	write_data |= 0x1;
+	set_pon_phy_data(pon, 0x1faf4110, write_data);
+	mdelay(1);
+
+	get_pon_phy_data(pon, 0x1faf4304, &read_data);
+	write_data = read_data & (~(1 << 8));
+	set_pon_phy_data(pon, 0x1faf4304, write_data);
+	dev_info(
+		pon->dev,
+		"PON_SYS_CTRL_1_ADDR[0x%x] read_data = 0x%x , write_data = 0x%x\n",
+		(0x1faf0000 + 0x4304), read_data, write_data);
+	udelay(1);
+	write_data = write_data | (1 << 8);
+	set_pon_phy_data(pon, 0x1faf4304, write_data);
+	dev_info(
+		pon->dev,
+		"PON_SYS_CTRL_1_ADDR[0x%x] read_data = 0x%x , write_data = 0x%x\n",
+		(0x1faf0000 + 0x4304), read_data, write_data);
+	mdelay(1);
+
+	// if( mt7570_select == 1 )
+	// {
+	//  TEC_switch = 1;
+	// 	BiasTracking_switch = 1;
+	// }
+}
+
+static void phy_event_handler(struct mtk_pon *pon,
+			      struct PON_PHY_Event_data_t *pEvent_data)
+{
+	// XPON_DPRINT_MSG("[%s] event:%d, src:%d\n", __FUNCTION__, pEvent_data->id, pEvent_data->src);
+	static int los_cnt = 0;
+	static int ready_cnt = 0;
+
+	switch (pEvent_data->id) {
+	case PHY_EVENT_PHY_LOF_INT:
+	case PHY_EVENT_TRANS_LOS_INT:
+	case PHY_EVENT_PHY_ILLG_INT:
+	case PHY_EVENT_TRANS_LOS_ILLG_INT:
+		phy_los_handler(pon);
+		los_cnt++;
+		break;
+
+	case PHY_EVENT_TF_INT:
+		break;
+
+	case PHY_EVENT_TRANS_INT:
+		break;
+
+	case PHY_EVENT_TRANS_SD_FAIL_INT:
+		break;
+
+	case PHY_EVENT_PHYRDY_INT:
+		phy_ready_handler(pon);
+		ready_cnt++;
+		break;
+
+	case PHY_EVENT_I2CM_INT:
+		break;
+
+	case PHY_EVENT_NO_LOS_NO_READY:
+		break;
+	default:
+		printk("[%s] event %d still left for ISR to handle\n",
+		       __FUNCTION__, pEvent_data->id);
+		break;
+	}
+
+	dev_info(pon->dev, "%s event:%d, src:%d (los=%d,ready=%d)\n",
+		 __FUNCTION__, pEvent_data->id, pEvent_data->src, los_cnt,
+		 ready_cnt);
+	// XPON_MAC_EVENT_HANDLER(pEvent_data); // Update to new mac handler
+}
+
+static void phy_trans_tx_getting(struct mtk_pon *pon,
+				 struct PHY_TransConfig_T *trans_status)
+{
+	uint read_data = 0;
+	get_pon_phy_data(pon, (0xbfaf0100 + 0x0038), &read_data);
+	if ((read_data & ~(0xffffffef)) != 0)
+		trans_status->trans_tx_sd_inv_status = (1);
+	else
+		trans_status->trans_tx_sd_inv_status = (0);
+	if ((read_data & ~(0xffffff7f)) != 0)
+		trans_status->trans_burst_en_inv_status = (1);
+	else
+		trans_status->trans_burst_en_inv_status = (0);
+	if ((read_data & ~(0xffffffdf)) != 0)
+		trans_status->trans_tx_fault_inv_status = (1);
+	else
+		trans_status->trans_tx_fault_inv_status = (0);
+}
+
+static void pon_phy_rogueonu_int_en(struct mtk_pon *pon, unchar rogue_int_en)
+{
+	uint read_data = 0, write_data = 0;
+	uint rogue_onu_length = 0xffff;
+
+	if (rogue_int_en == 1) {
+		get_pon_phy_data(pon, (0x1faf0000 + 0x4810), &rogue_onu_length);
+		rogue_onu_length &= 0xffff;
+		dev_info(pon->dev, "Rogue ONU ON (Length :%d ns) \n",
+			 rogue_onu_length * 4);
+
+		get_pon_phy_data(pon, (0x1faf0000 + 0x480c), &read_data);
+		write_data = read_data | 0x1000;
+		set_pon_phy_data(pon, (0x1faf0000 + 0x480c), write_data);
+
+		get_pon_phy_data(pon, (0x1faf0000 + 0x4804), &read_data);
+		write_data = read_data | 0x80;
+		set_pon_phy_data(pon, (0x1faf0000 + 0x4804), write_data);
+
+	} else {
+		dev_info(pon->dev, "Rogue ONU OFF \n");
+		get_pon_phy_data(pon, (0x1faf0000 + 0x480c), &read_data);
+		write_data = read_data & 0xffffefff;
+		set_pon_phy_data(pon, (0x1faf0000 + 0x480c), write_data);
+	}
+}
