diff --git a/drivers/net/pon/xpon.h b/drivers/net/pon/xpon.h
new file mode 100644
index 000000000..e27b03998
--- /dev/null
+++ b/drivers/net/pon/xpon.h
@@ -0,0 +1,66 @@
+#ifndef __LINUX_PON_H__
+#define __LINUX_PON_H__
+#include <linux/of_net.h>
+#include <linux/platform_device.h>
+#include <linux/netdevice.h>
+#include <linux/debugfs.h>
+#include <linux/etherdevice.h>
+#include <linux/iopoll.h>
+#include <linux/kernel.h>
+
+struct class *pon_class;
+extern struct attribute *xpon_attrs[];
+
+enum GPON_STATE {
+	GPON_STATE_UNKNOWN,
+	GPON_STATE_DISCONNECTED,
+	GPON_STATE_INITIAL,
+	GPON_STATE_STANDBY,
+	GPON_STATE_SERIAL_NUMBER,
+	GPON_STATE_RANGING,
+	GPON_STATE_OPERATION,
+	GPON_STATE_POPUP,
+	GPON_STATE_EMERGENCY_STOP,
+
+	GPON_STATE_MAX
+};
+
+enum GPON_AUTHENTICATION_STATUS {
+	GPON_AUTH_UNKNOWN,
+	GPON_AUTH_OK,
+	GPON_AUTH_UNAUNTHORIZED,
+};
+
+enum PON_TYPE {
+	EPON,
+	EPON10G,
+	GPON,
+	XGPON,
+	NGPON,
+	XGSPON,
+
+	PON_TYPE_MAX
+};
+
+struct xpon_device {
+	struct net_device* netdev;
+	struct device *dev;
+
+	enum PON_TYPE(*current_pon_type)(struct net_device* dev);
+	int (*switch_pon)(struct net_device* dev, enum PON_TYPE type);
+	enum GPON_STATE (*get_gpon_state)(struct net_device* dev);
+	int (*get_onu_id)(struct net_device* dev);
+	int (*epon_fec_down)(struct net_device* dev, int *fec_down);
+	int (*epon_fec_up)(struct net_device* dev, int *fec_up);
+};
+
+/**
+ * Same to alloc_netdev_dummy, but with `pon` interface name.
+ */
+struct xpon_device* alloc_pon_netdev(void);
+
+int register_xpon(struct xpon_device *xpon);
+
+void unregister_xpon(struct xpon_device *xpon);
+
+#endif
\ No newline at end of file
diff --git a/drivers/net/pon/xpon_dev.c b/drivers/net/pon/xpon_dev.c
new file mode 100644
index 000000000..c3bcf9d11
--- /dev/null
+++ b/drivers/net/pon/xpon_dev.c
@@ -0,0 +1,48 @@
+// SPDX-License-Identifier: GPL-2.0+
+#include "xpon.h"
+
+static void init_pon_netdev(struct net_device *dev)
+{
+	dev->reg_state = NETREG_DUMMY;
+}
+
+struct xpon_device *alloc_pon_netdev(void)
+{
+	struct xpon_device *xpon;
+
+	xpon = kzalloc(sizeof(*xpon), GFP_KERNEL);
+	if (!xpon)
+		return NULL;
+
+	xpon->netdev = alloc_netdev(0, "pon%d", NET_NAME_UNKNOWN, init_pon_netdev);
+	if (!xpon->netdev) {
+		kfree(xpon);
+		return NULL;
+	}
+
+	return xpon;
+}
+EXPORT_SYMBOL_GPL(alloc_pon_netdev);
+
+int register_xpon(struct xpon_device *xpon) {
+	struct device* dev = xpon->dev;
+
+	xpon->dev =	device_create(pon_class, xpon->dev, dev->devt, xpon, "%s", xpon->netdev->name);
+	if (IS_ERR(xpon->dev)) {
+		pr_err("failed to create device\n");
+		return PTR_ERR(xpon->dev);
+	}
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(register_xpon);
+
+void unregister_xpon(struct xpon_device *xpon) {
+	if (!xpon->dev)
+		return;
+
+	if (xpon->netdev)
+		free_netdev(xpon->netdev);
+
+	device_destroy(pon_class, xpon->dev->devt);
+}
\ No newline at end of file
diff --git a/drivers/net/pon/xpon_sysfs.c b/drivers/net/pon/xpon_sysfs.c
new file mode 100644
index 000000000..aaa83a855
--- /dev/null
+++ b/drivers/net/pon/xpon_sysfs.c
@@ -0,0 +1,141 @@
+// SPDX-License-Identifier: GPL-2.0+
+#include <linux/string.h>
+
+#include "xpon.h"
+
+/*
+Registration status
+ONU ID
+PON Type
+FEC Up/Down
+Current Speed upload and download
+*/
+
+static const char *gpon_state_status[GPON_STATE_MAX] = {
+	[GPON_STATE_UNKNOWN] = "Unknown",
+	[GPON_STATE_DISCONNECTED] = "PON Disconnected",
+	[GPON_STATE_INITIAL] = "Initial",
+	[GPON_STATE_STANDBY] = "Standby",
+	[GPON_STATE_SERIAL_NUMBER] = "Serial number",
+	[GPON_STATE_RANGING] = "Ranging",
+	[GPON_STATE_OPERATION] = "OK",
+	[GPON_STATE_POPUP] = "Waiting for popup",
+	[GPON_STATE_EMERGENCY_STOP] = "Emergency stop",
+};
+
+static const char* pon_types[PON_TYPE_MAX] = {
+	[EPON] = "EPON",
+	[EPON10G] = "EPON10G",
+	[GPON] = "GPON",
+	[XGPON] = "XGPON",
+	[NGPON] = "NGPON",
+	[XGSPON] = "XGSPON",
+};
+
+static ssize_t gpon_status_show(struct device *dev,
+				struct device_attribute *attr, char *buf)
+{
+	struct xpon_device *xpon = dev_get_drvdata(dev);
+	const char *status;
+
+	if (!xpon->get_gpon_state)
+		status = gpon_state_status[GPON_STATE_UNKNOWN];
+	else
+		status = gpon_state_status[xpon->get_gpon_state(xpon->netdev)];
+
+	return sprintf(buf, "%s\n", status);
+}
+static DEVICE_ATTR_RO(gpon_status);
+
+static ssize_t pon_onu_id_show(struct device *dev,
+			       struct device_attribute *attr, char *buf)
+{
+	struct xpon_device *xpon = dev_get_drvdata(dev);
+	int onu_id;
+
+	if (!xpon->get_onu_id)
+		onu_id = -ENOENT;
+	else
+		onu_id = xpon->get_onu_id(xpon->netdev);
+
+	if (onu_id < 0)
+		return onu_id;
+
+	return sprintf(buf, "%d\n", onu_id);
+}
+static DEVICE_ATTR_RO(pon_onu_id);
+
+static ssize_t pon_type_show(struct device *dev, struct device_attribute *attr,
+			     char *buf)
+{
+	struct xpon_device *xpon = dev_get_drvdata(dev);
+	const char *type;
+
+	if (!xpon->current_pon_type)
+		type = "Unknown";
+	else
+		type = pon_types[xpon->current_pon_type(xpon->netdev)];
+
+	return sprintf(buf, "%s\n", type);
+}
+
+static ssize_t pon_type_store(struct device *dev, struct device_attribute *attr,
+			 const char *buf, size_t count)
+{
+	struct xpon_device *xpon = dev_get_drvdata(dev);
+	int ret;
+	int type = -1;
+
+	for (int i = 0; i < PON_TYPE_MAX; i++) {
+		if (strcmp(buf, pon_types[i]) == 0) {
+			type = i;
+			break;
+		}
+	}
+
+	if (type < 0) {
+		ret = kstrtoint(buf, 10, &type);
+		if (ret < 0)
+			return ret;
+	}
+
+	if (type < EPON || type >= PON_TYPE_MAX)
+		return -EINVAL;
+
+	ret = xpon->switch_pon(xpon->netdev, type);
+	if (ret < 0)
+		return ret;
+
+	return count;
+}
+static DEVICE_ATTR_RW(pon_type);
+
+static ssize_t fec_up_down_show(struct device *dev,
+			       struct device_attribute *attr, char *buf)
+{
+	struct xpon_device *xpon = dev_get_drvdata(dev);
+	int fec_up, fec_down;
+	int ret;
+
+	if (!xpon->epon_fec_down || !xpon->epon_fec_up)
+		return -ENOENT;
+
+	ret = xpon->epon_fec_up(xpon->netdev, &fec_up);
+	if (ret < 0)
+		return ret;
+
+	ret = xpon->epon_fec_down(xpon->netdev, &fec_down);
+	if (ret < 0)
+		return ret;
+
+	return sprintf(buf, "FEC Upload: %d\nFEC Download: %d\n", fec_up, fec_down);
+}
+static DEVICE_ATTR_RO(fec_up_down);
+
+struct attribute *xpon_attrs[] = {
+	&dev_attr_gpon_status.attr,
+	&dev_attr_pon_onu_id.attr,
+	&dev_attr_pon_type.attr,
+	&dev_attr_fec_up_down.attr,
+	NULL,
+};
\ No newline at end of file
