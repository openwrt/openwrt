+
+static int mtk_dev_start(struct net_device *dev)
+{
+	Pgpon_mac_reg_REGS g_gpon_mac_reg_BASE;
+
+	/* Base Register of  GPON */
+	g_gpon_mac_reg_BASE =
+		ioremap(CONFIG_GPON_BASE_ADDR, CONFIG_GPON_REG_RANGE);
+	if (!g_gpon_mac_reg_BASE) {
+		dev_err(&dev->dev, "ioremap the GPON base address failed.\n");
+		return -ENOMEM;
+	}
+
+	print_gpon_mac_reg_regs(netdev_priv(dev), g_gpon_mac_reg_BASE);
+
+	uint *reg = ioremap(0xBFB00070, sizeof(uint));
+	if (reg)
+		dev_info(&dev->dev, "xpon mode 0x%x", *reg);
+
+	dev_info(&dev->dev, "MTK XPON device initialized\n");
+	dev->state |= NETDEV_UP;
+	return 0;
+}
+
+static int mtk_dev_up(struct net_device *dev)
+{
+	dev_info(&dev->dev, "MTK XPON device set up\n");
+	return 0;
+}
+
+static int mtk_dev_down(struct net_device *dev)
+{
+	dev_info(&dev->dev, "MTK XPON device set down\n");
+	return 0;
+}
+
+static int mtk_dev_change_mtu(struct net_device *dev, int mtu)
+{
+	dev_info(&dev->dev, "MTK XPON device MTU changed to %d\n", mtu);
+	return 0;
+}
+
+static int mtk_dev_set_macaddr(struct net_device *dev, void *p)
+{
+	int err;
+
+	err = eth_mac_addr(dev, p);
+	if (err)
+		return err;
+
+	dev_info(&dev->dev, "new MAC address %pM\n", dev->dev_addr);
+	return 0;
+}
+
+static int mtk_vlan_rx_add_vid(struct net_device *dev, __be16 proto, u16 vid)
+{
+	dev_info(&dev->dev, "MTK XPON device VLAN RX add VID %d, proto 0x%x\n",
+		 vid, ntohs(proto));
+	return 0;
+}
+
+static int mtk_vlan_rx_remove_vid(struct net_device *dev, __be16 proto, u16 vid)
+{
+	dev_info(&dev->dev,
+		 "MTK XPON device VLAN RX remove VID %d, proto 0x%x\n", vid,
+		 ntohs(proto));
+	return 0;
+}
+
+static int mtk_ethtool_get_link_ksettings(struct net_device *dev,
+					  struct ethtool_link_ksettings *cmd)
+{
+	cmd->base.speed = SPEED_25000;
+	cmd->base.duplex = DUPLEX_FULL;
+	cmd->base.autoneg = AUTONEG_DISABLE;
+
+	return 0;
+}
+
+static void mtk_ethtool_get_mac_stats(struct net_device *dev,
+				      struct ethtool_eth_mac_stats *stats)
+{
+	struct mtk_xpon *xdev = netdev_priv(dev);
+	dev_info(&dev->dev, "MTK XPON device get MAC stats\n");
+
+	stats->FramesTransmittedOK = xdev->stats->tx_packets;
+	stats->OctetsTransmittedOK = xdev->stats->tx_bytes;
+	stats->FramesReceivedOK = xdev->stats->rx_packets;
+	stats->OctetsReceivedOK = xdev->stats->rx_bytes;
+	stats->BroadcastFramesReceivedOK = 0;
+	stats->MulticastFramesXmittedOK = 0;
+	stats->BroadcastFramesXmittedOK = 0;
+}
+
+static void mtk_ethtool_get_drvinfo(struct net_device *dev,
+				    struct ethtool_drvinfo *info)
+{
+	struct mtk_xpon *eth = netdev_priv(dev);
+
+	strscpy(info->driver, eth->dev->driver->name, sizeof(info->driver));
+	strscpy(info->bus_info, dev_name(eth->dev), sizeof(info->bus_info));
+}
+
+static const struct net_device_ops mtk_xpon = {
+	.ndo_start_xmit = xpon_xmit_tx,
+	.ndo_init = mtk_dev_start,
+	.ndo_open = mtk_dev_up,
+	.ndo_stop = mtk_dev_down,
+	.ndo_change_mtu = mtk_dev_change_mtu,
+	.ndo_set_mac_address = mtk_dev_set_macaddr,
+	.ndo_vlan_rx_add_vid = mtk_vlan_rx_add_vid,
+	.ndo_vlan_rx_kill_vid = mtk_vlan_rx_remove_vid,
+};
+
+static const struct ethtool_ops mtk_ethtool_ops = {
+	.get_drvinfo = mtk_ethtool_get_drvinfo,
+	.get_link = ethtool_op_get_link,
+	.get_link_ksettings = mtk_ethtool_get_link_ksettings,
+	.get_eth_mac_stats = mtk_ethtool_get_mac_stats,
+};
+
+int add_xpon_mac(struct platform_device *pdev, struct mtk_phy_pon *phy)
+{
+	struct device *dev = &pdev->dev;
+	struct resource *res;
+	struct mtk_xpon *xdev;
+	struct net_device *netdev;
+	int ret;
+
+	netdev = devm_alloc_etherdev(dev, sizeof(*xdev));
+	if (!netdev)
+		return -ENOMEM;
+	strcpy(netdev->name, "xpon%d");
+	netdev->state = NETREG_UNINITIALIZED;
+
+	xdev = netdev_priv(netdev);
+	xdev->phy = phy;
+	xdev->dev = dev;
+
+	xdev->stats = devm_kzalloc(dev, sizeof(*xdev->stats), GFP_KERNEL);
+	if (!xdev->stats) {
+		free_netdev(netdev);
+		return -ENOMEM;
+	}
+
+	// MAC GPON Base
+	xdev->gpon_base =
+		devm_platform_ioremap_resource_byname(pdev, "gpon-mac");
+	if (IS_ERR(xdev->gpon_base)) {
+		free_netdev(netdev);
+		devm_kfree(dev, xdev->stats);
+		return dev_err_probe(dev, PTR_ERR(xdev->gpon_base),
+				     "failed to get gpon base\n");
+	}
+
+	// MAC EPON Base
+	xdev->epon_base =
+		devm_platform_ioremap_resource_byname(pdev, "epon-mac");
+	if (IS_ERR(xdev->epon_base)) {
+		free_netdev(netdev);
+		devm_kfree(dev, xdev->stats);
+		return dev_err_probe(dev, PTR_ERR(xdev->epon_base),
+				     "failed to get epon base\n");
+	}
+
+	// MAC XGPON Base
+	if ((res = platform_get_resource_byname(pdev, IORESOURCE_MEM,
+						"xgpon-mac"))) {
+		xdev->xgpon_base = devm_ioremap_resource(dev, res);
+		if (IS_ERR(xdev->xgpon_base)) {
+			free_netdev(netdev);
+			devm_kfree(dev, xdev->stats);
+			return dev_err_probe(dev, PTR_ERR(xdev->xgpon_base),
+					     "failed to get xgpon base\n");
+		}
+	}
+
+	// get irqs
+	for (int i = 0; i < ARRAY_SIZE(xdev->irqs); i++) {
+		xdev->irqs[i] = platform_get_irq(pdev, i);
+		if (xdev->irqs[i] < 0) {
+			free_netdev(netdev);
+			devm_kfree(dev, xdev->stats);
+			return dev_err_probe(dev, xdev->irqs[i],
+					     "failed to get irq %d\n", i);
+		}
+
+		dev_info(dev, "mac irq %d: %d", i, xdev->irqs[i]);
+	}
+
+	netdev->netdev_ops = &mtk_xpon;
+	netdev->ethtool_ops = &mtk_ethtool_ops;
+	netdev->max_mtu = 1500;
+	netdev->watchdog_timeo = 5 * HZ;
+	netdev->hw_features = NETIF_F_IP_CSUM | NETIF_F_RXCSUM | NETIF_F_TSO6 |
+			      NETIF_F_IPV6_CSUM | NETIF_F_SG | NETIF_F_TSO |
+			      NETIF_F_HW_TC | NETIF_F_HW_VLAN_CTAG_TX |
+			      NETIF_F_HW_VLAN_CTAG_RX |
+			      NETIF_F_HW_VLAN_CTAG_FILTER;
+	netdev->features |= netdev->hw_features;
+	netdev->vlan_features = netdev->hw_features;
+	netdev->dev.of_node = dev->of_node;
+	SET_NETDEV_DEV(netdev, dev);
+
+	eth_hw_addr_random(netdev);
+	dev_info(dev, "generated random MAC address %pM\n", netdev->dev_addr);
+
+	ret = register_netdev(netdev);
+	if (ret) {
+		dev_err(dev, "failed to register net device\n");
+		return ret;
+	}
+
+	return ret;
+}
