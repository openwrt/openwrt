+
+static bool mt7570_detection(struct mtk_pon *pon)
+{
+	struct mtk_mt7570_priv *priv = pon->priv;
+	unchar ptr[1];
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_FT_ADC_CLK_CLR, ptr, 1);
+	if (ptr[0] == 0x03) {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_DUMMY, ptr, 1);
+		priv->ver = ptr[0];
+		return true;
+	}
+
+	return false;
+}
+
+static int mt7570_init(struct platform_device *pdev, struct mtk_pon *pon)
+{
+	struct mtk_mt7570_priv *priv;
+
+	priv = devm_kzalloc(&pdev->dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+	pon->priv = priv;
+
+	if (!mt7570_detection(pon))
+		return dev_err_probe(pon->dev, -ENODEV,
+				     "mt7570 PON PHY not detected\n");
+
+	return dev_err_probe(pon->dev, -EINVAL, "mt7570 not setup");
+	// dev_info(pon->dev, "mt7570 PON PHY initialized\n");
+	// return 0;
+}
+
+const struct mtk_pon_data mt7570_pon_data = {
+	.init = mt7570_init,
+};
