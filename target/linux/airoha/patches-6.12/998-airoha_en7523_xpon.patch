+void APD_I2C_write(struct mtk_pon *pon, unchar ptr[1]);
+void APD_control(struct mtk_pon *pon);
+void CDR(struct mtk_pon *pon, int CDR_switch);
+void TGEN(struct mtk_pon *pon, int xPON);
+int phy_fw_ready(struct mtk_pon *pon, unchar fwrdy_en);
+int phy_mode_config(struct mtk_pon *pon, enum xpon_phy_mode xpon_mode,
+		    int tx_enable);
+void RSSI_gain_init(struct mtk_pon *pon);
+void LOS_init(struct mtk_pon *pon);
