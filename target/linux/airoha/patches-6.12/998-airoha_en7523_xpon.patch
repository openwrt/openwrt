+#ifndef __MTK_PON_H__
+#define __MTK_PON_H__
+#include <linux/device.h>
+#include <linux/platform_device.h>
+#include <linux/i2c.h>
+#include <linux/of.h>
+#include <linux/regmap.h>
+
+#include "mtk-mt757x-regs.h"
+
+// #define CR_CHIP_SCU_IOMUX_CTRL_3 	0x21C // an7581 an7583 and an7552
+#define CR_CHIP_SCU_IOMUX_CTRL_3 0x218 // en7523
+#define CR_NP_WAN_CONF 0x70
+#define CR_NP_SCU_RST_ACC_CHK_BMAP 0x92c
+#define CR_NP_SCU_GPIO_SSR 0x860
+#define CR_NP_SCU_RST_CFG 0x830
+
+#define handle_hw_irq_event(PON, EVENT)                  \
+	phy_event_handler(pon, &((struct PON_PHY_Event_data_t){ \
+		.id = EVENT, .src = PON_PHY_EVENT_SOURCE_HW_IRQ }))
+
+#define is_ready_int_authentic(int_status) ((!(int_status & TRANS_LOS_INT)) || (!(int_status & PHY_ILLG_INT)))
+
+enum xpon_phy_mode {
+	PHY_EPON_CONFIG,
+	PHY_GPON_CONFIG,
+	PHY_XGPON_CONFIG,
+	PHY_XGSPON_CONFIG,
+	PHY_XEPON_10G_1G_CONFIG,
+	PHY_XEPON_10G_10G_CONFIG,
+	PHY_XEPON_1G_1G_CONFIG,
+	PHY_NGPON2_10G_10G_CONFIG,
+	PHY_NGPON2_10G_2G_CONFIG,
+	PHY_NGPON2_2G_2G_CONFIG,
+	PHY_GPON_SYM_CONFIG,
+
+	PHY_UNKNOWN_CONFIG,
+};
+
+enum pon_los_status {
+	PHY_LINK_STATUS_LOS,
+	PHY_LINK_STATUS_READY,
+	PHY_LINK_STATUS_UNKNOWN,
+};
+
+enum PHY_Event_Source_t {
+	PON_PHY_EVENT_SOURCE_HW_IRQ, /* event comes from hard irq*/
+	PON_PHY_EVENT_SOURCE_SW_POLL, /* event comes from sw irq polling */
+};
+
+enum PHY_Event_Type_t {
+	/*
+        phy interrupt event
+    */
+	PHY_EVENT_TRANS_LOS_INT = 0x00,
+	PHY_EVENT_PHY_LOF_INT,
+	PHY_EVENT_TF_INT,
+	PHY_EVENT_TRANS_INT,
+	PHY_EVENT_TRANS_SD_FAIL_INT,
+	PHY_EVENT_PHYRDY_INT,
+	PHY_EVENT_PHY_ILLG_INT,
+	PHY_EVENT_I2CM_INT,
+	PHY_EVENT_TRANS_LOS_ILLG_INT, /* LOS and Illegal INT happen simultaneously */
+
+	/* all phy interrupt event id should be less than this  */
+	PHY_EVENT_MAX_INT = 0x100,
+
+	/*
+        phy non-interrupt event
+    */
+	PHY_EVENT_START_ROGUE_MODE,
+	PHY_EVENT_STOP_ROGUE_MODE,
+
+	PHY_EVENT_CALIBRATION_START,
+	PHY_EVENT_CALIBRATION_STOP,
+	PHY_EVENT_TX_POWER_ON,
+	PHY_EVENT_TX_POWER_OFF,
+	PHY_EVENT_NO_LOS_NO_READY,
+
+};
+
+struct mtk_pon;
+
+/**
+ * struct mtk_pon_data - Mediatek PON platform data
+ *
+ * @init: Function pointer to initialize PON PHY
+ */
+struct mtk_pon_data {
+	int (*init)(struct platform_device *pdev, struct mtk_pon *pon);
+};
+
+/**
+ * struct mtk_pon - Mediatek PON device structure
+ *
+ * @dev: Pointer to the device structure
+ * @pon_data: Pointer to platform-specific PON data
+ * @priv: Pointer to private data
+ * @i2c_dev: Pointer to the I2C client for PON PHY communication
+ * @pon_phy_asic_rg_range: I/O memory region for ASIC registers
+ * @pon_phy_fpga_rg_tx_off: I/O memory region for FPGA TX off registers
+ * @pon_phy_asic_rg_range2: I/O memory region for additional ASIC registers
+ * @pon_phy_asic_rg_range3: I/O memory region for additional ASIC registers
+ * @irq: IRQ number for PON PHY interrupts
+ */
+struct mtk_pon {
+	struct device *dev;
+	const struct mtk_pon_data *pon_data;
+	void *priv;
+
+	struct i2c_client *i2c_dev;
+
+	// airoha,scu
+	struct regmap *scu_regmap;
+
+	struct regmap *pon_phy_asic_rg_range;
+	struct regmap *pon_phy_fpga_rg_tx_off;
+	struct regmap *pon_phy_asic_rg_range2;
+	struct regmap *pon_phy_asic_rg_range3;
+
+	uint32_t flash_matrix[100];
+
+	enum pon_los_status pon_status;
+	enum xpon_phy_mode phy_mode;
+
+	/* flag for rogue mode	cmd: echo Phy_Rogue_PRBS 1/0 > /proc/pon_phy/debug */
+	u8 phy_rogue;
+
+	uint rogue_onu_det_en;
+	uint tx_power_setting;
+	uint phy_txPowerEnFlag;
+
+	int BG1V76;
+	int BG0V875;
+
+	int ic_temperature; // decidegrees (0.1 C)
+	int bosa_temperature; // decidegrees (0.1 C)
+	int env_temperature; // decidegrees (0.1 C)
+	int apd_voltage; // mV
+	int adc_slope; // uV/code
+	int adc_offset; // uV
+	int efuse_temperature_offset; // decidegrees
+
+	int version;
+	int internal_ddmi;
+	int fast_ddmi;
+	int xpon_mode;
+	int select;
+	int rssi_vref;
+	int rssi_v;
+	int patternenabled;
+	int ddmi_rx_cal_flag;
+	int erc;
+	int scl;
+	int dol;
+	int kt;
+	int pav_loop;
+	int ver;
+	int sys_mode;
+	int cross;
+	int cross_cnt_imod;
+	int cross_cnt_ibias;
+
+	int global_temperature_code;
+	int global_vcc_code;
+
+	unsigned int delay1;
+	unsigned int delay2;
+
+	uint32_t temperature_adc;
+	uint32_t voltage_adc;
+	uint32_t rssi_current;
+	uint32_t pwradc;
+	uint32_t pwradc_offset;
+	uint32_t tapd;
+	uint32_t alarm;
+
+	int irq;
+};
+
+struct PON_PHY_Event_data_t {
+	enum PHY_Event_Source_t src;
+	enum PHY_Event_Type_t id;
+};
+
+struct PHY_TransConfig_T
+{
+	unchar	trans_tx_sd_inv_status;
+	unchar	trans_burst_en_inv_status;
+	unchar	trans_tx_fault_inv_status;
+};
+
+// I_bias & I_mod look-up-table (declaration only)
+extern uint lut_ibias_imod[64][2];
+
+enum ENUM_PhyCounterCtrl {
+	PHY_ERR_CNT_CLR = 0x01,
+	PHY_BIP_CNT_CLR = 0x02,
+	PHY_RXFRAME_CNT_CLR = 0x04,
+	PHY_TXFRAME_CNT_CLR = 0x08,
+	PHY_EPON_ERR_CNT_CLR = 0x10
+};
+
+// Function prototypes
+uint32_t GET_SCU_RST_RG(struct mtk_pon *pon);
+void SET_SCU_RST_RG(struct mtk_pon *pon, uint32_t val);
