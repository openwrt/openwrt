+#include <../xpon.h>
+
+struct xpon_device *dev;
+static const struct net_device_ops opts = {};
+
+static int __init pon_init(void)
+{
+	int ret;
+	dev = alloc_pon_netdev();
+	dev->netdev->netdev_ops = &opts;
+
+	ret = register_xpon(dev);
+	return ret;
+}
+
+static void __exit pon_exit(void)
+{
+	unregister_xpon(dev);
+	free_netdev(dev->netdev);
+	kfree(dev);
+}
