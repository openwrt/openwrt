+/**
+ * GET_IS_FPGA - Check if the current platform is FPGA or ASIC
+ *
+ * Is FPGA == 0
+ * Is ASIC == 1
+ */
+bool GET_IS_FPGA(struct mtk_pon *pon)
+{
+	uint32_t val = 0;
+	regmap_read(pon->scu_regmap, 0x9c, &val);
+	return (val & 0x1) == 0;
+}
+
+int get_flash_register(struct mtk_pon *pon, int address_offset)
+{
+	uint return_int = 0;
+	return_int = pon->flash_matrix[(address_offset >> 2)];
+	return return_int;
+}
+
+void set_flash_register(struct mtk_pon *pon, uint reg, uint offset)
+{
+	pon->flash_matrix[offset >> 2] = reg;
+}
+
+void phy_ben_switch(struct mtk_pon *pon, bool ben_switch)
+{
+	uint read_data = 0, write_data = 0;
+
+	if (ben_switch == 0) {
+		dev_info(pon->dev, "7523 TX OFF BEN Normal \n");
+		get_pon_phy_data(pon, 0x1faf4244, &read_data);
+		write_data = (read_data & 0x0FFFFFFF) | 0x10000000;
+		set_pon_phy_data(pon, 0x1faf4244, write_data);
+
+		write_data = read_data & 0x0FFFFFFF;
+		set_pon_phy_data(pon, 0x1faf4244, write_data);
+	} else if (ben_switch == 1) {
+		dev_info(pon->dev, "7523 TX ON BEN ON\n");
+		get_pon_phy_data(pon, 0x1faf4244, &read_data);
+		write_data = read_data | 0x30000000;
+		set_pon_phy_data(pon, 0x1faf4244, write_data);
+	}
+}
+
+void phy_tx_test_pattern(struct mtk_pon *pon, uint pattern)
+{
+	uint read_data = 0, write_data = 0;
+	switch (pattern) {
+	case 0x00:
+		set_pon_phy_data(pon, 0xbfaf04A4, 0);
+		set_pon_phy_data(pon, 0xbfaf04A0, pattern);
+		break;
+	case 0x01:
+	case 0x02:
+	case 0x03:
+	case 0x04:
+
+	case 0x0a:
+	case 0x09:
+
+		set_pon_phy_data(pon, 0xbfaf04A4, 0);
+		set_pon_phy_data(pon, 0xbfaf04A0, pattern);
+		break;
+	case 0x05:
+	case 0x06:
+	case 0x07:
+		set_pon_phy_data(pon, 0xbfaf04A0, pattern);
+		set_pon_phy_data(pon, 0xbfaf04A4, 1);
+		break;
+	case 0x0b:
+		set_pon_phy_data(pon, 0xbfaf0520, 2);
+		set_pon_phy_data(pon, 0xbfaf0510, 1);
+		break;
+	case 0x0c:
+		set_pon_phy_data(pon, 0xbfaf04A4, 0);
+		set_pon_phy_data(pon, 0xbfaf04A0, 0);
+		set_pon_phy_data(pon, 0xbfaf0520, 0);
+		set_pon_phy_data(pon, 0xbfaf0510, 0);
+		get_pon_phy_data(pon, 0xbfaf042C, &read_data);
+		read_data &= 0xfffffffd;
+		write_data = (read_data | ~0xfffffffd);
+		set_pon_phy_data(pon, 0xbfaf042C, write_data);
+		set_pon_phy_data(pon, 0xbfaf042C, read_data);
+		break;
+	default:
+		set_pon_phy_data(pon, 0xbfaf04A4, 0);
+		set_pon_phy_data(pon, 0xbfaf04A0, 0);
+		break;
+	}
+}
+
+void sw_reset(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_SW_RESET, ptr, 4);
+	ptr[0] = (ptr[0] & 0xf8) | (0x01);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_SW_RESET, ptr, 4);
+}
+
+void ADC_calibration(struct mtk_pon *pon)
+{
+	unchar ptr[2];
+	uint read_data = 0;
+	uint cnt = 8;
+	uint i = 0;
+	uint temp = 0;
+
+	// Set ADC to BG 1.76V
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 1);
+	read_data = ptr[0];
+	ptr[0] = (ptr[0] & ADC_SELECT_MASK) | ADC_SELECT_BG_1V76;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 1);
+	for (i = 0; i < cnt; i++) {
+		// Latch ADC
+		phy_I2C_read(pon->i2c_dev, 0x70, 2,
+			     (MT7570_PROBE_CONTROL + (0x01)), ptr, 1);
+		ptr[0] = (ptr[0] & ADC_LATCH_MASK) | ADC_LATCH;
+		phy_I2C_write(pon->i2c_dev, 0x70, 2,
+			      (MT7570_PROBE_CONTROL + (0x01)), ptr, 1);
+		// Read 1.76V value
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_ADC_PROBE_STATUS,
+			     ptr, 2);
+		temp += (ptr[0] | (ptr[1] << 8));
+	}
+	// Set ADC to default
+	ptr[0] = read_data;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 1);
+	pon->BG1V76 = ((temp >> 2) + 1) >> 1;
+	//Set temp to 0
+	temp = 0;
+
+	// Set ADC to BG 0.875V
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, (MT7570_SVADC_PD + 0x01), ptr, 1);
+	read_data = ptr[0];
+	ptr[0] = (ptr[0] & (ADC_BG_0V875_MASK)) | (ADC_SELECT_BG_0V875);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (MT7570_SVADC_PD + 0x01), ptr, 1);
+	for (i = 0; i < cnt; i++) {
+		// Latch ADC
+		phy_I2C_read(pon->i2c_dev, 0x70, 2,
+			     (MT7570_PROBE_CONTROL + (0x01)), ptr, 1);
+		ptr[0] = (ptr[0] & (ADC_LATCH_MASK)) | (ADC_LATCH);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2,
+			      (MT7570_PROBE_CONTROL + (0x01)), ptr, 1);
+		// Read 0.875V value
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_ADC_PROBE_STATUS,
+			     ptr, 2);
+		temp += (ptr[0] | (ptr[1] << 8));
+	}
+	//Set ADC to default
+	ptr[0] = read_data;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, (MT7570_SVADC_PD + 0x01), ptr, 1);
+
+	pon->BG0V875 = ((temp >> 2) + 1) >> 1;
+	//Set temp to 0
+	temp = 0;
+
+	dev_info(pon->dev, "BG 1V76 = 0x%x, BG 0V875 =0x%x\n", pon->BG1V76,
+		 pon->BG0V875);
+
+	if ((pon->BG1V76 - pon->BG0V875) <= 0) // Error
+	{
+		dev_info(pon->dev, "ADC calibration fail\n");
+		return;
+	}
+
+	/* 1.76V = 1760000uV, 0.875V = 875000uV */
+	/* Use integer arithmetic: uV / code */
+	if ((pon->BG1V76 - pon->BG0V875) != 0)
+		pon->adc_slope =
+			(1760000 - 875000) / (pon->BG1V76 - pon->BG0V875);
+	else
+		pon->adc_slope = 0;
+
+	pon->adc_offset = 1760000 - pon->adc_slope * pon->BG1V76;
+}
+
+void APD_initialization(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_APD_DAC_CODE, ptr, 4);
+	ptr[2] = ptr[2] | (APD_SOFTSTART_ENABLE);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_APD_DAC_CODE, ptr, 4);
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_APD_DAC_CODE, ptr, 4);
+	ptr[1] = ptr[1] | (APD_CONTROL_ENABLE);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_APD_DAC_CODE, ptr, 4);
+	dev_info(pon->dev, "APD initialization done\n");
+}
+
+void APD_I2C_write(struct mtk_pon *pon, unchar ptr[1])
+{
+	dev_info(pon->dev, "APD in APD_I2C_write = 0x%x\n", ptr[0]);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_APD_DAC_CODE, ptr, 1);
+}
+
+void APD_control(struct mtk_pon *pon)
+{
+	if (get_flash_register(pon, 0x030) > 0x0000ffff &&
+	    get_flash_register(pon, 0x034) > 0x0000ffff) {
+		// A brand new structure by HC 20151020
+		unchar ptr[1];
+		int a = 0;
+		int b = 0;
+
+		// Units:
+		// Voltage: mV (e.g. 35000 = 35V)
+		// Slope: mV/decidegree (0.1V/C = 100mV/C = 10mV/0.1C)
+		// Temperature: decidegrees (25C = 250)
+
+		int APD_slope_up = 10; // 0.10 V/C = 10 mV/decidegree
+		int APD_slope_dn = 7; // 0.07 V/C = 7 mV/decidegree
+		int APD_voltage_NT = 35000; // 35.0 V
+		int APD_voltage_step = DEFAULT_APD_VOLTAGE_STEP; // mV
+		int APD_voltage_0x00 = DEFAULT_APD_ZERO_CODE_VOLTAGE; // mV
+		int APD_voltage_0x40 = 36000; // 36.0 V
+		int APD_voltage_0x80 = 42000; // 42.0 V
+		int APD_voltage_0xC0 = 45600; // 45.6 V
+
+		//Load slope and voltage from FLASH
+		// Assume flash values are scaled such that /100 gives intended double value
+		// Here we want mV. If flash was V*100 (e.g. 10 for 0.1), then for mV we *10.
+		if (get_flash_register(pon, FLASH_APD_SLOPE1) != 0xffffffff)
+			APD_slope_up =
+				(get_flash_register(pon, FLASH_APD_SLOPE1) *
+				 10) /
+				100; // = reg/10
+
+		if (get_flash_register(pon, FLASH_APD_SLOPE2) != 0xffffffff)
+			APD_slope_dn =
+				(get_flash_register(pon, FLASH_APD_SLOPE2) *
+				 10) /
+				100;
+
+		if (get_flash_register(pon, FLASH_APD_CHANGE_POINT) !=
+		    0xffffffff)
+			APD_voltage_NT = (get_flash_register(
+						  pon, FLASH_APD_CHANGE_POINT) *
+					  1000) /
+					 100; // reg*10
+
+		if ((get_flash_register(pon, FLASH_APD_VOLTAGE_1) |
+		     get_flash_register(pon, FLASH_APD_VOLTAGE_2)) !=
+		    0xffffffff) //by HC 20150303
+		{
+			// (reg >> 16) / 10 was the double. e.g. 350 -> 35.0. We want 35000.
+			// So ((reg >> 16) * 100)
+			APD_voltage_0x00 =
+				((get_flash_register(pon, FLASH_APD_VOLTAGE_1) &
+				  0xffff0000) >>
+				 16) *
+				100;
+			APD_voltage_0x40 =
+				(get_flash_register(pon, FLASH_APD_VOLTAGE_1) &
+				 0x0000ffff) *
+				100;
+			APD_voltage_0x80 =
+				((get_flash_register(pon, FLASH_APD_VOLTAGE_2) &
+				  0xffff0000) >>
+				 16) *
+				100;
+			APD_voltage_0xC0 =
+				(get_flash_register(pon, FLASH_APD_VOLTAGE_2) &
+				 0x0000ffff) *
+				100;
+
+			if ((APD_voltage_0x40 <= APD_voltage_0x00) ||
+			    (APD_voltage_0x80 <= APD_voltage_0x40) ||
+			    (APD_voltage_0xC0 <= APD_voltage_0x80)) {
+				dev_info(pon->dev, "APD slope error\n");
+				return;
+			}
+		}
+
+		//Equation for Vapd calculation
+		// bosa_temperature is in decidegrees. 25C = 250.
+		if (pon->bosa_temperature > 250)
+			pon->apd_voltage =
+				APD_voltage_NT +
+				APD_slope_up * (pon->bosa_temperature - 250);
+		else
+			pon->apd_voltage =
+				APD_voltage_NT -
+				APD_slope_dn * (250 - pon->bosa_temperature);
+
+		//Print pon->bosa_temperature (decidegrees)
+		a = pon->bosa_temperature / 10;
+		b = abs(pon->bosa_temperature % 10);
+		dev_info(pon->dev, "BOSA temperature = %d.%dC\n", a, b);
+
+		//Print APD_voltage (mV)
+		a = pon->apd_voltage / 1000;
+		b = (pon->apd_voltage % 1000) / 100; // 1st decimal
+		dev_info(pon->dev, "APD Voltage = %d.%dV\n", a, b);
+
+		if (pon->apd_voltage < APD_voltage_0x80) {
+			if (pon->apd_voltage <
+			    APD_voltage_0x40) // V00 <= VAPD < V40
+			{
+				APD_voltage_step =
+					(APD_voltage_0x40 - APD_voltage_0x00) /
+					64;
+				if (APD_voltage_step == 0)
+					APD_voltage_step = 1;
+				ptr[0] = 0x00 +
+					 (pon->apd_voltage - APD_voltage_0x00) /
+						 APD_voltage_step;
+				dev_info(pon->dev, "APD slope 1\n");
+			} else // V40 <= VAPD < V80
+			{
+				APD_voltage_step =
+					(APD_voltage_0x80 - APD_voltage_0x40) /
+					64;
+				if (APD_voltage_step == 0)
+					APD_voltage_step = 1;
+				ptr[0] = 0x40 +
+					 (pon->apd_voltage - APD_voltage_0x40) /
+						 APD_voltage_step;
+				dev_info(pon->dev, "APD slope 2\n");
+			}
+
+		} else {
+			APD_voltage_step =
+				(APD_voltage_0xC0 - APD_voltage_0x80) / 64;
+			if (APD_voltage_step == 0)
+				APD_voltage_step = 1;
+			dev_info(pon->dev, "APD slope 3\n");
+
+			if (pon->apd_voltage <
+			    APD_voltage_0xC0) // V80 <= VAPD < VC0
+				ptr[0] = 0x80 +
+					 (pon->apd_voltage - APD_voltage_0x80) /
+						 APD_voltage_step;
+			else // VC0 <= VAPD <= VFF
+			{
+				ptr[0] = 0xC0 +
+					 (pon->apd_voltage - APD_voltage_0xC0) /
+						 APD_voltage_step;
+				if (ptr[0] > 0xff)
+					ptr[0] = 0xff;
+			}
+		}
+
+		dev_info(pon->dev, "APD = 0x%x\n", ptr[0]);
+		APD_I2C_write(pon, ptr);
+	} else {
+		unchar ptr[1];
+		int a = 0;
+		int b = 0;
+
+		int APD_slope_up = 10; // mV/decideg
+		int APD_slope_dn = 7; // mV/decideg
+		int APD_voltage_NT = 35000; // mV
+		int APD_zero_code_voltage = DEFAULT_APD_ZERO_CODE_VOLTAGE; // mV
+		int APD_voltage_step = DEFAULT_APD_VOLTAGE_STEP; // mV
+
+		//Load slope and voltage from FLASH
+		if (get_flash_register(pon, FLASH_APD_SLOPE1) != 0xffffffff)
+			APD_slope_up =
+				(get_flash_register(pon, FLASH_APD_SLOPE1) *
+				 10) /
+				100;
+
+		if (get_flash_register(pon, FLASH_APD_SLOPE2) != 0xffffffff)
+			APD_slope_dn =
+				(get_flash_register(pon, FLASH_APD_SLOPE2) *
+				 10) /
+				100;
+
+		if (get_flash_register(pon, FLASH_APD_CHANGE_POINT) !=
+		    0xffffffff)
+			APD_voltage_NT = (get_flash_register(
+						  pon, FLASH_APD_CHANGE_POINT) *
+					  1000) /
+					 100;
+
+		if (get_flash_register(pon, FLASH_APD_ZERO_CODE_VOLTAGE) !=
+		    0xffffffff) //by HC 20150303
+			APD_zero_code_voltage =
+				(get_flash_register(
+					 pon, FLASH_APD_ZERO_CODE_VOLTAGE) *
+				 1000) /
+				100;
+
+		if (get_flash_register(pon, FLASH_APD_VOLTAGE_STEP) !=
+		    0xffffffff) //by HC 20150303
+			APD_voltage_step =
+				(get_flash_register(pon,
+						    FLASH_APD_VOLTAGE_STEP) *
+				 1000) /
+				1000; // scaling check?
+
+		//Equation for Vapd calculation
+		if (pon->bosa_temperature > 250)
+			pon->apd_voltage =
+				APD_voltage_NT +
+				APD_slope_up * (pon->bosa_temperature - 250);
+		else
+			pon->apd_voltage =
+				APD_voltage_NT -
+				APD_slope_dn * (250 - pon->bosa_temperature);
+
+		//Print pon->bosa_temperature
+		a = pon->bosa_temperature / 10;
+		b = abs(pon->bosa_temperature % 10);
+		dev_info(pon->dev, "BOSA temperature = %d.%dC\n", a, b);
+		//Print APD_voltage
+		a = pon->apd_voltage / 1000;
+		b = (pon->apd_voltage % 1000) / 100;
+		dev_info(pon->dev, "APD Voltage = %d.%dV\n", a, b);
+
+		if (APD_voltage_step == 0)
+			APD_voltage_step = 1;
+		ptr[0] = (pon->apd_voltage - APD_zero_code_voltage) /
+			 APD_voltage_step;
+		dev_info(pon->dev, "APD = 0x%x\n", ptr[0]);
+		APD_I2C_write(pon, ptr);
+	}
+}
+
+void CDR(struct mtk_pon *pon, int CDR_switch)
+{
+	uint read_data = 0;
+	if (CDR_switch == 0) {
+		get_pon_phy_data(pon, 0x1faf4620, &read_data);
+		set_pon_phy_data(pon, 0x1faf4620,
+				 (read_data | PHY_TX_LOCK_2_REF));
+
+		get_pon_phy_data(pon, 0x1faf4614, &read_data);
+		set_pon_phy_data(pon, 0x1faf4614, (read_data | 0x4000000));
+
+		dev_info(pon->dev, "CDR disabled\n");
+	} else if (CDR_switch == 1) {
+		get_pon_phy_data(pon, 0x1faf4614, &read_data);
+		set_pon_phy_data(pon, 0x1faf4614,
+				 (read_data &
+				  0xFBFFFFFF)); // PHY_TX_LOCK_2_DATA inverse?
+
+		dev_info(pon->dev, "CDR enabled\n");
+	}
+}
+
+void TGEN(struct mtk_pon *pon, int xPON)
+{
+	unchar ptr[4];
+	uint RGS_T0C = 0;
+	uint RGS_T1C = 0;
+	int i = 0;
+
+	//Disable CDR
+	CDR(pon, 0);
+
+	phy_ben_switch(pon, 1);
+
+	//752X sends PRBS23
+	phy_tx_test_pattern(pon, PHY_BIST_PRBS23);
+
+	mdelay(10);
+
+	for (i = 0; i < 32; i++) // Get MAX T0C/T1C
+	{
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+		ptr[3] = (ptr[3] & ERC_ENABLE_MASK);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+		udelay(2);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+		ptr[0] = (ptr[0] & T1_T0_DELAY_MASK) | (T1_T0_DELAY_SETTING1);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+		udelay(2);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+		ptr[1] = (ptr[1] & T1_TIMER_RESET_MASK) |
+			 (T1_TIMER_RESET_VALUE);
+		ptr[2] = (ptr[2] & T0_TIMER_RESET_MASK) |
+			 (T0_TIMER_RESET_VALUE);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+		udelay(2);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+		ptr[3] = (ptr[3] & TGEN_RESET_VALUE_MASK) |
+			 (TGEN_RESET_VALUE_T1T0_TIMER);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+		udelay(2);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+		ptr[3] = (ptr[3] & TGEN_RESET_VALUE_MASK);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+		udelay(2);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+		ptr[3] = (ptr[3] & TGEN_METHOD2_MASK) | (TGEN_METHOD2_ENABLE);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+		udelay(2);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+		ptr[3] = (ptr[3] & TGEN_METHOD2_MASK);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T0C, ptr, 4);
+		if (ptr[0] > RGS_T0C)
+			RGS_T0C = ptr[0];
+		if (ptr[1] > RGS_T1C)
+			RGS_T1C = ptr[1];
+	}
+
+	mdelay(10);
+
+	// Set T0T1delay
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr,
+		     4); // by HC 20151015
+	if (get_flash_register(pon, FLASH_T0T1DELAY) != 0xffffffff) {
+		ptr[0] = (ptr[0] & T1_T0_DELAY_MASK) |
+			 (get_flash_register(pon, FLASH_T0T1DELAY) & 0xff);
+		dev_info(pon->dev, "T0/T1 delay = 0x%02x\n",
+			 get_flash_register(pon, FLASH_T0T1DELAY) & 0xff);
+	} else if (xPON == PHY_GPON_CONFIG) {
+		ptr[0] = (ptr[0] & T1_T0_DELAY_MASK) |
+			 0x9a; // 0x9a by HC 20150814
+		dev_info(pon->dev, "T0/T1 delay = 0x9a\n");
+	} else if (xPON == PHY_EPON_CONFIG) {
+		ptr[0] = (ptr[0] & T1_T0_DELAY_MASK) |
+			 0x47; // 0x47 by CH 20150623
+		dev_info(pon->dev, "T0/T1 delay = 0x47\n");
+	}
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+	mdelay(10);
+
+	// Set RGS_T0C/T1C by HC 20150623
+	if (get_flash_register(pon, FLASH_T0CT1C) !=
+	    0xffffffff) // Get fixed T0C/T1C
+	{
+		RGS_T0C = get_flash_register(pon, FLASH_T0CT1C) & 0x0000ffff;
+		RGS_T1C =
+			(get_flash_register(pon, FLASH_T0CT1C) & 0xffff0000) >>
+			16;
+	}
+	dev_info(pon->dev, "RGS_T0C = 0x%x\nRGS_T1C = 0x%x\n", RGS_T0C,
+		 RGS_T1C);
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+	ptr[1] = (ptr[1] & T1_TIMER_RESET_MASK) | RGS_T1C;
+	ptr[2] = (ptr[2] & T0_TIMER_RESET_MASK) | RGS_T0C;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+	mdelay(10);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+	ptr[3] = (ptr[3] & TGEN_RESET_VALUE_MASK) |
+		 (TGEN_RESET_VALUE_T1T0_TIMER);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+	mdelay(10);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+	ptr[3] = (ptr[3] & TGEN_RESET_VALUE_MASK);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+	mdelay(10);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+	ptr[3] = (ptr[3] & ERC_ENABLE_MASK) | (ERC_ENABLE);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_T1DELAY, ptr, 4);
+
+	//Enable CDR
+	CDR(pon, 1);
+
+	phy_ben_switch(pon, 0);
+
+	//752X back to normal mode
+	phy_tx_test_pattern(pon, PHY_BIST_IDLE);
+
+	dev_info(pon->dev, "TGEN done\n");
+}
+
+int phy_fw_ready(struct mtk_pon *pon, unchar fwrdy_en)
+{
+	uint read_data = 0, write_data = 0;
+
+	get_pon_phy_data(pon, 0xbfaf0104, &read_data);
+	if (fwrdy_en == 1)
+		write_data = (read_data & (0xfffffffe)) | 1;
+	else if (fwrdy_en == 0)
+		write_data = read_data & (0xfffffffe);
+	else
+		return 1;
+	dev_info(pon->dev, "Phy_Fw_Ready function success. \n");
+
+	set_pon_phy_data(pon, 0xbfaf0104, write_data);
+	return 0;
+}
+
+int phy_mode_config(struct mtk_pon *pon, enum xpon_phy_mode xpon_mode,
+		    int tx_enable)
+{
+	uint write_data = 0, read_data = 0, flag_7523_asic = 0;
+
+	if (PHY_GPON_CONFIG != xpon_mode && PHY_EPON_CONFIG != xpon_mode &&
+	    0xa7050701 != xpon_mode) {
+		dev_info(pon->dev, "can not recognize phy mode %d\n",
+			 xpon_mode);
+		return 1;
+	}
+
+	if (1 != tx_enable && 0 != tx_enable) {
+		dev_info(pon->dev, "can not recognize tx_enable %d\n",
+			 tx_enable);
+		return 1;
+	}
+
+	if (!GET_IS_FPGA(pon)) {
+		flag_7523_asic = 1;
+	}
+
+	phy_fw_ready(pon, 0);
+	// gpPhyPriv->phy_status = PHY_LINK_STATUS_UNKNOWN;
+
+	// { gpPhyPriv->event_poll_timer.expires = gpPhyPriv->event_poll_timer_value;mod_timer(&gpPhyPriv->event_poll_timer, (jiffies + ((gpPhyPriv->event_poll_timer.expires*100)/1000))) ; };
+
+	if (xpon_mode == 0xa7050701) {
+		if (GET_IS_FPGA(pon)) {
+			dev_info(pon->dev, "SET PHY_CSR_XPON_SETTING 10f\n");
+			set_pon_phy_data(pon, (0xbfaf0100 + 0x0038), 0x10f);
+		}
+		// phy_trans_power_switch(0);
+
+		if (flag_7523_asic == 1) {
+			config_mode_7523(pon, PHY_UNKNOWN_CONFIG);
+		} else {
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data & 0xffffffdf;
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+
+			// spin_lock_irqsave(&gpPhyPriv->pllReset_lock, flag);
+
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data | ((1 << 31)) | ((1 << 27));
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+			mdelay(1);
+
+			get_pon_phy_data(pon, (0xbfaf0100 + 0x0024),
+					 &read_data);
+			write_data = (read_data | (1 << 31));
+			set_pon_phy_data(pon, (0xbfaf0100 + 0x0024),
+					 write_data);
+			mdelay(1);
+
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data & (0x77ffffff);
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+			mdelay(1);
+			// spin_unlock_irqrestore(&gpPhyPriv->pllReset_lock, flag);
+		}
+	} else if (xpon_mode == PHY_GPON_CONFIG) {
+		if (GET_IS_FPGA(pon)) {
+			dev_info(pon->dev, "SET PHY_CSR_XPON_SETTING 10f\n");
+			set_pon_phy_data(pon, (0xbfaf0100 + 0x0038), 0x10f);
+		}
+
+		// phy_trans_power_switch(0);
+		if (flag_7523_asic == 1) {
+			config_mode_7523(pon, xpon_mode);
+		} else {
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data & 0xffffffdf;
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+
+			// spin_lock_irqsave(&gpPhyPriv->pllReset_lock, flag);
+
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data | ((1 << 31)) | ((1 << 27));
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+			mdelay(1);
+
+			get_pon_phy_data(pon, (0xbfaf0100 + 0x0024),
+					 &read_data);
+			write_data = (read_data | (1 << 31));
+			set_pon_phy_data(pon, (0xbfaf0100 + 0x0024),
+					 write_data);
+			mdelay(1);
+
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data & (0x77ffffff);
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+			mdelay(1);
+			// spin_unlock_irqrestore(&gpPhyPriv->pllReset_lock, flag);
+		}
+	} else if (xpon_mode == PHY_EPON_CONFIG) {
+		if (GET_IS_FPGA(pon)) {
+			dev_info(pon->dev, "SET PHY_CSR_XPON_SETTING 10f\n");
+			set_pon_phy_data(pon, (0xbfaf0100 + 0x0038), 0x10f);
+		}
+
+		if (flag_7523_asic == 1)
+			config_mode_7523(pon, xpon_mode);
+		else {
+			// phy_trans_power_switch(0);
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data & 0xffffffdf;
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+
+			// spin_lock_irqsave(&gpPhyPriv->pllReset_lock, flag);
+
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data | ((1 << 31)) | ((1 << 27));
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+			mdelay(1);
+
+			get_pon_phy_data(pon, (0xbfaf0100 + 0x0024),
+					 &read_data);
+			write_data = (read_data & ~(1 << 31));
+			set_pon_phy_data(pon, (0xbfaf0100 + 0x0024),
+					 write_data);
+			mdelay(1);
+
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data & (0x77ffffff);
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+			mdelay(1);
+			// spin_unlock_irqrestore(&gpPhyPriv->pllReset_lock, flag);
+
+			get_pon_phy_data(pon, 0xbfaf0108, &read_data);
+			write_data = read_data | ~(0xffffffdf);
+			set_pon_phy_data(pon, 0xbfaf0108, write_data);
+		}
+	}
+
+	if (1 == tx_enable) {
+		// phy_trans_power_switch(1);
+	}
+	phy_fw_ready(pon, 1);
+	return 0;
+}
