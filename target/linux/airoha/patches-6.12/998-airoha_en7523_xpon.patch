+void RSSI_gain_init(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	//RSSI gain initialization
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_LA_PWD, ptr, 4);
+	ptr[2] = (ptr[2] & RSSI_GAIN_MASK) | (0x05);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_LA_PWD, ptr, 4);
+}
+
+void LOS_init(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL1, ptr, 4);
+	ptr[0] = (ptr[0] & (LOS_CALIBRATION_MASK)) | (LOS_CALIBRATION_TRIG);
+	// Set rg_ain_stable_cnt
+	ptr[1] = (ptr[1] & (LOS_AIN_STABLE_CNT_MASK)) |
+		 (LOS_AIN_STABLE_CNT_SETTING);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL1, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 4);
+	ptr[3] = (ptr[3] & (LOS_ADCREV2_MASK)) | (LOS_ADCREV2_ENABLE);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 4);
+	ptr[2] = (ptr[2] & (LOS_ADCREV1_MASK)) | (LOS_ADCREV1_ENABLE);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 4);
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL2, ptr, 4);
+	ptr[1] = (ptr[1] & (LOS_CONFIDENCE_MASK)) | (LOS_CONFIDENCE_SETTING);
+	// Set rg_los_sd_cnt
+	ptr[0] = (ptr[0] & (LOS_CNT_MASK)) | (LOS_CNT_SETTING);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL2, ptr, 4);
+}
+
+void LOS_level_set(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	LOS_init(pon);
+	if ((get_flash_register(pon, FLASH_LOS_HIGH_THLD) != 0xffffffff) &&
+	    (get_flash_register(pon, FLASH_LOS_LOW_THLD) != 0xffffffff)) {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL1, ptr, 4);
+		ptr[3] =
+			(ptr[3] & (LOS_COMP_THLD_MASK)) |
+			(get_flash_register(
+				pon,
+				FLASH_LOS_LOW_THLD)); //Fix coding mistake YMC 20150128
+		ptr[2] =
+			(ptr[2] & (LOS_COMP_THLD_MASK)) |
+			(get_flash_register(
+				pon,
+				FLASH_LOS_HIGH_THLD)); //Fix coding mistake YMC 20150128
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL1, ptr, 4);
+	} else {
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL1, ptr, 4);
+		ptr[3] = (ptr[3] & (LOS_COMP_THLD_MASK)) |
+			 (LOS_COMP_THLD_L_SETTING);
+		ptr[2] = (ptr[2] & (LOS_COMP_THLD_MASK)) |
+			 (LOS_COMP_THLD_H_SETTING);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_LOS_CTRL1, ptr, 4);
+	}
+	dev_info(pon->dev, "Rx LOS is set\n");
+}
+
+void RougeONU_clear(struct mtk_pon *pon)
+{
+	unchar ptr[1];
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_ROGUE_ONU_DET_CTRL + 0x01,
+		     ptr, 1);
+	ptr[0] = (ptr[0] & ROGUEONU_MASK) | 0x1;
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_ROGUE_ONU_DET_CTRL + 0x01,
+		      ptr, 1);
+	dev_info(pon->dev, "Rogue ONU clear\n");
+}
