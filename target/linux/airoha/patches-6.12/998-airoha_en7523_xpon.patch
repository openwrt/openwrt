+int get_pon_phy_data(struct mtk_pon *pon, uint32_t reg, uint32_t *reg_offset)
+{
+	uint32_t reg_phy = 0, addr = 0;
+
+	/* translate addr to physical addr */
+	if (reg > 0xa0000000)
+		reg_phy = (reg & 0x1fffffff);
+	else
+		reg_phy = reg;
+
+	//reg_offset = reg_phy % 4;
+	if ((reg_phy % 4) != 0) {
+		dev_err(pon->dev, "(%s)Get reg_offset error, reg=0x%08X\n",
+			__func__, reg);
+		return -EINVAL;
+	}
+
+	if ((reg_maps[0][0] <= reg_phy) && (reg_phy < reg_maps[0][1])) {
+		addr = reg_phy - reg_maps[0][0];
+		return regmap_read(pon->pon_phy_asic_rg_range, addr,
+				   reg_offset);
+	} else if (reg_maps[1][0] == reg_phy) {
+		return regmap_read(pon->pon_phy_fpga_rg_tx_off, 0, reg_offset);
+	} else if ((reg_maps[2][0] <= reg_phy) && (reg_phy < reg_maps[2][1])) {
+		addr = reg_phy - reg_maps[2][0];
+		return regmap_read(pon->pon_phy_asic_rg_range2, addr,
+				   reg_offset);
+	} else if ((reg_maps[3][0] <= reg_phy) && (reg_phy < reg_maps[3][1])) {
+		addr = reg_phy - reg_maps[3][0];
+		return regmap_read(pon->pon_phy_asic_rg_range3, addr,
+				   reg_offset);
+	} else
+		dev_warn(pon->dev, "Datapath(%s) get reg error, reg=0x%08X\n",
+			 __func__, reg);
+
+	return -EINVAL;
+}
+EXPORT_SYMBOL_GPL(get_pon_phy_data);
+
+int set_pon_phy_data(struct mtk_pon *pon, uint32_t reg, uint32_t val)
+{
+	uint32_t reg_phy = 0;
+	uint32_t reg_offset = 0;
+	uint32_t addr;
+
+	/* translate addr to physical addr */
+	if (reg > 0xa0000000)
+		reg_phy = (reg & 0x1fffffff);
+	else
+		reg_phy = reg;
+
+	reg_offset = reg_phy % 4;
+	if (reg_offset != 0) {
+		dev_err(pon->dev, "(%s)Set reg_offset error, reg=0x%08X\n",
+			__func__, reg);
+		return -EINVAL;
+	}
+
+	if ((reg_maps[0][0] <= reg_phy) && (reg_phy < reg_maps[0][1])) {
+		addr = reg_phy - reg_maps[0][0];
+		return regmap_write(pon->pon_phy_asic_rg_range, addr, val);
+	} else if (reg_maps[1][0] == reg_phy) {
+		return regmap_write(pon->pon_phy_fpga_rg_tx_off, 0, val);
+	} else if ((reg_maps[2][0] <= reg_phy) && (reg_phy < reg_maps[2][1])) {
+		addr = reg_phy - reg_maps[2][0];
+		return regmap_write(pon->pon_phy_asic_rg_range2, addr, val);
+	} else if ((reg_maps[3][0] <= reg_phy) && (reg_phy < reg_maps[3][1])) {
+		addr = reg_phy - reg_maps[3][0];
+		return regmap_write(pon->pon_phy_asic_rg_range3, addr, val);
+	} else
+		dev_warn(pon->dev, "Datapath(%s) set reg error, reg=0x%08X\n",
+			 __func__, reg);
+
+	return -EINVAL;
+}
+EXPORT_SYMBOL_GPL(set_pon_phy_data);
