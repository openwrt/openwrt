+}
+
+void LUT_recover(struct mtk_pon *pon)
+{
+	uint Init_Ibias = 0;
+	uint FLASH_Ibias = 0;
+	uint FLASH_Ibias_up = 0;
+	uint FLASH_Imod = 0;
+	uint FLASH_Imod_up = 0;
+	uint Ibias_offset = 0;
+	uint Ibias_recover = 0;
+	uint Imod_recover = 0;
+	uint Ibias_cal = 0;
+
+	int FLASH_index = 0;
+	int index = 0;
+
+	int temperature_cal = 250; // decidegrees (25.0C)
+	int temperature = 0; // decidegrees
+
+	if (pon->dol == 1) // For open loop mode, by HC 20160410
+	{
+		for (index = 0; index < 64; index++) {
+			// temperature = index * 2.5 - 40;
+			// decidegrees: index * 25 - 400
+			temperature = index * 25 - 400;
+
+			// FLASH_index = (int)((temperature + 40) / 10);
+			// decidegrees: (temp + 400) / 100
+			FLASH_index = (temperature + 400) / 100;
+
+			if (FLASH_index < 0) // FLASH_index should be >= 0
+				FLASH_index = 0;
+			else if (FLASH_index >
+				 15) // FLASH_index should be <= 15
+				FLASH_index = 15;
+
+			//Read Ibias initial value
+			FLASH_Ibias = (get_flash_register(
+					       pon, 0xa0 + FLASH_index * 4) &
+				       0x0fff0000) >>
+				      16;
+			FLASH_Ibias_up =
+				(get_flash_register(
+					 pon, 0xa0 + (FLASH_index + 1) * 4) &
+				 0x0fff0000) >>
+				16;
+			FLASH_Imod = (get_flash_register(
+					      pon, 0xa0 + FLASH_index * 4) &
+				      0x00000fff);
+			FLASH_Imod_up =
+				(get_flash_register(
+					 pon, 0xa0 + (FLASH_index + 1) * 4) &
+				 0x00000fff);
+
+			// Recover Ibias
+			if (FLASH_Ibias == 0xfff ||
+			    FLASH_Ibias_up ==
+				    0xfff) // If one of FLASH contents is empty
+			{
+				lut_ibias_imod[index][0] = 0xfff;
+			} else {
+				if (FLASH_index < 4)
+					// Ibias_recover = FLASH_Ibias + ((temperature + 40) - (FLASH_index * 10)) * (FLASH_Ibias_up - FLASH_Ibias) / 10;
+					// Scaled: (temp_dec + 400) - index*100. Diff is decideg. Divide by 100 decideg (10 deg step).
+					Ibias_recover =
+						FLASH_Ibias +
+						((temperature + 400) -
+						 (FLASH_index * 100)) *
+							(FLASH_Ibias_up -
+							 FLASH_Ibias) /
+							100;
+				else
+					// Ibias_recover = FLASH_Ibias + (temperature - ((10 * FLASH_index) - 40)) * (FLASH_Ibias_up - FLASH_Ibias) / 10;
+					// Scaled: temp - (100*index - 400).
+					Ibias_recover =
+						FLASH_Ibias +
+						(temperature -
+						 ((100 * FLASH_index) - 400)) *
+							(FLASH_Ibias_up -
+							 FLASH_Ibias) /
+							100;
+
+				lut_ibias_imod[index][0] = Ibias_recover;
+			}
+
+			// Recover Imod
+			if (FLASH_Imod == 0xfff ||
+			    FLASH_Imod_up ==
+				    0xfff) // If one of FLASH contents is empty
+			{
+				lut_ibias_imod[index][1] = 0xfff;
+			} else {
+				if (FLASH_index < 4)
+					Imod_recover = FLASH_Imod +
+						       ((temperature + 400) -
+							(FLASH_index * 100)) *
+							       (FLASH_Imod_up -
+								FLASH_Imod) /
+							       100;
+				else
+					Imod_recover =
+						FLASH_Imod +
+						(temperature -
+						 ((100 * FLASH_index) - 400)) *
+							(FLASH_Imod_up -
+							 FLASH_Imod) /
+							100;
+
+				lut_ibias_imod[index][1] = Imod_recover;
+			}
+		}
+
+		// -40, -30,...0...90, 100,...
+		for (FLASH_index = 0; FLASH_index <= 15; FLASH_index++) {
+			index = 4 * FLASH_index;
+
+			if (((get_flash_register(pon, 0xa0 + FLASH_index * 4) &
+			      0x0fff0000) >>
+			     16) != 0xfff) {
+				lut_ibias_imod[index][0] =
+					((get_flash_register(
+						  pon, 0xa0 + FLASH_index * 4) &
+					  0x0fff0000) >>
+					 16);
+			}
+
+			if ((get_flash_register(pon, 0xa0 + FLASH_index * 4) &
+			     0x00000fff) != 0xfff) {
+				lut_ibias_imod[index][1] =
+					(get_flash_register(
+						 pon, 0xa0 + FLASH_index * 4) &
+					 0x00000fff);
+			}
+		}
+	} else {
+		if (get_flash_register(pon, FLASH_RESERVED_FOR_ETC1) !=
+		    0xffffffff)
+			temperature_cal =
+				get_flash_register(pon,
+						   FLASH_RESERVED_FOR_ETC1) *
+				10 / 10;
+		// Reg/10 was double C. *10 for decideg -> Reg.
+
+		FLASH_index = (temperature_cal + 400) / 100;
+
+		if (get_flash_register(pon, 0xa0 + FLASH_index * 4) ==
+		    0xffffffff) // If table is empty
+		{
+			dev_info(pon->dev, "Lack of bias-current table\n");
+			return;
+		}
+
+		//Read Ibias initial value
+		FLASH_Ibias = (get_flash_register(pon, 0xa0 + FLASH_index * 4) &
+			       0x0fff0000) >>
+			      16;
+		FLASH_Ibias_up =
+			(get_flash_register(pon, 0xa0 + (FLASH_index + 1) * 4) &
+			 0x0fff0000) >>
+			16;
+		Ibias_cal = FLASH_Ibias +
+			    (temperature_cal - ((100 * FLASH_index) - 400)) *
+				    (FLASH_Ibias_up - FLASH_Ibias) / 100;
+		// Read calibrated bias current
+		Init_Ibias = get_flash_register(pon, FLASH_IBIAS_INIT);
+		// Calculate bias offset
+		Ibias_offset = Init_Ibias - Ibias_cal;
+		dev_info(pon->dev, "Bias offset = 0x%x\n", Ibias_offset);
+
+		for (index = 0; index < 64; index++) {
+			temperature = index * 25 - 400;
+			FLASH_index = (temperature + 400) / 100;
+
+			if (FLASH_index < 0) // FLASH_index should be >= 0
+				FLASH_index = 0;
+			else if (FLASH_index >
+				 15) // FLASH_index should be <= 15
+				FLASH_index = 15;
+
+			//Read Ibias initial value
+			FLASH_Ibias = (get_flash_register(
+					       pon, 0xa0 + FLASH_index * 4) &
+				       0x0fff0000) >>
+				      16;
+			FLASH_Ibias_up =
+				(get_flash_register(
+					 pon, 0xa0 + (FLASH_index + 1) * 4) &
+				 0x0fff0000) >>
+				16;
+
+			if (FLASH_Ibias == 0xfff ||
+			    FLASH_Ibias_up ==
+				    0xfff) // If one of FLASH contents is empty
+			{
+				lut_ibias_imod[index][0] = 0xfff;
+			} else {
+				if (FLASH_index < 4)
+					Ibias_recover =
+						FLASH_Ibias +
+						((temperature + 400) -
+						 (FLASH_index * 100)) *
+							(FLASH_Ibias_up -
+							 FLASH_Ibias) /
+							100;
+				else
+					Ibias_recover =
+						FLASH_Ibias +
+						(temperature -
+						 ((100 * FLASH_index) - 400)) *
+							(FLASH_Ibias_up -
+							 FLASH_Ibias) /
+							100;
+
+				lut_ibias_imod[index][0] =
+					Ibias_recover + Ibias_offset;
+			}
+
+			if (lut_ibias_imod[index][0] <=
+			    0x0) // Check if bias <= 0 mA
+			{
+				dev_info(pon->dev, "LUT recover failed\n");
+				return;
+			}
+		}
+
+		// -40, -30,...0...90, 100,...
+		for (FLASH_index = 0; FLASH_index <= 15; FLASH_index++) {
+			index = 4 * FLASH_index;
+			if (((get_flash_register(pon, 0xa0 + FLASH_index * 4) &
+			      0x0fff0000) >>
+			     16) != 0xfff) {
+				lut_ibias_imod[index][0] =
+					((get_flash_register(
+						  pon, 0xa0 + FLASH_index * 4) &
+					  0x0fff0000) >>
+					 16) +
+					Ibias_offset;
+			}
+		}
+	}
+}
+
+int ADC_temperature_get(struct mtk_pon *pon)
+{
+	unchar ptr[4];
+	uint cnt = 8;
+	uint i = 0;
+	uint temp = 0;
+
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 1);
+	ptr[0] = (ptr[0] & (ADC_SELECT_MASK)) | (ADC_SELECT_TEMPERATURE);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 1);
+	for (i = 0; i < cnt; i++) {
+		//latch ADC value
+		phy_I2C_read(pon->i2c_dev, 0x70, 2,
+			     (MT7570_PROBE_CONTROL + (0x01)), ptr, 1);
+		ptr[0] = (ptr[0] & (ADC_LATCH_MASK)) | (ADC_LATCH);
+		phy_I2C_write(pon->i2c_dev, 0x70, 2,
+			      (MT7570_PROBE_CONTROL + (0x01)), ptr, 1);
+
+		// Get temperature
+		phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_ADC_PROBE_STATUS,
+			     ptr, 2);
+		temp += (ptr[0] | (ptr[1] << 8));
+	}
+
+	//set to default ADCAUX
+	phy_I2C_read(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 1);
+	ptr[0] = ptr[0] & (ADC_SELECT_MASK);
+	phy_I2C_write(pon->i2c_dev, 0x70, 2, MT7570_SVADC_PD, ptr, 1);
+
+	pon->global_temperature_code = ((temp >> 2) + 1) >> 1;
+	//Set temp to 0
+	temp = 0;
+
+	return pon->global_temperature_code;
+}
+
+void temperature_get(struct mtk_pon *pon)
+{
+	uint read_data = 0;
+	int BOSA_temperature_offset =
+		DEFAULT_BOSA_TEMPERATURE_OFFSET; // decideg
+	int Env_temperature_offset = 100; // 10.0C -> 100 decideg
+	int T_V_slope = TEMPERATURE_ADC_SLOP; // units? code says reg/10.
+	int T_V_offset = TEMPERATURE_OFFSET;
+	int sensor_voltage_uv;
+
+	if ((get_flash_register(pon, FLASH_TEMPERATURE_K_SLOPE_OFFSET) &
+	     FLASH_TEMPERATURE_SLOPE_MASK) !=
+	    0xffff0000) //Load temperature slope
+	{
+		read_data = get_flash_register(
+			pon, FLASH_TEMPERATURE_K_SLOPE_OFFSET);
+		T_V_slope = (read_data & FLASH_TEMPERATURE_SLOPE_MASK) >>
+			    FLASH_TEMPERATURE_SLOPE_OFFSET;
+		// Code was slope / 10. We keep as is and scale calcs.
+	}
+
+	if ((get_flash_register(pon, FLASH_TEMPERATURE_K_SLOPE_OFFSET) &
+	     FLASH_TEMPERATURE_OFFSET_MASK) != 0xffff) //Load temperature offset
+	{
+		read_data = get_flash_register(
+			pon, FLASH_TEMPERATURE_K_SLOPE_OFFSET);
+		T_V_offset = (read_data & FLASH_TEMPERATURE_OFFSET_MASK);
+		// Code was offset / 10. We keep as is and scale calcs.
+	}
+
+	ADC_temperature_get(pon);
+
+	// pon->adc_slope is uV/code.
+	// sensor_voltage (uV)
+	sensor_voltage_uv =
+		pon->adc_slope * pon->global_temperature_code + pon->adc_offset;
+
+	/* IC_temperature = temperature_offset - ( temperature_slop * sensor_voltage ) */
+	/* double: off/10 - (slope/10 * v) */
+	/* decideg: (off - slope * v) */
+	/* But slope/10 was used with Volts? or uV?
+	   If standard temp sensors, slope is approx -1.6mV/C.
+	   Here calculation is T = Off - Slope*V.
+	   Given T_V_slope comes from a register divided by 10.
+	   Let's assume the formula `(off - slope * sensor_voltage / 1000) / 10`
+	   to approximate the original `off/10 - slope/10 * v`.
+	   We will use `div_s64` safe math if needed, but for now simple scaling.
+	*/
+
+	// Assuming T_V_offset is x10 degrees (decidegrees * 10? no, code was /10).
+	// If reg=250 -> 25.0. So reg is decidegrees.
+	// ic_temp (decideg) = T_V_offset - (T_V_slope * sensor_voltage_uv) / 100000;
+	// (Scaling factor guess based on slope/10 and uV).
+
+	pon->ic_temperature =
+		T_V_offset - T_V_slope * sensor_voltage_uv / 100000;
+
+	read_data = get_flash_register(pon, FLASH_TEMERATURE_OFFSET);
+	if ((read_data & 0x0000ffff) != 0xffff)
+		BOSA_temperature_offset = read_data & 0x0000ffff;
+	if ((read_data & 0xffff0000) >> 16 !=
+	    0xffff) // Enviroment temperature offset by HC 20151006
+		Env_temperature_offset = (read_data & 0xffff0000) >>
+					 16; // reg/10 -> decideg
+
+	pon->bosa_temperature = pon->ic_temperature - BOSA_temperature_offset;
+	pon->env_temperature = pon->ic_temperature - Env_temperature_offset;
+}
