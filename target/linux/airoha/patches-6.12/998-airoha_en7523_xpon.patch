+int phy_I2C_write(struct i2c_client *client, u8 u1DevAddr, u8 u1WordAddrNum,
+		  u32 u4WordAddr, u8 *pu1Buf, u16 u2ByteCnt)
+{
+	struct i2c_msg msg;
+	u8 *buf;
+	int i;
+	int ret;
+
+	buf = kmalloc(u1WordAddrNum + u2ByteCnt, GFP_KERNEL);
+	if (!buf)
+		return 0;
+
+	for (i = 0; i < u1WordAddrNum; i++)
+		buf[i] = (u4WordAddr >> ((u1WordAddrNum - 1 - i) * 8)) & 0xFF;
+
+	memcpy(buf + u1WordAddrNum, pu1Buf, u2ByteCnt);
+	msg.addr = u1DevAddr;
+	msg.flags = 0;
+	msg.len = u1WordAddrNum + u2ByteCnt;
+	msg.buf = buf;
+
+	ret = i2c_transfer(client->adapter, &msg, 1);
+	kfree(buf);
+	if (ret == 1) {
+		return 1;
+	}
+
+	dev_err(&client->dev, "phy_I2C_write error: addr=0x%x reg=0x%x\n",
+		u1DevAddr, u4WordAddr);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(phy_I2C_write);
+
+int phy_I2C_read(struct i2c_client *client, u8 u1DevAddr, u8 u1WordAddrNum,
+		 u32 u4WordAddr, u8 *pu1Buf, u16 u2ByteCnt)
+{
+	struct i2c_msg msgs[2];
+	u8 reg_addr_buf[4];
+	int i;
+	int ret;
+
+	for (i = 0; i < u1WordAddrNum; i++)
+		reg_addr_buf[i] =
+			(u4WordAddr >> ((u1WordAddrNum - 1 - i) * 8)) & 0xFF;
+
+	msgs[0].addr = u1DevAddr;
+	msgs[0].flags = 0;
+	msgs[0].len = u1WordAddrNum;
+	msgs[0].buf = reg_addr_buf;
+
+	msgs[1].addr = u1DevAddr;
+	msgs[1].flags = I2C_M_RD;
+	msgs[1].len = u2ByteCnt;
+	msgs[1].buf = pu1Buf;
+
+	ret = i2c_transfer(client->adapter, msgs, 2);
+	if (ret == 2) {
+		return 1;
+	}
+	dev_err(&client->dev, "phy_I2C_read error: addr=0x%x reg=0x%x\n",
+		u1DevAddr, u4WordAddr);
+	return 0;
+}
