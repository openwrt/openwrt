+static irqreturn_t mtk_pon_irq_handler(int irq, void *priv)
+{
+	struct mtk_pon *pon = (struct mtk_pon *)priv;
+	dev_info(pon->dev, "PON IRQ handled\n");
+	uint phyIntStatus = 0, phyIntStatus_7523 = 0, read_data = 0,
+	     write_data = 0;
+	uint rogue_7523_en = 0, rogue_7523_int_detect = 0;
+	struct PHY_TransConfig_T *p_trans_status;
+
+	get_pon_phy_data(pon, 0xbfaf05F8, &phyIntStatus);
+	dev_info(pon->dev, "PON IRQ Status: 0x%x\n", phyIntStatus);
+	set_pon_phy_data(pon, 0xbfaf05F4, phyIntStatus);
+
+	get_pon_phy_data(pon, 0x1faf4800, &phyIntStatus_7523);
+	dev_info(pon->dev, "PON 7523 IRQ Status: 0x%x\n", phyIntStatus_7523);
+	set_pon_phy_data(pon, 0x1faf4808, phyIntStatus_7523);
+
+	if ((phyIntStatus & 0x01) || (phyIntStatus & 0x40)) {
+		dev_info(pon->dev,
+			 "PHY IRQ: TRANS_LOS(%d)|PHY_ILLG(%d) interrupt.\n",
+			 ((phyIntStatus & 0x01) ? 1 : 0),
+			 ((phyIntStatus & 0x40) ? 1 : 0));
+	}
+	pon->pon_status = PHY_LINK_STATUS_LOS;
+
+	if ((phyIntStatus & 0x01) && (phyIntStatus & 0x40)) {
+		if (phyIntStatus & 0x20) {
+			handle_hw_irq_event(pon, PHY_EVENT_TRANS_LOS_ILLG_INT);
+		} else {
+			handle_hw_irq_event(pon, PHY_EVENT_TRANS_LOS_ILLG_INT);
+		}
+	} else if (phyIntStatus & 0x01) {
+		handle_hw_irq_event(pon, PHY_EVENT_TRANS_LOS_INT);
+	} else if (phyIntStatus & 0x40) {
+		if (PHY_GPON_CONFIG != pon->phy_mode || !pon->phy_rogue)
+			handle_hw_irq_event(pon, PHY_EVENT_PHY_ILLG_INT);
+	}
+
+	if (phyIntStatus & 0x02) {
+		dev_info(pon->dev, "PHY IRQ: transceiver LOF interrupt.\n");
+		pon->phy_rogue = PHY_LINK_STATUS_LOS;
+		handle_hw_irq_event(pon, PHY_EVENT_PHY_LOF_INT);
+	}
+
+	if (phyIntStatus & 0x04) {
+		phy_trans_tx_getting(pon, p_trans_status);
+		if (p_trans_status->trans_tx_fault_inv_status == 0) {
+			dev_info(pon->dev, "turn off power.\n");
+			handle_hw_irq_event(pon, PHY_EVENT_TF_INT);
+		}
+		dev_info(pon->dev, "PHY IRQ: transceiver TF interrupt.\n");
+	}
+
+	if (phyIntStatus & 0x08) {
+		dev_info(pon->dev, "PHY IRQ: transceiver interrupt.\n");
+		handle_hw_irq_event(pon, PHY_EVENT_TRANS_INT);
+	}
+
+	if (phyIntStatus & 0x10) {
+		dev_info(pon->dev,
+			 "PHY IRQ: transceiver TX_SD fail interrupt.\n");
+		handle_hw_irq_event(pon, PHY_EVENT_TRANS_SD_FAIL_INT);
+	}
+
+	if (phyIntStatus & 0x20) {
+		if ((pon->phy_rogue == PHY_LINK_STATUS_READY) &&
+		    (phyIntStatus & 0x200)) {
+			dev_info(pon->dev,
+				 "PHY IRQ: transceiver SIGDET interrupt.\n");
+			pon->phy_rogue = PHY_LINK_STATUS_LOS;
+			handle_hw_irq_event(pon, PHY_EVENT_TRANS_LOS_INT);
+		}
+
+		if (is_ready_int_authentic(phyIntStatus)) {
+			pon->phy_rogue = PHY_LINK_STATUS_READY;
+			handle_hw_irq_event(pon, PHY_EVENT_PHYRDY_INT);
+			// {
+			// 	if (((preempt_count() &
+			// 	      ((((1UL << (4)) - 1) << ((0 + 8) + 8)) |
+			// 	       (((1UL << (8)) - 1) << (0 + 8)) |
+			// 	       (((1UL << (1)) - 1)
+			// 		<< (((0 + 8) + 8) + 4)))))) {
+			// 		del_timer(&pon->phy_ready_timer);
+			// 	} else {
+			// 		del_timer_sync(
+			// 			&pon->phy_ready_timer);
+			// 	}
+			// };
+			dev_info(pon->dev, "PHY IRQ: phy ready interrupt.\n");
+		} else {
+			dev_info(pon->dev,
+				 "PHY IRQ: FALSE phy ready interrupt.\n");
+		}
+	}
+
+	if (phyIntStatus & 0x80) {
+		dev_info(pon->dev, "PHY IRQ: I2C master interrupt.\n");
+		handle_hw_irq_event(pon, PHY_EVENT_I2CM_INT);
+	}
+
+	if (pon->rogue_onu_det_en) {
+		get_pon_phy_data(pon, (0x1faf0000 + 0x480c), &rogue_7523_en);
+		rogue_7523_en = (rogue_7523_en >> 12) & 01;
+		rogue_7523_int_detect = (phyIntStatus_7523 >> 7) & 01;
+
+		if ((rogue_7523_en == 1) && (rogue_7523_int_detect == 1)) {
+			dev_info(pon->dev, "PHY IRQ: ROGUE ENABLE & DETECT.\n");
+
+			read_data = get_pon_phy_data(pon, (0x1faf0000 + 0x480c),
+						     &read_data);
+			write_data = read_data & 0xffffefff;
+			set_pon_phy_data(pon, (0x1faf0000 + 0x480c),
+					 write_data);
+
+			read_data = get_pon_phy_data(pon, (0x1faf0000 + 0x4808),
+						     &read_data);
+			write_data = (read_data & 0xffffff7f) | (0x80);
+			set_pon_phy_data(pon, (0x1faf0000 + 0x4808),
+					 write_data);
+
+			read_data = get_pon_phy_data(pon, (0x1faf0000 + 0x480c),
+						     &read_data);
+			dev_info(pon->dev, "rogue onu DISABLE(0x480C) %x\n",
+				 read_data);
+
+			read_data = get_pon_phy_data(pon, (0x1faf0000 + 0x4808),
+						     &read_data);
+			dev_info(pon->dev, "rogue onu CLR(0x4808) %x\n",
+				 read_data);
+
+			handle_hw_irq_event(pon, PHY_EVENT_TF_INT);
+			phy_trans_power_switch(pon, 0);
+		}
+	}
+
+	/* the following function is used to avoid frequently interrupt */
+	// if (pon->phyCfg.intCounter == 0) {
+	// 	pon->phyCfg.intTime = jiffies;
+	// }
+	// pon->phyCfg.intCounter++;
+	// if (pon->phyCfg.intCounter == 10) {
+	// 	pon->phyCfg.intCounter = 0;
+
+	// 	if ((jiffies - pon->phyCfg.intTime) <
+	// 	    50) { // phy interrupt occur every 5 system interrupt
+
+	// 		dev_info(pon->dev,
+	// 			"PHY detect interrupt error. phyIntStatus = 0x%x, "
+	// 			"phyIntStatus_7523=0x%x\n",
+	// 			phyIntStatus, phyIntStatus_7523);
+	// 	}
+	// }
+
+	return IRQ_HANDLED;
+}
+
+static int mtk_xpon_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct mtk_pon *pon;
+	struct device_node *np;
+	struct i2c_adapter *adapter;
+	int ret;
+
+	pon = devm_kzalloc(&pdev->dev, sizeof(*pon), GFP_KERNEL);
+	if (!pon)
+		return -ENOMEM;
+	pon->dev = &pdev->dev;
+
+	pon->pon_data = of_device_get_match_data(&pdev->dev);
+	if (!pon->pon_data)
+		return dev_err_probe(
+			dev, -EINVAL,
+			"no matching device data found or not enabled\n");
+
+	pon->pon_phy_asic_rg_range =
+		devm_platform_ioremap_resource_byname(pdev, "asic1");
+	if (IS_ERR(pon->pon_phy_asic_rg_range))
+		return dev_err_probe(dev, PTR_ERR(pon->pon_phy_asic_rg_range),
+				     "failed to iomap asic1 regs\n");
+	pon->pon_phy_fpga_rg_tx_off =
+		devm_platform_ioremap_resource_byname(pdev, "fpga-off");
+	if (IS_ERR(pon->pon_phy_fpga_rg_tx_off))
+		return dev_err_probe(dev, PTR_ERR(pon->pon_phy_fpga_rg_tx_off),
+				     "failed to iomap fpga-off regs\n");
+	pon->pon_phy_asic_rg_range2 =
+		devm_platform_ioremap_resource_byname(pdev, "asic2");
+	if (IS_ERR(pon->pon_phy_asic_rg_range2))
+		return dev_err_probe(dev, PTR_ERR(pon->pon_phy_asic_rg_range2),
+				     "failed to iomap asic2 regs\n");
+	pon->pon_phy_asic_rg_range3 =
+		devm_platform_ioremap_resource_byname(pdev, "asic3");
+	if (IS_ERR(pon->pon_phy_asic_rg_range3))
+		return dev_err_probe(dev, PTR_ERR(pon->pon_phy_asic_rg_range3),
+				     "failed to iomap asic3 regs\n");
+
+	// get irq
+	pon->irq = platform_get_irq(pdev, 0);
+	if (pon->irq < 0)
+		return dev_err_probe(pon->dev, pon->irq, "failed to get irq\n");
+
+	np = of_parse_phandle(dev->of_node, "airoha,chip-scu", 0);
+	if (!np)
+		return -EINVAL;
+
+	pon->scu_regmap = syscon_node_to_regmap(np);
+	if (IS_ERR(pon->scu_regmap))
+		return dev_err_probe(dev, PTR_ERR(pon->scu_regmap),
+				     "failed to find SCU regmap\n");
+
+	// I2C Client to maneger PON PHY
+	np = of_parse_phandle(dev->of_node, "i2c,chip", 0);
+	if (!np)
+		return dev_err_probe(pon->dev, PTR_ERR(np),
+				     "cannot get i2c chip node\n");
+
+	adapter = of_find_i2c_adapter_by_node(np);
+	of_node_put(np);
+	if (!adapter)
+		return dev_err_probe(pon->dev, -EPROBE_DEFER,
+				     "cannot get i2c adapter\n");
+
+	struct i2c_board_info info;
+	memset(&info, 0, sizeof(info));
+	strscpy(info.type, "mtk_pon_i2c", I2C_NAME_SIZE);
+	info.addr = 0x60;
+
+	pon->i2c_dev = i2c_new_client_device(adapter, &info);
+	i2c_put_adapter(adapter);
+	if (IS_ERR(pon->i2c_dev))
+		return dev_err_probe(pon->dev, PTR_ERR(pon->i2c_dev),
+				     "failed to create i2c client\n");
+
+	// Start with default flash matrix values
+	memset(pon->flash_matrix, 0, ARRAY_SIZE(pon->flash_matrix));
+	for (ret = 0; ret < 40; ret++)
+		pon->flash_matrix[ret] = 0xffffffff;
+
+	// Read blob from device tree if available
+	if (of_property_read_u32_array(dev->of_node, "airoha,pon-flash-matrix",
+				       pon->flash_matrix, 100) < 0) {
+		dev_info(pon->dev, "using default flash matrix values\n");
+	}
+
+	dev_info(pon->dev, "Checking if running on FPGA or ASIC...\n");
+	bool isFpga = GET_IS_FPGA(pon);
+	dev_info(pon->dev, "Is FPGA: %s", isFpga ? "true" : "false");
+
+	ret = mtk_reset_phy(pdev, pon);
+	if (ret)
+		return dev_err_probe(dev, ret, "failed to reset PON PHY\n");
+
+	ret = mtk_dev_init(pdev, pon);
+	if (ret)
+		return dev_err_probe(dev, ret, "failed to init device\n");
+
+	platform_set_drvdata(pdev, pon);
+	ret = pon->pon_data->init(pdev, pon);
+	if (ret)
+		return dev_err_probe(dev, ret,
+				     "failed to initialize platform data\n");
+
+	ret = devm_request_irq(&pdev->dev, pon->irq, mtk_pon_irq_handler, 0,
+			       pdev->name, pon);
+	if (ret) {
+		dev_err(dev, "Can't get interrupt working.\n");
+		return ret;
+	}
+
+	return 0;
+}
+
+static const struct of_device_id mtk_xpon_match[] = {
+#ifdef CONFIG_AIROHA_XPON_MT7570
+	{ .compatible = "mediatek,mt7570-pon-phy", .data = &mt7570_pon_data },
+#endif
+#ifdef CONFIG_AIROHA_XPON_EN7571
+	{ .compatible = "airoha,en7571-pon-phy", .data = &en7571_pon_data },
+#endif
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, mtk_xpon_match);
+
+static struct platform_driver mtk_pon_driver = {
+	.probe = mtk_xpon_probe,
+	.driver = {
+		.name = "mtk-phy-pon",
+		.of_match_table = mtk_xpon_match,
+	},
+};
+module_platform_driver(mtk_pon_driver);
+
+MODULE_DESCRIPTION("Airoha xPON driver");
+MODULE_AUTHOR("Matheus Sampaio Queiroga <srherobrine20@gmail.com>");
+MODULE_LICENSE("GPL");
