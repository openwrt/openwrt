+static int phy_trans_power_switch(struct mtk_pon *pon, unchar trans_switch)
+{
+	pon->tx_power_setting = trans_switch;
+
+	if (trans_switch == 0) {
+		if (pon->rogue_onu_det_en) {
+			pon_phy_rogueonu_int_en(pon, 0);
+		}
+		phy_tx_ctl(pon, 0);
+
+		dev_info(pon->dev, "turn off transceiver power success! \n");
+		return 0;
+	} else if (trans_switch == 1) {
+		if (pon->rogue_onu_det_en) {
+			pon_phy_rogueonu_int_en(pon, 1);
+		}
+
+		if (pon->phy_txPowerEnFlag) {
+			phy_tx_ctl(pon, 1);
+
+			dev_info(pon->dev,
+				 "turn on transceiver power success! \n");
+		}
+		return 0;
+	} else {
+		dev_info(pon->dev, "setting transceiver power fail. \n");
+		return 1;
+	}
+}
