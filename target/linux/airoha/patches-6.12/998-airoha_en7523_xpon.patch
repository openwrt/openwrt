+static netdev_tx_t xpon_xmit_tx(struct sk_buff *skb, struct net_device *dev)
+{
+	struct mtk_xpon *xdev = netdev_priv(dev);
+	dev_info(
+		&dev->dev,
+		"skb transmitted, size %d, protocol 0x%x, vlan all 0x%x, vlan_proto 0x%x, vlan_tci 0x%x",
+		skb->len, skb->protocol, skb->vlan_all, skb->vlan_proto,
+		skb->vlan_tci);
+
+	xdev->stats->tx_packets++;
+	xdev->stats->tx_bytes += skb->len;
+
+	// print hex dump of skb data
+	print_hex_dump(KERN_INFO, "skb data: ", DUMP_PREFIX_OFFSET, 16, 1,
+		       skb->data, skb->len, false);
+	kfree_skb(skb);
+
+	return NETDEV_TX_OK;
+}
