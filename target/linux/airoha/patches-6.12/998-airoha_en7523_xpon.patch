+	{ 0x1fa2ff24, 0x1fa2ff24 + 0x4 }, // PON_PHY_FPGA_RG_TX_OFF
+	{ 0x1faf3000, 0x1faf3000 + 0xfff }, // PON_PHY_ASIC_RG range2
