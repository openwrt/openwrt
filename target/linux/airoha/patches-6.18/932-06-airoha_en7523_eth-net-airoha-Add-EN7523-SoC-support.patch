+		default:
+			break;
+		}
+
+		if (type == PPE_PKT_TYPE_BRIDGE) {
+			data = hwe->bridge.data;
+			ib2 = hwe->bridge.ib2;
+			l2 = &hwe->bridge.l2.common;
