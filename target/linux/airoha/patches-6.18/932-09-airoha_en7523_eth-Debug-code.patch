From: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
Date: Fri, 12 Jun 2026 19:11:15 -0300
Subject: [PATCH 9/9] Debug code

Signed-off-by: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
---
 drivers/net/ethernet/airoha/airoha_eth.c | 76 ++++++++++++++++++++++++
 drivers/net/pcs/airoha/pcs-en7523.c      | 73 +++++++++++++++++++++++
 2 files changed, 149 insertions(+)

diff --git a/drivers/net/ethernet/airoha/airoha_eth.c b/drivers/net/ethernet/airoha/airoha_eth.c
index 5c4f6366b..a21a92c71 100644
--- a/drivers/net/ethernet/airoha/airoha_eth.c
+++ b/drivers/net/ethernet/airoha/airoha_eth.c
@@ -180,6 +180,73 @@ static int airoha_set_vip_for_gdm_port(struct airoha_gdm_dev *dev, bool enable)
 	return 0;
 }
 
+static void airoha_en7523_gdm2_direct_enable(struct airoha_eth *eth)
+{
+	u32 fwd_cfg, lpbk_cfg, txchn_en, rxchn_en, len_cfg;
+	u32 vip_port_en, ifc_port_en, wan_port, dft_cport0;
+	u32 val;
+
+	if (!airoha_is(eth, en7523))
+		return;
+
+	/*
+	 * EN7523 AE/PON WAN direct path uses GDMA2/GDM2 as the real ingress
+	 * MAC.  The PCIe/USB WAN path instead reuses GDM2 only as a loopback
+	 * bridge to GDM3/GDM4.  When GDM2 is used directly, make sure the
+	 * loopback state left by the PCIe/USB path is gone, enable the GDMA2
+	 * channels, and strip the ingress FCS like the vendor AE/PON path.
+	 */
+	airoha_fe_clear(eth, REG_GDM_LPBK_CFG(AIROHA_GDM2_IDX),
+			LPBK_CHAN_MASK | LPBK_MODE_MASK | LPBK_EN_MASK);
+	airoha_fe_wr(eth, REG_GDM_TXCHN_EN(AIROHA_GDM2_IDX), 0xffffffff);
+	airoha_fe_wr(eth, REG_GDM_RXCHN_EN(AIROHA_GDM2_IDX), 0x0000ffff);
+	airoha_fe_set(eth, REG_GDM_FWD_CFG(AIROHA_GDM2_IDX),
+		      GDM_STRIP_CRC_MASK);
+
+	/* FE_API_SET_GDMA_ENABLE(XSI_AE_IDX) in the vendor SDK enables
+	 * bit 2 in FE_VIP_PORT_EN and FE_IFC_PORT_EN for the AE/PON path.
+	 * Without these bits, GDMA2 can have link and channels enabled but
+	 * ingress packets never get classified/forwarded to the CPU path.
+	 */
+	airoha_fe_set(eth, REG_FE_VIP_PORT_EN, BIT(AIROHA_GDM2_IDX));
+	airoha_fe_set(eth, REG_FE_IFC_PORT_EN, BIT(AIROHA_GDM2_IDX));
+	airoha_fe_rmw(eth, REG_FE_WAN_PORT, WAN0_MASK,
+		      FIELD_PREP(WAN0_MASK, AIROHA_GDM2_IDX));
+
+	/*
+	 * v4 diagnostic path: bypass PPE for the direct AE/PON GDM2 path and
+	 * deliver ingress frames straight to CDM2/QDMA1.  GDM1 already proves
+	 * the PPE path can work for LAN; forcing GDM2 to CDM2 isolates whether
+	 * the remaining no-RX issue is in XSI/GDM2 or in PPE classification/CPU
+	 * port setup for the WAN-side fport.
+	 */
+	airoha_set_gdm_port_fwd_cfg(eth, REG_GDM_FWD_CFG(AIROHA_GDM2_IDX),
+				    FE_PSE_PORT_CDM2);
+
+	/* Direct GDM2 frames are reported as normal GDMA source ports.  Make the
+	 * GDMA2 source-port default CPU port explicit as CDM2 as well.
+	 */
+	val = 3 & SP_CPORT_DFT_MASK;
+	airoha_fe_rmw(eth, REG_SP_DFT_CPORT(3 >> fls(SP_CPORT_DFT_MASK)),
+		      SP_CPORT_MASK(val),
+		      __field_prep(SP_CPORT_MASK(val), FE_PSE_PORT_CDM2));
+
+	fwd_cfg = airoha_fe_rr(eth, REG_GDM_FWD_CFG(AIROHA_GDM2_IDX));
+	lpbk_cfg = airoha_fe_rr(eth, REG_GDM_LPBK_CFG(AIROHA_GDM2_IDX));
+	txchn_en = airoha_fe_rr(eth, REG_GDM_TXCHN_EN(AIROHA_GDM2_IDX));
+	rxchn_en = airoha_fe_rr(eth, REG_GDM_RXCHN_EN(AIROHA_GDM2_IDX));
+	len_cfg = airoha_fe_rr(eth, REG_GDM_LEN_CFG(AIROHA_GDM2_IDX));
+	vip_port_en = airoha_fe_rr(eth, REG_FE_VIP_PORT_EN);
+	ifc_port_en = airoha_fe_rr(eth, REG_FE_IFC_PORT_EN);
+	wan_port = airoha_fe_rr(eth, REG_FE_WAN_PORT);
+	dft_cport0 = airoha_fe_rr(eth, REG_SP_DFT_CPORT(0));
+
+	dev_info(eth->dev,
+		 "EN7523 GDM2 direct: fwd_cfg=%08x lpbk_cfg=%08x txchn_en=%08x rxchn_en=%08x len_cfg=%08x vip=%08x ifc=%08x wan_port=%08x dft_cport0=%08x\n",
+		 fwd_cfg, lpbk_cfg, txchn_en, rxchn_en, len_cfg,
+		 vip_port_en, ifc_port_en, wan_port, dft_cport0);
+}
+
 static void airoha_fe_maccr_init(struct airoha_eth *eth)
 {
 	int p;
@@ -2158,6 +2225,9 @@ static int airoha_dev_open(struct net_device *netdev)
 	airoha_set_gdm_port_fwd_cfg(qdma->eth, REG_GDM_FWD_CFG(port->id),
 				    pse_port);
 
+	if (port->id == AIROHA_GDM2_IDX)
+		airoha_en7523_gdm2_direct_enable(qdma->eth);
+
 	return 0;
 }
 
@@ -2302,6 +2372,7 @@ static int airoha_disable_gdm2_loopback(struct airoha_gdm_dev *dev)
 						 : FE_PSE_PORT_PPE1;
 	airoha_set_gdm_port_fwd_cfg(eth, REG_GDM_FWD_CFG(AIROHA_GDM2_IDX),
 				    pse_port);
+	airoha_en7523_gdm2_direct_enable(eth);
 
 	airoha_fe_rmw(eth, REG_FE_WAN_PORT, WAN0_MASK,
 		      FIELD_PREP(WAN0_MASK, AIROHA_GDM2_IDX));
@@ -2362,6 +2433,9 @@ static void airoha_dev_set_qdma(struct airoha_gdm_dev *dev)
 			  dev->port->id == AIROHA_GDM4_IDX ||
 			  dev->port->id == AIROHA_GDM2_IDX) &&
 			  airoha_ppe_is_enabled(eth, 1)) ? 1 : 0);
+
+		if (dev->port->id == AIROHA_GDM2_IDX)
+			airoha_en7523_gdm2_direct_enable(eth);
 	}
 
 	ppe_id = !airoha_is_lan_gdm_dev(dev) && airoha_ppe_is_enabled(eth, 1);
@@ -4229,6 +4303,8 @@ static int airoha_en7523_get_sport(struct airoha_gdm_port *port, int nbq)
 static u32 airoha_en7523_get_vip_port(struct airoha_gdm_port *port, int nbq)
 {
 	switch (port->id) {
+	case AIROHA_GDM2_IDX:
+		return BIT(AIROHA_GDM2_IDX);
 	case AIROHA_GDM3_IDX:
 		if (nbq == 4)
 			return XSI_PCIE0_VIP_PORT_MASK;
diff --git a/drivers/net/pcs/airoha/pcs-en7523.c b/drivers/net/pcs/airoha/pcs-en7523.c
index b3425b032..181c6d8d8 100644
--- a/drivers/net/pcs/airoha/pcs-en7523.c
+++ b/drivers/net/pcs/airoha/pcs-en7523.c
@@ -49,6 +49,24 @@
 #define EN7523_XSI_PRB_OUTH			0xc4
 #define EN7523_XSI_PRB_OUTL			0xc8
 #define EN7523_XSI_IF_STS			0xcc
+#define EN7523_XSI_CNT_CLR			0x100
+
+#define EN7523_XSI_GLB_CFG_TXMBI_STOP		BIT(0)
+#define EN7523_XSI_GLB_CFG_TXMPI_STOP		BIT(1)
+#define EN7523_XSI_GLB_CFG_RXMBI_STOP		BIT(2)
+#define EN7523_XSI_GLB_CFG_RXMPI_STOP		BIT(3)
+#define EN7523_XSI_GLB_CFG_RX_FC_EN		BIT(4)
+#define EN7523_XSI_GLB_CFG_TX_FC_EN		BIT(5)
+#define EN7523_XSI_GLB_CFG_TXMPI_MASK		BIT(9)
+#define EN7523_XSI_GLB_CFG_IPG_NUM		GENMASK(15, 10)
+#define EN7523_XSI_GLB_CFG_TX_FRAG_LEN		GENMASK(21, 17)
+#define EN7523_XSI_GLB_CFG_RX_FRAG_LEN		GENMASK(26, 22)
+#define EN7523_XSI_STOP_MASK			(EN7523_XSI_GLB_CFG_TXMBI_STOP | \
+						 EN7523_XSI_GLB_CFG_TXMPI_STOP | \
+						 EN7523_XSI_GLB_CFG_RXMBI_STOP | \
+						 EN7523_XSI_GLB_CFG_RXMPI_STOP)
+#define EN7523_XSI_CNT_CLR_GLB_CNTCLR		BIT(0)
+#define EN7523_XSI_MAC_LOGIC_RST_ENABLE		BIT(0)
 
 /* PON SerDes/PHY init sequence from SDK sgmii_api_pon0_force_hsgmii().
  * The SDK exposes these as absolute addresses below PON_CSR_PMA_BASE
@@ -304,6 +322,60 @@ static int en7523_pcs_init_regmap(struct platform_device *pdev,
 	return 0;
 }
 
+static void en7523_pcs_xsi_mac_init(struct en7523_pcs_port *port,
+				    phy_interface_t interface)
+{
+	struct en7523_pcs *priv = port->priv;
+	u32 before = 0, stopped = 0, after = 0;
+
+	if (priv->data->type != EN7523_PCS_PON || !port->xsi)
+		return;
+
+	regmap_read(port->xsi, EN7523_XSI_GLB_CFG, &before);
+
+	/*
+	 * Vendor ae_wan_mac_init() does the XSI MAC side setup in addition
+	 * to SerDes/PCS setup: stop MPI/MBI, reset/release MAC logic, set
+	 * IPG=10, then enable MPI/MBI and TX/RX flow-control.  Without this
+	 * the PON/GDM2 PCS can report link while no useful traffic reaches FE.
+	 */
+	regmap_set_bits(port->xsi, EN7523_XSI_GLB_CFG,
+			EN7523_XSI_STOP_MASK |
+			EN7523_XSI_GLB_CFG_TXMPI_MASK);
+	usleep_range(1000, 2000);
+
+	regmap_read(port->xsi, EN7523_XSI_GLB_CFG, &stopped);
+
+	/* Vendor xsimaclogicrst()/xsimaclogicrstenable(): write 0, then 1. */
+	regmap_write(port->xsi, EN7523_XSI_MAC_LOGIC_RST, 0);
+	usleep_range(1000, 2000);
+	regmap_write(port->xsi, EN7523_XSI_MAC_LOGIC_RST,
+		     EN7523_XSI_MAC_LOGIC_RST_ENABLE);
+
+	regmap_set_bits(port->xsi, EN7523_XSI_CNT_CLR,
+			EN7523_XSI_CNT_CLR_GLB_CNTCLR);
+
+	regmap_update_bits(port->xsi, EN7523_XSI_GLB_CFG,
+			EN7523_XSI_STOP_MASK |
+			EN7523_XSI_GLB_CFG_TXMPI_MASK |
+			EN7523_XSI_GLB_CFG_IPG_NUM |
+			EN7523_XSI_GLB_CFG_TX_FRAG_LEN |
+			EN7523_XSI_GLB_CFG_RX_FRAG_LEN |
+			EN7523_XSI_GLB_CFG_RX_FC_EN |
+			EN7523_XSI_GLB_CFG_TX_FC_EN,
+			FIELD_PREP(EN7523_XSI_GLB_CFG_IPG_NUM, 10) |
+			FIELD_PREP(EN7523_XSI_GLB_CFG_TX_FRAG_LEN, 31) |
+			FIELD_PREP(EN7523_XSI_GLB_CFG_RX_FRAG_LEN, 31) |
+			EN7523_XSI_GLB_CFG_RX_FC_EN |
+			EN7523_XSI_GLB_CFG_TX_FC_EN);
+
+	regmap_read(port->xsi, EN7523_XSI_GLB_CFG, &after);
+	dev_info(priv->dev,
+		 "xsi_mac_init: type=%s port=%u interface=%s glb %08x->%08x->%08x\n",
+		 en7523_pcs_type_name(priv->data->type), port->index,
+		 phy_modes(interface), before, stopped, after);
+}
+
 static void en7523_pcs_pon_hsgmii_phy_init(struct en7523_pcs_port *port,
 					      phy_interface_t interface)
 {
@@ -416,6 +488,7 @@ static void en7523_pcs_setup_scu(struct en7523_pcs_port *port,
 		regmap_write(priv->scu, EN7523_SCU_WAN_CONF, wan_val);
 
 		en7523_pcs_pon_hsgmii_phy_init(port, interface);
+		en7523_pcs_xsi_mac_init(port, interface);
 
 		regmap_read(priv->scu, EN7523_SCU_SSR3, &ssr3_after);
 		regmap_read(priv->scu, EN7523_SCU_WAN_CONF, &wan_after);
-- 
