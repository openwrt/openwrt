+	case en7523:
+		return airoha_fe_get(eth, REG_CDM_LRO_EN(qdma_id + 1), EN7523_LRO_RXQ_EN_MASK);
+	case en7581:
+	case an7583:
+		return airoha_fe_get(eth, REG_CDM_LRO_EN(qdma_id + 1), LRO_RXQ_EN_MASK);
+	default:
+		return false;
+	}
 }
 
