From 33da58c29d5b8d87e87df3225512a0a78d63abc0 Mon Sep 17 00:00:00 2001
From: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
Date: Wed, 25 Mar 2026 16:19:05 -0300
Subject: [PATCH 5/7] net: airoha: Add EN7523 SoC support

Introduce support for EN7523 ethernet controller to airoha-eth dirver

Signed-off-by: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
---
 drivers/net/ethernet/airoha/airoha_eth.c      | 474 ++++++++++++++----
 drivers/net/ethernet/airoha/airoha_eth.h      | 131 +++--
 drivers/net/ethernet/airoha/airoha_ppe.c      | 284 ++++++++---
 .../net/ethernet/airoha/airoha_ppe_debugfs.c  |  54 +-
 drivers/net/ethernet/airoha/airoha_regs.h     |  87 +++-
 5 files changed, 801 insertions(+), 229 deletions(-)

diff --git a/drivers/net/ethernet/airoha/airoha_eth.c b/drivers/net/ethernet/airoha/airoha_eth.c
index 570bb56c1..ae9ab1f8f 100644
--- a/drivers/net/ethernet/airoha/airoha_eth.c
+++ b/drivers/net/ethernet/airoha/airoha_eth.c
@@ -145,6 +145,16 @@ static int airoha_set_macaddr(struct airoha_gdm_dev *dev, const u8 *addr)
 	airoha_fe_wr(eth, REG_FE_MAC_LMIN(reg), lmin);
 	airoha_fe_wr(eth, REG_FE_MAC_LMAX(reg), lmax);
 
+	// FIXME @merbanan: wan mix/max should be a range
+	if (airoha_is(eth, en7523)) {
+		reg = REG_FE_WAN_MAC_H;
+		val = (addr[0] << 16) | (addr[1] << 8) | addr[2];
+		airoha_fe_wr(eth, reg, val);
+		val = (addr[3] << 16) | (addr[4] << 8) | addr[5];
+		airoha_fe_wr(eth, REG_FE_MAC_LMIN(reg), val);
+		airoha_fe_wr(eth, REG_FE_MAC_LMAX(reg), val);
+		airoha_fe_wr(eth, reg, val);
+	}
 	airoha_ppe_init_upd_mem(dev, addr);
 
 	return 0;
@@ -197,6 +207,8 @@ static void airoha_fe_maccr_init(struct airoha_eth *eth)
 
 	airoha_fe_rmw(eth, REG_CDM_VLAN_CTRL(1), CDM_VLAN_MASK,
 		      FIELD_PREP(CDM_VLAN_MASK, 0x8100));
+	airoha_fe_rmw(eth, REG_CDM_VLAN_CTRL(1), CDM_VLAN_MASK,
+		      FIELD_PREP(STAG_EN, 0x1));
 
 	airoha_fe_set(eth, REG_FE_CPORT_CFG, FE_CPORT_PAD);
 }
