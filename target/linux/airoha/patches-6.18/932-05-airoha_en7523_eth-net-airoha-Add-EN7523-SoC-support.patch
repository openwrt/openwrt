+static void seq_hex_dump_file(struct seq_file *m, void *data, size_t size)
+{
+	for (int j = 0; j < size; j += 16) {
+		seq_printf(m, " %04x: ", j);
+		for (int k = 0; k < 16 && j + k < size; k++)
+			seq_printf(m, "%02x ", ((u8 *)data)[j + k]);
+		seq_puts(m, "  ");
+		for (int k = 0; k < 16 && j + k < size; k++) {
+			u8 c = ((u8 *)data)[j + k];
+			seq_putc(m, (c >= 32 && c <= 126) ? c : '.');
+		}
+		seq_putc(m, '\n');
+	}
+}
