+		airoha_fe_wr(eth, REG_PSE_SHARE_USED_THD, 0x1e001f4);
+		return 0;
+	}
+
 	/* modify hthd */
 	fq_limit = airoha_fe_get(eth, PSE_FQ_CFG, PSE_FQ_LIMIT_MASK);
 	tmp = fq_limit - all_rsv - 0x20;
