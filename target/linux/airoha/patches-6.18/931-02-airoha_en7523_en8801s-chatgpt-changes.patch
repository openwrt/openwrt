From 3d1dd624a0307181ff081e8a543913fb03bc90a0 Mon Sep 17 00:00:00 2001
From: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
Date: Thu, 11 Jun 2026 22:19:49 -0300
Subject: [PATCH 2/2] chatgpt changes

Signed-off-by: Matheus Sampaio Queiroga <srherobrine20@gmail.com>
---
 drivers/net/phy/en8801sc.c | 70 +++++++++++++++++++++++++++++++-------
 drivers/net/phy/en8801sc.h |  5 ++-
 2 files changed, 62 insertions(+), 13 deletions(-)

diff --git a/drivers/net/phy/en8801sc.c b/drivers/net/phy/en8801sc.c
index 89236c7f6..774d27278 100644
--- a/drivers/net/phy/en8801sc.c
+++ b/drivers/net/phy/en8801sc.c
@@ -25,6 +25,7 @@
 #include <linux/mii.h>
 #include <linux/ethtool.h>
 #include <linux/phy.h>
+#include <linux/property.h>
 #include <linux/delay.h>
 
 #include <linux/uaccess.h>
@@ -32,7 +33,7 @@
 
 #include "en8801sc.h"
 
-MODULE_DESCRIPTION("Airoha EN8801S PHY");
+MODULE_DESCRIPTION("Airoha EN8801S/EN8801SC/EN8801SN PHY");
 MODULE_AUTHOR("Airoha");
 MODULE_LICENSE("GPL");
 
@@ -42,7 +43,7 @@ MODULE_LICENSE("GPL");
 #define phydev_mdio_bus(_dev) (_dev->mdio.bus)
 #define phydev_phy_addr(_dev) (_dev->mdio.addr)
 #define phydev_dev(_dev) (&_dev->mdio.dev)
-#define phydev_pbus_addr(dev) ((dev)->mdio.addr + 1)
+#define phydev_pbus_addr(_dev) (((struct en8801s_priv *)(_dev)->priv)->pbus_addr)
 
 enum {
 	PHY_STATE_DONE = 0,
@@ -55,6 +56,7 @@ struct en8801s_priv {
 	bool first_init;
 	u16 count;
 	u16 pro_version;
+	u8 pbus_addr;
 };
 
 /*
@@ -93,6 +95,12 @@ static const u16 led_dur = UNIT_LED_BLINK_DURATION << AIR_LED_BLK_DUR_64M;
 ************************************************************************/
 static int en8801s_phase2_init(struct phy_device *phydev);
 
+static bool en8801s_phy_id2_match(u16 phy_id2)
+{
+	return phy_id2 == EN8801SC_PHY_ID2 ||
+	       phy_id2 == EN8801SN_PHY_ID2;
+}
+
 static int __airoha_cl45_write(struct mii_bus *bus, int port,
 			u32 devad, u32 reg, u16 val)
 {
@@ -460,11 +468,14 @@ static int en8801s_phase1_init(struct phy_device *phydev)
 		}
 		pbus_addr = phydev_pbus_addr(phydev);
 		if (0 == --retry) {
-			dev_err(dev, "Probe fail !\n");
-			return 0;
+			dev_err(dev, "Probe fail! unable to find PBUS OUI 0x%04x\n",
+				EN8801S_PBUS_OUI);
+			return -ENODEV;
 		}
 	}
 
+	priv->pbus_addr = pbus_addr;
+
 	ret = airoha_pbus_write(mbus, pbus_addr, EN8801S_RG_BUCK_CTL, 0x03);
 	if (ret < 0)
 		return ret;
@@ -507,24 +518,31 @@ static int en8801s_phase1_init(struct phy_device *phydev)
 	pbus_data = airoha_pbus_read(mbus, pbus_addr,
 				EN8801S_RG_SMI_ADDR); /* SMI ADDR */
 	pbus_data = (pbus_data & 0xffff0000) |
-				(unsigned long)(phydev_pbus_addr(phydev) << 8) |
-				(unsigned long)(phydev_phy_addr(phydev));
-	dev_info(phydev_dev(phydev), "SMI_ADDR=%lx (renew)\n", pbus_data);
+				((unsigned long)pbus_addr << 8) |
+				(unsigned long)phydev_phy_addr(phydev);
+	dev_info(dev, "SMI_ADDR=%lx (renew)\n", pbus_data);
 	ret = airoha_pbus_write(mbus, pbus_addr,
 				EN8801S_RG_SMI_ADDR, pbus_data);
+	if (ret < 0)
+		return ret;
 	mdelay(10);
 
 	retry = MAX_RETRY;
 	while (1) {
 		mdelay(10);
 		reg_value = phy_read(phydev, MII_PHYSID2);
-		if (reg_value == EN8801S_PHY_ID2)
+		if (en8801s_phy_id2_match(reg_value)) {
+			dev_info(dev, "PHY ID2 0x%04x ready\n", reg_value);
 			break;    /* wait GPHY ready */
+		}
 
 		retry--;
 		if (retry == 0) {
-			dev_err(dev, "Initialize fail !\n");
-			return 0;
+			dev_err(dev,
+				"Initialize fail! phy=0x%x pbus=0x%x PHYSID2=0x%04x expected 0x%04x/0x%04x\n",
+				phydev_phy_addr(phydev), pbus_addr, reg_value,
+				EN8801SC_PHY_ID2, EN8801SN_PHY_ID2);
+			return -ETIMEDOUT;
 		}
 	}
 	/* Software Reset PHY */
@@ -540,7 +558,7 @@ static int en8801s_phase1_init(struct phy_device *phydev)
 		retry--;
 		if (retry == 0) {
 			dev_err(dev, "Reset fail !\n");
-			return 0;
+			return -ETIMEDOUT;
 		}
 	} while (reg_value & BMCR_RESET);
 
@@ -1009,13 +1027,24 @@ static int en8801s_probe(struct phy_device *phydev)
 	struct en8801s_priv *priv;
 	unsigned long phy_addr = phydev_phy_addr(phydev);
 	struct mdio_device *mdiodev = &phydev->mdio;
+	u32 pbus_addr = phy_addr + 1;
 
 	priv = kzalloc(sizeof(*priv), GFP_KERNEL);
 	if (!priv)
 		return -ENOMEM;
 
+	device_property_read_u32(phydev_dev(phydev), "airoha,pbus-address",
+				 &pbus_addr);
+	if (pbus_addr >= PHY_MAX_ADDR) {
+		dev_err(phydev_dev(phydev), "invalid PBUS addr 0x%x\n",
+			pbus_addr);
+		kfree(priv);
+		return -EINVAL;
+	}
+
 	priv->count = 0;
 	priv->first_init = true;
+	priv->pbus_addr = pbus_addr;
 
 	if (mdiodev->reset_gpio) {
 		dev_info(phydev_dev(phydev),
@@ -1024,8 +1053,10 @@ static int en8801s_probe(struct phy_device *phydev)
 		phy_device_reset(phydev, 1);
 	}
 
-	dev_info(phydev_dev(phydev), "EN8801S initialized");
 	phydev->priv = priv;
+	dev_info(phydev_dev(phydev),
+		 "EN8801S initialized, PHY addr 0x%lx, PBUS addr 0x%x\n",
+		 phy_addr, priv->pbus_addr);
 
 	return 0;
 }
@@ -1106,6 +1137,20 @@ static struct phy_driver Airoha_driver[] = {
 		.resume         = genphy_resume,
 		.read_mmd       = airoha_mmd_read,
 		.write_mmd      = airoha_mmd_write,
+	},
+	{
+		.phy_id         = EN8801SN_PHY_ID,
+		.name           = "Airoha EN8801SN",
+		.phy_id_mask    = 0x0ffffff0,
+		.features       = PHY_GBIT_FEATURES,
+		.probe          = en8801s_probe,
+		.config_init    = en8801s_phase1_init,
+		.config_aneg    = genphy_config_aneg,
+		.read_status    = en8801s_read_status,
+		.suspend        = genphy_suspend,
+		.resume         = genphy_resume,
+		.read_mmd       = airoha_mmd_read,
+		.write_mmd      = airoha_mmd_write,
 	}
 };
 
@@ -1113,6 +1158,7 @@ module_phy_driver(Airoha_driver);
 
 static const struct mdio_device_id __maybe_unused Airoha_tbl[] = {
 	{ EN8801SC_PHY_ID, 0x0ffffff0 },
+	{ EN8801SN_PHY_ID, 0x0ffffff0 },
 	{ }
 };
 
diff --git a/drivers/net/phy/en8801sc.h b/drivers/net/phy/en8801sc.h
index 60b9c3272..b990cac10 100644
--- a/drivers/net/phy/en8801sc.h
+++ b/drivers/net/phy/en8801sc.h
@@ -23,8 +23,11 @@
 
 #define EN8801S_PBUS_OUI        0x17a5
 #define EN8801S_PHY_ID1         0x03a2
-#define EN8801S_PHY_ID2         0x9471
+#define EN8801SC_PHY_ID2        0x9471
+#define EN8801SN_PHY_ID2        0x9461
+#define EN8801S_PHY_ID2         EN8801SC_PHY_ID2
 #define EN8801SC_PHY_ID         0x03a29471
+#define EN8801SN_PHY_ID         0x03a29461
 
 #define LED_ON_CTRL(i)              (0x024 + ((i)*2))
 #define LED_ON_EN                   (1 << 15)
-- 
2.54.0

