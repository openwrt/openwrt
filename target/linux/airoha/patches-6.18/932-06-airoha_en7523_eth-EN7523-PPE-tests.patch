+	if (!airoha_ppe_tuple_is_offload_candidate(&tuple))
+		return NULL;
+
+	hlist_for_each_entry(e, &en7523_pending_flows, list) {
+		if (e->type != FLOW_TYPE_L4)
+			continue;
+
+		if (e->hash != 0xffff)
+			continue;
+
+		if (airoha_ppe_foe_entry_match_skb_tuple(e, &tuple))
+			return e;
+	}
+
+	return NULL;
+}
