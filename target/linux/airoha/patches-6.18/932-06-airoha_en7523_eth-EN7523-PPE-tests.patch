+struct airoha_skb_ipv4_tuple {
+	u8 proto;
+	u32 src_ip;
+	u32 dst_ip;
+	u16 src_port;
+	u16 dst_port;
+	bool has_ports;
+};
+
+static bool
+airoha_ppe_skb_read_ipv4_tuple_at(struct sk_buff *skb, unsigned int off,
+				  struct airoha_skb_ipv4_tuple *tuple)
+{
+	struct udphdr _uh, *uh;
+	struct tcphdr _th, *th;
+	struct iphdr _iph, *iph;
+	unsigned int l4_off;
+	u16 tot_len;
+
+	if (off + sizeof(_iph) > skb->len)
+		return false;
+
+	iph = skb_header_pointer(skb, off, sizeof(_iph), &_iph);
+	if (!iph)
+		return false;
+
+	if (iph->version != 4 || iph->ihl < 5)
+		return false;
+
+	if (iph->protocol != IPPROTO_TCP &&
+	    iph->protocol != IPPROTO_UDP)
+		return false;
+
+	tot_len = ntohs(iph->tot_len);
+	if (tot_len < iph->ihl * 4)
+		return false;
+
+	if (off + tot_len > skb->len)
+		return false;
+
+	l4_off = off + iph->ihl * 4;
+
+	tuple->proto = iph->protocol;
+	tuple->src_ip = be32_to_cpu(iph->saddr);
+	tuple->dst_ip = be32_to_cpu(iph->daddr);
+	tuple->has_ports = false;
+
+	switch (iph->protocol) {
+	case IPPROTO_TCP:
+		th = skb_header_pointer(skb, l4_off, sizeof(_th), &_th);
+		if (!th)
+			return false;
+
+		tuple->src_port = be16_to_cpu(th->source);
+		tuple->dst_port = be16_to_cpu(th->dest);
+		tuple->has_ports = true;
+		break;
+	case IPPROTO_UDP:
+		uh = skb_header_pointer(skb, l4_off, sizeof(_uh), &_uh);
+		if (!uh)
+			return false;
+
+		tuple->src_port = be16_to_cpu(uh->source);
+		tuple->dst_port = be16_to_cpu(uh->dest);
+		tuple->has_ports = true;
+		break;
+	}
+
+	return true;
+}
+
+static bool
+airoha_ppe_skb_find_ipv4_tuple(struct sk_buff *skb,
+			       struct airoha_skb_ipv4_tuple *tuple)
+{
+	static const unsigned int fixed_offsets[] = {
+		0,
+		ETH_HLEN,
+		ETH_HLEN + 4,
+		ETH_HLEN + 8,
+	};
+	unsigned int i, off, max_scan;
+
+	/* Try likely offsets first. skb->protocol is unreliable here on EN7523. */
+	for (i = 0; i < ARRAY_SIZE(fixed_offsets); i++) {
+		if (airoha_ppe_skb_read_ipv4_tuple_at(skb, fixed_offsets[i],
+						      tuple))
+			return true;
+	}
+
+	if (skb_network_offset(skb) < skb->len &&
+	    airoha_ppe_skb_read_ipv4_tuple_at(skb, skb_network_offset(skb),
+					      tuple))
+		return true;
+
+	/* Fallback: scan early bytes. False positives are unlikely because
+	 * we still compare src/dst/proto/ports against pending flows.
+	 */
+	max_scan = min_t(unsigned int, skb->len, 96);
+	for (off = 0; off < max_scan; off++) {
+		if (airoha_ppe_skb_read_ipv4_tuple_at(skb, off, tuple))
+			return true;
+	}
+
+	return false;
+}
+
+static bool
+airoha_ppe_ipv4_tuple_match_skb_tuple(const struct airoha_foe_ipv4_tuple *t,
+				      const struct airoha_skb_ipv4_tuple *s,
+				      bool with_ports)
+{
+	if (t->src_ip != s->src_ip || t->dest_ip != s->dst_ip)
+		return false;
+
+	if (!with_ports)
+		return true;
+
+	if (!s->has_ports)
+		return false;
+
+	return t->src_port == s->src_port &&
+	       t->dest_port == s->dst_port;
+}
+
+static bool
+airoha_ppe_foe_entry_match_skb_tuple(struct airoha_flow_table_entry *e,
+				     const struct airoha_skb_ipv4_tuple *s)
+{
+	u32 type = FIELD_GET(AIROHA_FOE_IB1_BIND_PACKET_TYPE, e->data.ib1);
+
+	switch (type) {
+	case PPE_PKT_TYPE_IPV4_ROUTE:
+		return airoha_ppe_ipv4_tuple_match_skb_tuple(&e->data.ipv4.orig_tuple,
+							     s, false);
+
+	case PPE_PKT_TYPE_IPV4_HNAPT:
+		return airoha_ppe_ipv4_tuple_match_skb_tuple(&e->data.ipv4.orig_tuple,
+							     s, true) ||
+		       airoha_ppe_ipv4_tuple_match_skb_tuple(&e->data.ipv4.new_tuple,
+							     s, true);
+
+	default:
+		return false;
+	}
+}
+
+static bool
+airoha_ppe_tuple_is_offload_candidate(const struct airoha_skb_ipv4_tuple *tuple)
+{
+	__be32 dst = cpu_to_be32(tuple->dst_ip);
+
+	if (ipv4_is_multicast(dst) ||
+	    ipv4_is_lbcast(dst) ||
+	    ipv4_is_zeronet(dst))
+		return false;
+
+	/* Local service discovery/control traffic is never a useful NAT offload
+	 * candidate and is very noisy on EN7523 while handling FOE_UNHIT.
+	 */
+	if (tuple->proto == IPPROTO_UDP &&
+	    (tuple->dst_port == 1900 || tuple->dst_port == 5351 ||
+	     tuple->src_port == 1900 || tuple->src_port == 5351))
+		return false;
+
+	return true;
+}
+
+static struct airoha_flow_table_entry *
+airoha_ppe_find_pending_flow_by_skb(struct airoha_ppe *ppe, struct sk_buff *skb)
+{
+	struct airoha_skb_ipv4_tuple tuple;
+	struct airoha_flow_table_entry *e;
+
+	if (!airoha_ppe_skb_find_ipv4_tuple(skb, &tuple))
+		return NULL;
