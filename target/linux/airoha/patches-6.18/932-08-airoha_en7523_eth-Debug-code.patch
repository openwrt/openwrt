+}
+
+static void en7523_pcs_pon_hsgmii_phy_init(struct en7523_pcs_port *port,
+					      phy_interface_t interface)
+{
+	struct en7523_pcs *priv = port->priv;
+	u32 phy1_cdr = 0, serdes0 = 0, sys0 = 0, hg_rst = 0;
+	u32 hg_mode = 0, pon_sts0 = 0;
+
+	if (priv->data->type != EN7523_PCS_PON)
+		return;
+
+	if (port->pon_hsgmii_phy_done)
+		return;
+
+	if (!port->pon_phy1 || !port->pon_phy2) {
+		dev_dbg(priv->dev,
+			"pon_hsgmii_phy_init: type=%s port=%u interface=%s missing pon-phy regmaps\n",
+			en7523_pcs_type_name(priv->data->type), port->index,
+			phy_modes(interface));
+		return;
+	}
+
+	dev_info(priv->dev,
+		 "pon_hsgmii_phy_init: type=%s port=%u interface=%s apply SDK PON HSGMII SerDes sequence\n",
+		 en7523_pcs_type_name(priv->data->type), port->index,
+		 phy_modes(interface));
+
+	/* SDK: set_pon_phy_data(SS_LCPLL_TDC_FLT_2_ADDR, 0x64000000) */
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_LCPLL_TDC_FLT_2,
+		     0x64000000);
+
+	/* SDK PON/HSGMII SerDes setup. */
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_SERDES_CTRL_10,
+		     0x00000103);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_FRQ_CTRL_2,
+		     0x00003003);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_FRQ_CTRL_4,
+		     0x15601560);
+	regmap_write(port->pon_phy1, EN7523_PON_PHY1_CDR_PD_DIV_BYPASS,
+		     0x18001722);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_SYS_CTRL_0,
+		     0x250003c0);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_HG_RST_CTRL_0,
+		     0x0000003f);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_DA_CTRL_2,
+		     0x54101801);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_RXFEDIG_CTRL_12,
+		     0x00380013);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_OSR_SEL_CTRL,
+		     0x00000011);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_HG_MODE_CTRL_0,
+		     0x00000001);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_SYS_CTRL_0,
+		     0x240003c0);
+
+	/* SDK LCPLL toggle. */
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_LCPLL_TDC_FLT_5,
+		     0x00010100);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_LCPLL_TDC_FLT_3,
+		     0x20000100);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_LCPLL_TDC_FLT_5,
+		     0x01010100);
+	regmap_write(port->pon_phy2, EN7523_PON_PHY2_SERDES_CTRL_0,
+		     0x00100381);
+
+	if (port->an)
+		regmap_write(port->an, AIROHA_PCS_HSGMII_AN_SGMII_REG_AN_0,
+			     0x00000140);
+
+	regmap_read(port->pon_phy1, EN7523_PON_PHY1_CDR_PD_DIV_BYPASS,
+		    &phy1_cdr);
+	regmap_read(port->pon_phy2, EN7523_PON_PHY2_SERDES_CTRL_0, &serdes0);
+	regmap_read(port->pon_phy2, EN7523_PON_PHY2_SYS_CTRL_0, &sys0);
+	regmap_read(port->pon_phy2, EN7523_PON_PHY2_HG_RST_CTRL_0, &hg_rst);
+	regmap_read(port->pon_phy2, EN7523_PON_PHY2_HG_MODE_CTRL_0, &hg_mode);
+	regmap_read(port->pon_phy2, EN7523_PON_PHY2_PON_STS_0, &pon_sts0);
+
+	dev_info(priv->dev,
+		 "pon_hsgmii_phy_init-done: type=%s port=%u phy1_cdr=%08x serdes0=%08x sys0=%08x hg_rst=%08x hg_mode=%08x pon_sts0=%08x\n",
+		 en7523_pcs_type_name(priv->data->type), port->index,
+		 phy1_cdr, serdes0, sys0, hg_rst, hg_mode, pon_sts0);
+
+	port->pon_hsgmii_phy_done = true;
 }
 
 static void en7523_pcs_setup_scu(struct en7523_pcs_port *port,
@@ -141,63 +393,129 @@ static void en7523_pcs_setup_scu(struct en7523_pcs_port *port,
 {
 	struct en7523_pcs *priv = port->priv;
 	const struct en7523_pcs_res *res = &priv->data->res[port->index];
+	u32 ssr3_before = 0, ssr3_after = 0, wan_before = 0, wan_after = 0;
+
+	regmap_read(priv->scu, EN7523_SCU_SSR3, &ssr3_before);
+	regmap_read(priv->scu, EN7523_SCU_WAN_CONF, &wan_before);
 
 	if (res->setup_pon) {
+		u32 wan_val;
+
 		regmap_update_bits(priv->scu, EN7523_SCU_SSR3,
 				   EN7523_SCU_SSR3_PON_MODE,
 				   EN7523_SCU_SSR3_PON_SGMII);
-		regmap_write(priv->scu, EN7523_SCU_WAN_CONF,
-			     EN7523_WAN_CONF_SGMII);
+
+		/*
+		 * The SDK PON SerDes sequence uses WAN_CONF bit0 set
+		 * (0xe0000011).  Keep it set even when phylink later
+		 * switches copper SFP modules from 2500base-x to 1000base-x;
+		 * otherwise the PON/AE path keeps PCS/XSI activity but never
+		 * completes in-band link.
+		 */
+		wan_val = EN7523_WAN_CONF_HSGMII;
+		regmap_write(priv->scu, EN7523_SCU_WAN_CONF, wan_val);
+
+		en7523_pcs_pon_hsgmii_phy_init(port, interface);
+
+		regmap_read(priv->scu, EN7523_SCU_SSR3, &ssr3_after);
+		regmap_read(priv->scu, EN7523_SCU_WAN_CONF, &wan_after);
+		dev_info(priv->dev,
+			 "setup_scu: type=%s port=%u interface=%s PON SGMII wan_val=%08x ssr3 %08x->%08x wan_conf %08x->%08x\n",
+			 en7523_pcs_type_name(priv->data->type), port->index,
+			 phy_modes(interface), wan_val, ssr3_before, ssr3_after,
+			 wan_before, wan_after);
 		return;
 	}
 
 	if (res->ssr3_clear)
 		regmap_clear_bits(priv->scu, EN7523_SCU_SSR3, res->ssr3_clear);
+
+	regmap_read(priv->scu, EN7523_SCU_SSR3, &ssr3_after);
+	regmap_read(priv->scu, EN7523_SCU_WAN_CONF, &wan_after);
+	dev_info(priv->dev,
+		 "setup_scu: type=%s port=%u interface=%s ssr3_clear=%08x ssr3 %08x->%08x wan_conf %08x->%08x\n",
+		 en7523_pcs_type_name(priv->data->type), port->index,
+		 phy_modes(interface), res->ssr3_clear, ssr3_before,
+		 ssr3_after, wan_before, wan_after);
 }
 
 static int en7523_pcs_set_phya_mode(struct en7523_pcs_port *port,
 					    phy_interface_t interface)
 {
-	u32 val;
+	u32 before = 0, after = 0, val;
+	int ret;
 
-	if (!port->phya)
+	if (!port->phya) {
+		dev_dbg(port->priv->dev,
+			"set_phya_mode: type=%s port=%u interface=%s no PHYA regmap\n",
+			en7523_pcs_type_name(port->priv->data->type), port->index,
+			phy_modes(interface));
 		return 0;
+	}
 
 	val = (interface == PHY_INTERFACE_MODE_2500BASEX) ? 0x14817 : 0x14813;
+	regmap_read(port->phya, AIROHA_PCS_HSGMII_ANA_SGMII_PHYA_11, &before);
+	ret = regmap_write(port->phya, AIROHA_PCS_HSGMII_ANA_SGMII_PHYA_11,
+				   val);
+	regmap_read(port->phya, AIROHA_PCS_HSGMII_ANA_SGMII_PHYA_11, &after);
+
+	dev_info(port->priv->dev,
+		 "set_phya_mode: type=%s port=%u interface=%s phya11 %08x->%08x target=%08x ret=%d\n",
+		 en7523_pcs_type_name(port->priv->data->type), port->index,
+		 phy_modes(interface), before, after, val, ret);
 
-	return regmap_write(port->phya, AIROHA_PCS_HSGMII_ANA_SGMII_PHYA_11,
-				 val);
+	return ret;
 }
 
 static unsigned int en7523_pcs_inband_caps(struct phylink_pcs *pcs,
 						  phy_interface_t interface)
