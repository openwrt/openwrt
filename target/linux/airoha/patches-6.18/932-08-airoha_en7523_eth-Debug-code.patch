 #define EN7523_SCU_SSR3_PCIE0_HSGMII_DIS	BIT(31)
 #define EN7523_SCU_SSR3_PCIE1_HSGMII_DIS	BIT(30)
-#define EN7523_SCU_SSR3_USB0_HSGMII_DIS	BIT(29)
+#define EN7523_SCU_SSR3_USB0_HSGMII_DIS		BIT(29)
 #define EN7523_SCU_SSR3_PON_MODE		GENMASK(14, 13)
 #define EN7523_SCU_SSR3_PON_SGMII		FIELD_PREP_CONST(EN7523_SCU_SSR3_PON_MODE, 0x2)
 
 #define EN7523_WAN_CONF_SGMII			0xe0000010
+#define EN7523_WAN_CONF_HSGMII			0xe0000011
+#define EN7523_PON_PCS_STATE_ACTIVE		GENMASK(19, 16)
+
+/* Vendor DTS ecnt-xsi blocks: AE=0x1fa60000, PCIE0=0x1fa70000, PCIE1=0x1fa71000, USB=0x1fa80000.
+ * These are the same resources already used as pcs-mac/pcs-mac0/pcs-mac1. */
+#define EN7523_XSI_GLB_CFG			0x00
+#define EN7523_XSI_INT_STS			0x04
+#define EN7523_XSI_INT_EN			0x08
+#define EN7523_XSI_MAC_LOGIC_RST		0x10
+#define EN7523_XSI_FAULT_STS			0x80
+#define EN7523_XSI_PRB_OUTH			0xc4
+#define EN7523_XSI_PRB_OUTL			0xc8
+#define EN7523_XSI_IF_STS			0xcc
+
+/* PON SerDes/PHY init sequence from SDK sgmii_api_pon0_force_hsgmii().
+ * The SDK exposes these as absolute addresses below PON_CSR_PMA_BASE
+ * (0x1faf0000).  In this driver they are split by DTS resources:
+ *  - pon-phy0: 0x1faf0000
+ *  - pon-phy1: 0x1faf3000
+ *  - pon-phy2: 0x1faf4000
+ */
+#define EN7523_PON_PHY1_CDR_PD_DIV_BYPASS	0x028
+#define EN7523_PON_PHY2_LCPLL_TDC_FLT_2		0x130
+#define EN7523_PON_PHY2_LCPLL_TDC_FLT_3		0x134
+#define EN7523_PON_PHY2_LCPLL_TDC_FLT_5		0x13c
+#define EN7523_PON_PHY2_SERDES_CTRL_0		0x200
+#define EN7523_PON_PHY2_SERDES_CTRL_10		0x228
+#define EN7523_PON_PHY2_SYS_CTRL_0		0x300
+#define EN7523_PON_PHY2_HG_RST_CTRL_0		0x310
+#define EN7523_PON_PHY2_HG_MODE_CTRL_0		0x314
+#define EN7523_PON_PHY2_PON_STS_0		0x31c
+#define EN7523_PON_PHY2_OSR_SEL_CTRL		0x320
+#define EN7523_PON_PHY2_FRQ_CTRL_2		0x364
+#define EN7523_PON_PHY2_FRQ_CTRL_4		0x36c
+#define EN7523_PON_PHY2_RXFEDIG_CTRL_12		0x530
+#define EN7523_PON_PHY2_DA_CTRL_2		0x608
 
 enum en7523_pcs_type {
 	EN7523_PCS_PON,
@@ -50,6 +86,10 @@ struct en7523_pcs_res {
 	unsigned int an;
 	unsigned int ra;
 	unsigned int phya;
+	unsigned int xsi;
+	unsigned int pon_phy0;
+	unsigned int pon_phy1;
+	unsigned int pon_phy2;
 	u32 ssr3_clear;
 	bool setup_pon;
 };
@@ -71,8 +111,21 @@ struct en7523_pcs_port {
 	struct regmap *an;
 	struct regmap *ra;
 	struct regmap *phya;
+	struct regmap *xsi;
+	struct regmap *pon_phy0;
+	struct regmap *pon_phy1;
+	struct regmap *pon_phy2;
 	phy_interface_t interface;
+	phy_interface_t last_state_interface;
 	unsigned int index;
+	int last_speed;
+	int last_duplex;
+	int last_pause;
+	bool last_state_valid;
+	bool last_link;
