 };
 
 struct en7523_pcs {
@@ -88,19 +141,129 @@ static struct en7523_pcs_port *to_en7523_pcs_port(struct phylink_pcs *pcs)
 	return container_of(pcs, struct en7523_pcs_port, pcs);
 }
 
+static const char *en7523_pcs_type_name(enum en7523_pcs_type type)
+{
+	switch (type) {
+	case EN7523_PCS_PON:
+		return "pon";
+	case EN7523_PCS_PCIE:
+		return "pcie";
+	case EN7523_PCS_USB:
+		return "usb";
+	default:
+		return "unknown";
+	}
+}
+
+static const char *en7523_pcs_neg_mode_name(unsigned int neg_mode)
+{
+	if (neg_mode == PHYLINK_PCS_NEG_INBAND_ENABLED)
+		return "inband-enabled";
+	if (neg_mode & PHYLINK_PCS_NEG_INBAND)
+		return "inband-disabled";
+	return "outband/none";
+}
+
+static void en7523_pcs_dbg_dump_regs(struct en7523_pcs_port *port,
+				     const char *tag)
+{
+	struct en7523_pcs *priv = port->priv;
+	u32 ssr3 = 0, wan_conf = 0;
+	u32 an0 = 0, an1 = 0, an4 = 0, an5 = 0, an11 = 0, an13 = 0;
+	u32 pcs_ctl1 = 0, pcs_ctl3 = 0, pcs_ctl6 = 0, pcs_sts2 = 0;
+	u32 pcs_mode_force = 0, ra0 = 0, phya11 = 0;
+	u32 xsi_glb = 0, xsi_int_sts = 0, xsi_int_en = 0;
+	u32 xsi_logic_rst = 0, xsi_fault = 0, xsi_if_sts = 0;
+	u32 xsi_prb_h = 0, xsi_prb_l = 0;
+
+	if (priv->scu) {
+		regmap_read(priv->scu, EN7523_SCU_SSR3, &ssr3);
+		regmap_read(priv->scu, EN7523_SCU_WAN_CONF, &wan_conf);
+	}
+
+	if (port->an) {
+		regmap_read(port->an, AIROHA_PCS_HSGMII_AN_SGMII_REG_AN_0, &an0);
+		regmap_read(port->an, AIROHA_PCS_HSGMII_AN_SGMII_REG_AN_1, &an1);
+		regmap_read(port->an, AIROHA_PCS_HSGMII_AN_SGMII_REG_AN_4, &an4);
+		regmap_read(port->an, AIROHA_PCS_HSGMII_AN_SGMII_REG_AN_5, &an5);
+		regmap_read(port->an, AIROHA_PCS_HSGMII_AN_SGMII_REG_AN_11, &an11);
+		regmap_read(port->an, AIROHA_PCS_HSGMII_AN_SGMII_REG_AN_13, &an13);
+	}
+
+	if (port->pcs2) {
+		regmap_read(port->pcs2, AIROHA_PCS_HSGMII_PCS_CTROL_1, &pcs_ctl1);
+		regmap_read(port->pcs2, AIROHA_PCS_HSGMII_PCS_CTROL_3, &pcs_ctl3);
+		regmap_read(port->pcs2, AIROHA_PCS_HSGMII_PCS_CTROL_6, &pcs_ctl6);
+		regmap_read(port->pcs2, ARIOHA_PCS_HSGMII_PCS_STATE_2, &pcs_sts2);
+
+		/* The PON PCS2 layout does not implement this offset; reading it
+		 * returns the bus/debug poison value 0xdeadbeef. Keep it out of
+		 * the PON dump to avoid treating it as hardware state.
+		 */
+		if (priv->data->type != EN7523_PCS_PON)
+			regmap_read(port->pcs2,
+				    AIROHA_PCS_HSGMII_PCS_AN_SGMII_MODE_FORCE,
+				    &pcs_mode_force);
+	}
+
+	if (port->ra)
+		regmap_read(port->ra, AIROHA_PCS_HSGMII_RATE_ADAPT_CTRL_0, &ra0);
+
+	if (port->phya)
+		regmap_read(port->phya, AIROHA_PCS_HSGMII_ANA_SGMII_PHYA_11,
+			    &phya11);
+
+	if (port->xsi) {
+		regmap_read(port->xsi, EN7523_XSI_GLB_CFG, &xsi_glb);
+		regmap_read(port->xsi, EN7523_XSI_INT_STS, &xsi_int_sts);
+		regmap_read(port->xsi, EN7523_XSI_INT_EN, &xsi_int_en);
+		regmap_read(port->xsi, EN7523_XSI_MAC_LOGIC_RST, &xsi_logic_rst);
+		regmap_read(port->xsi, EN7523_XSI_FAULT_STS, &xsi_fault);
+		regmap_read(port->xsi, EN7523_XSI_PRB_OUTH, &xsi_prb_h);
+		regmap_read(port->xsi, EN7523_XSI_PRB_OUTL, &xsi_prb_l);
+		regmap_read(port->xsi, EN7523_XSI_IF_STS, &xsi_if_sts);
+	}
+
+	if (priv->data->type == EN7523_PCS_PON)
+		dev_info(priv->dev,
+			 "%s: type=%s port=%u cached_interface=%s ssr3=%08x wan_conf=%08x an0=%08x an1=%08x an4=%08x an5=%08x an11=%08x an13=%08x pcs_ctl1=%08x pcs_ctl3=%08x pcs_ctl6=%08x pcs_sts2=%08x pcs_mode_force=n/a ra0=%08x phya11=%08x xsi_glb=%08x xsi_int_sts=%08x xsi_int_en=%08x xsi_logic_rst=%08x xsi_fault=%08x xsi_prb_h=%08x xsi_prb_l=%08x xsi_if_sts=%08x\n",
+			 tag, en7523_pcs_type_name(priv->data->type), port->index,
+			 phy_modes(port->interface), ssr3, wan_conf, an0, an1, an4,
+			 an5, an11, an13, pcs_ctl1, pcs_ctl3, pcs_ctl6,
+			 pcs_sts2, ra0, phya11, xsi_glb, xsi_int_sts,
+			 xsi_int_en, xsi_logic_rst, xsi_fault, xsi_prb_h,
+			 xsi_prb_l, xsi_if_sts);
+	else
+		dev_info(priv->dev,
+			 "%s: type=%s port=%u cached_interface=%s ssr3=%08x wan_conf=%08x an0=%08x an1=%08x an4=%08x an5=%08x an11=%08x an13=%08x pcs_ctl1=%08x pcs_ctl3=%08x pcs_ctl6=%08x pcs_sts2=%08x pcs_mode_force=%08x ra0=%08x phya11=%08x xsi_glb=%08x xsi_int_sts=%08x xsi_int_en=%08x xsi_logic_rst=%08x xsi_fault=%08x xsi_prb_h=%08x xsi_prb_l=%08x xsi_if_sts=%08x\n",
+			 tag, en7523_pcs_type_name(priv->data->type), port->index,
+			 phy_modes(port->interface), ssr3, wan_conf, an0, an1, an4,
+			 an5, an11, an13, pcs_ctl1, pcs_ctl3, pcs_ctl6,
+			 pcs_sts2, pcs_mode_force, ra0, phya11, xsi_glb,
+			 xsi_int_sts, xsi_int_en, xsi_logic_rst, xsi_fault,
+			 xsi_prb_h, xsi_prb_l, xsi_if_sts);
+}
+
