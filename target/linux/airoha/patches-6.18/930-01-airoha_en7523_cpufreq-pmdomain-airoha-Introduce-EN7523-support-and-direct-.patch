+	/* apply changes */
+	old_chg = readl(base + priv->scu_data->cpupll_pcw_chg);
+	if (old_chg & priv->scu_data->chg_bit)
+		writel(old_chg & ~priv->scu_data->chg_bit, base + priv->scu_data->cpupll_pcw_chg);
