 static const char * const airoha_cpufreq_clk_names[] = { "cpu", NULL };
-static const char * const airoha_cpufreq_pd_names[] = { "perf" };
+static const char * const airoha_cpufreq_pd_names[] = { "perf", NULL };
 
 static int airoha_cpufreq_probe(struct platform_device *pdev)
 {
-	const struct dev_pm_domain_attach_data attach_data = {
-		.pd_names = airoha_cpufreq_pd_names,
-		.num_pd_names = ARRAY_SIZE(airoha_cpufreq_pd_names),
-		.pd_flags = PD_FLAG_DEV_LINK_ON | PD_FLAG_REQUIRED_OPP,
-	};
-	struct dev_pm_opp_config config = {
-		.clk_names = airoha_cpufreq_clk_names,
-		.config_clks = airoha_cpufreq_config_clks_nop,
-	};
 	struct platform_device *cpufreq_dt;
 	struct airoha_cpufreq_priv *priv;
 	struct device *dev = &pdev->dev;
 	struct device *cpu_dev;
-	int ret;
+	struct dev_pm_opp_config config = {
+		.clk_names = airoha_cpufreq_clk_names,
+		.config_clks = airoha_cpufreq_config_clks_nop,
+	};
+	int ret, i, num_devs;
 
 	/* CPUs refer to the same OPP table */
 	cpu_dev = get_cpu_device(0);
@@ -62,17 +58,66 @@ static int airoha_cpufreq_probe(struct platform_device *pdev)
 	if (priv->opp_token < 0)
 		return dev_err_probe(dev, priv->opp_token, "Failed to set OPP config\n");
 
-	/* Attach PM for OPP */
-	ret = dev_pm_domain_attach_list(cpu_dev, &attach_data,
-					&priv->pd_list);
-	if (ret)
-		goto clear_opp_config;
+	/* Count power domains */
+	num_devs = 0;
+	while (airoha_cpufreq_pd_names[num_devs])
+		num_devs++;
+
+	/* Manually attach genpd devices */
+	if (num_devs > 0) {
+		struct device **virt_devs;
+
+		virt_devs = devm_kcalloc(dev, num_devs, sizeof(*virt_devs), GFP_KERNEL);
+		if (!virt_devs) {
+			ret = -ENOMEM;
+			goto err_clear_opp_config;
+		}
+
+		/* Attach each genpd domain */
+		for (i = 0; i < num_devs; i++) {
+			virt_devs[i] = dev_pm_domain_attach_by_name(cpu_dev, 
+								     airoha_cpufreq_pd_names[i]);
+			if (IS_ERR_OR_NULL(virt_devs[i])) {
+				ret = PTR_ERR(virt_devs[i]) ? : -ENODEV;
+				dev_err(dev, "failed to attach %s: %d\n",
+					airoha_cpufreq_pd_names[i], ret);
+
+				/* Detach previously attached domains */
+				while (--i >= 0)
+					dev_pm_domain_detach(virt_devs[i], false);
+
+				goto err_clear_opp_config;
+			}
+		}
+
+		/* Resume all virtual devices for OPP ACTIVE */
+		for (i = 0; i < num_devs; i++) {
+			ret = pm_runtime_resume_and_get(virt_devs[i]);
+			if (ret) {
+				dev_err(dev, "failed to resume %s: %d\n",
+					airoha_cpufreq_pd_names[i], ret);
+
+				/* Rollback previous PM runtime calls and detach domains */
+				while (--i >= 0)
+					pm_runtime_put(virt_devs[i]);
+
+				/* Detach all domains */
+				for (i = 0; i < num_devs; i++)
+					dev_pm_domain_detach(virt_devs[i], false);
+
+				goto err_clear_opp_config;
+			}
+		}
+
+		priv->virt_devs = virt_devs;
+		priv->num_virt_devs = num_devs;
+	}
 
 	cpufreq_dt = platform_device_register_simple("cpufreq-dt", -1, NULL, 0);
 	ret = PTR_ERR_OR_ZERO(cpufreq_dt);
 	if (ret) {
 		dev_err(dev, "failed to create cpufreq-dt device: %d\n", ret);
-		goto detach_pm;
+		goto err_register_cpufreq;
 	}
 
 	priv->cpufreq_dt = cpufreq_dt;
@@ -80,9 +125,15 @@ static int airoha_cpufreq_probe(struct platform_device *pdev)
 
 	return 0;
 
-detach_pm:
-	dev_pm_domain_detach_list(priv->pd_list);
-clear_opp_config:
+err_register_cpufreq:
+	if (priv->virt_devs) {
+		for (i = 0; i < priv->num_virt_devs; i++) {
+			pm_runtime_put(priv->virt_devs[i]);
+			dev_pm_domain_detach(priv->virt_devs[i], false);
+		}
+	}
+
+err_clear_opp_config:
 	dev_pm_opp_clear_config(priv->opp_token);
 
 	return ret;
@@ -91,12 +142,18 @@ static int airoha_cpufreq_probe(struct platform_device *pdev)
 static void airoha_cpufreq_remove(struct platform_device *pdev)
 {
 	struct airoha_cpufreq_priv *priv = platform_get_drvdata(pdev);
+	int i;
 
 	platform_device_unregister(priv->cpufreq_dt);
 
-	dev_pm_domain_detach_list(priv->pd_list);
-
 	dev_pm_opp_clear_config(priv->opp_token);
+
+	if (priv->virt_devs) {
+		for (i = 0; i < priv->num_virt_devs; i++) {
+			pm_runtime_put(priv->virt_devs[i]);
+			dev_pm_domain_detach(priv->virt_devs[i], false);
+		}
+	}
 }
 
 static struct platform_driver airoha_cpufreq_driver = {
@@ -108,8 +165,9 @@ static struct platform_driver airoha_cpufreq_driver = {
 };
 
 static const struct of_device_id airoha_cpufreq_match_list[] __initconst = {
+	{ .compatible = "airoha,an7581" },
 	{ .compatible = "airoha,an7583" },
-	{ .compatible = "airoha,en7581" },
+	{ .compatible = "airoha,en7523" },
 	{},
 };
 MODULE_DEVICE_TABLE(of, airoha_cpufreq_match_list);
