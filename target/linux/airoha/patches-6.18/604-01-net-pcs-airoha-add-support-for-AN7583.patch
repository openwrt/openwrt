+static int an7583_pcs_bringup(struct airoha_pcs_priv *priv,
+			      phy_interface_t interface)
+{
+	int err;
+
+	an7583_pcs_dig_reset_hold(priv);
+
+	an7583_pcs_phya_bringup(priv, interface);
+	an7583_pcs_phyd_bringup(priv, interface);
+
+	an7583_pcs_dig_reset_release(priv);
+
+	/* Check for PLL Lock */
+	err = regmap_read_poll_timeout(priv->xfi_pma, AIROHA_PCS_PMA_SS_RX_FREQ_DET_4,
+				       err, (err & AIROHA_PCS_PMA_FREQLOCK_DET_EN),
+				       2000, 300000);
+	if (err)
+		dev_err(priv->dev, "PLL not Locked\n");
+
+	return err;
+}
+
+static int airoha_pcs_config(struct phylink_pcs *pcs, unsigned int neg_mode,
+			     phy_interface_t interface,
+			     const unsigned long *advertising,
+			     bool permit_pause_to_mac)
+{
+	struct airoha_pcs_priv *priv = phylink_pcs_to_airoha_pcs_port(pcs);
+	int ret;
+
+	ret = airoha_pcs_setup_scu(priv, interface);
+	if (ret)
+		return ret;
+
+	airoha_pcs_init(priv, interface);
+
+	if (priv->interface != interface) {
+		priv->interface = interface;
+
+		if (priv->data->bringup) {
+			ret = priv->data->bringup(priv, interface);
+			if (ret)
+				return ret;
+		}
+	}
+
+	airoha_pcs_interrupt_init(priv, interface);
 
 	return 0;
 }
