#include "en7523-tplink_xx230v_v1.dts"

/ {
	model = "TP-Link XX530V v1";
	compatible = "tplink,xx530v-v1", "airoha,en7523";
};

/* xx530v v1
	0x000000000000-0x000004a00000 : "whole"
	0x000000000000-0x000000080000 : "boot"
	0x000000080000-0x0000000a0000 : "romfile"
	0x0000000a0000-0x0000002a0000 : "misc"
	0x0000002a0000-0x000002500000 : "firmware"
	0x000002500000-0x000004760000 : "firmware_slave"
	0x0000049e0000-0x000004a00000 : "reserve"
*/
&nand {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

    partition@0 {
      label = "uboot-atf";
      reg = <0x00000000 0x00080000>;
      read-only;
    };

		partition@1 {
			label = "romfile";
			reg = <0x80000 0xa0000>;
			read-only;
		};

		partition@2 {
			label = "misc";
			reg = <0x0a0000 0x200000>;
			read-only;

			nvmem-layout {
				compatible = "fixed-layout";
				#address-cells = <1>;
				#size-cells = <1>;

				macaddr: macaddr@4f100 {
					#nvmem-cell-cells = <1>;
					compatible = "mac-base";
					reg = <0x4f100 0x6>;
				};

				eeprom0: eeprom@80000 {
					reg = <0x80000 0x1000>;
				};

				en7571_bob: en7571_bob@c0000 {
					reg = <0xc0000 0xff>;
				};
			};
		};

		// Fist 512 have header of kernel
		// flash write 0x02a0000 0x$filesize $loadaddr
		partition@3 {
			label = "firmware";
			reg = <0x02a0000 0x7360000>;
		};

		partition@4 {
			label = "kernel";
			reg = <0x02a0000 0x1000000>;
		};

		partition@5 {
			label = "rootfs";
			reg = <0x12a0000 0x6360000>;
		};

		/* reserved for bad block table */
		partition@6 {
			label = "reserved_bmt";
			reg = <0x7600000 0x0b00000>;
			read-only;
		};
	};
};

&xpon_phy {
	nvmem-cells = <&en7571_bob>;
	nvmem-cell-names = "phy-bob";
};

&xpon {
	nvmem-cells = <&macaddr 0>;
	nvmem-cell-names = "mac-address";
	pon,sn = "TPLG";
};

&mt76 {
	nvmem-cells = <&eeprom0>;
	nvmem-cell-names = "eeprom";

	// 2.4 GHz
	band@0 {
		nvmem-cells = <&macaddr 0>;
		nvmem-cell-names = "mac-address";
	};

	// 5 GHz
	band@1 {
		nvmem-cells = <&macaddr 2>;
		nvmem-cell-names = "mac-address";
	};
};

&gdm1 {
	nvmem-cells = <&macaddr 0>;
	nvmem-cell-names = "mac-address";
};

&switch {
	ports {
		port@6 {
			nvmem-cells = <&macaddr 0>;
			nvmem-cell-names = "mac-address";
		};
	};
};