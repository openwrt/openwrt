/dts-v1/;

/* Bootloader installs ATF here */
/memreserve/ 0x80000000 0x200000;

#include <dt-bindings/leds/common.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include "en7523.dtsi"

/ {
	model = "TP-Link xx230v";
	compatible = "tplink,xx230v", "airoha,en7523";

	chosen {
		bootargs = "console=ttyS0,115200 earlycon";
		stdout-path = "serial0:115200n8";
	};

	aliases {
		serial0 = &uart1;
		led-boot = &led_power;
		led-failsafe = &led_power;
		led-upgrade = &led_power;
		led-running = &led_power;
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 0x40000000>;
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
		};

		wps {
			label = "wps";
			linux,code = <KEY_WPS_BUTTON>;
			gpios = <&gpio0 7 GPIO_ACTIVE_LOW>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_power: power {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <0>;
			gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
		};

		xpon {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <0>;
			gpios = <&gpio0 10 GPIO_ACTIVE_LOW>;
		};

		los {
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <1>;
			gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
		};

		internet {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <0>;
			gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;
		};

		wifi {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WLAN;
			function-enumerator = <0>;
			gpios = <&gpio0 6 GPIO_ACTIVE_LOW>;
		};

		fxs {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <0>;
			gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>;
		};

		lan1 {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <0>;
			gpios = <&gpio0 22 GPIO_ACTIVE_LOW>;
		};

		lan2 {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <0>;
			gpios = <&gpio0 23 GPIO_ACTIVE_LOW>;
		};

		lan3 {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <0>;
			gpios = <&gpio0 24 GPIO_ACTIVE_LOW>;
		};

		wan {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WAN;
			function-enumerator = <0>;
			gpios = <&gpio0 25 GPIO_ACTIVE_LOW>;
		};
	};
};

&nand {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		// partition@0 {
		// 	label = "u-boot";
		// 	reg = <0x0 0x7C000>;
		// 	read-only;
		// };

		// partition@7C000 {
		// 	label = "u-boot-env";
		// 	reg = <0x7C000 0x4000>;
		// };

		partition@0 {
			label = "u-boot";
			reg = <0x0 0x60000>;
			read-only;
		};

		partition@60000 {
			label = "u-boot-env";
			reg = <0x60000 0x20000>;
		};

		partition@80000 {
			label = "romfile";
			reg = <0x80000 0xa0000>;
			read-only;
		};

		partition@a0000 {
			label = "misc";
			reg = <0x0a0000 0x1a0000>;
			read-only;

			nvmem-layout {
				compatible = "fixed-layout";
				#address-cells = <1>;
				#size-cells = <1>;

				eeprom0: eeprom@80000 {
					reg = <0x80000 0xe00>;
				};

				switch_macaddr: macaddr@4f1e0 {
					compatible = "mac-base";
					reg = <0x4f1e0 0x6>;
					#nvmem-cell-cells = <1>;
				};

				wifi_macaddr: macaddr@4f100 {
					compatible = "mac-base";
					reg = <0x4f100 0x6>;
					#nvmem-cell-cells = <1>;
				};
			};
		};

		partition@1a0000 {
			label = "firmware";
			reg = <0x01a0000 0x2000000>;
		};

		partition@200000 {
			label = "firmware_slave";
			reg = <0x2000000 0x3e60000>;
			read-only;
		};

		partition@3fe0000 {
			label = "reserve";
			reg = <0x3fe0000 0x4000000>;
			read-only;
		};
	};
};

&pcie0 {
	status = "okay";
};

&pcie1 {
	status = "okay";

	pcie@1,0 {
		reg = <0x00000800 0 0 0 0>;
		#address-cells = <3>;
		#size-cells = <2>;

		mt7915@0,0 {
			reg = <0x0000 0 0 0 0>;
			#address-cells = <1>;
			#size-cells = <0>;
			nvmem-cells = <&eeprom0>;
			nvmem-cell-names = "eeprom";

			// 2.4 GHz
			band@0 {
				reg = <0>;
				nvmem-cells = <&wifi_macaddr 0>;
				nvmem-cell-names = "mac-address";
			};

			// 5 GHz
			band@1 {
				reg = <1>;
				nvmem-cells = <&wifi_macaddr 2>;
				nvmem-cell-names = "mac-address";
			};
		};
	};
};