spi@1fa10000 {
	compatible = "econet,spi";
	reg = <0x1fa10000 0x140>;
	interrupts = <0x00 0x33 0x04>;
	spi-sw-a = <0x01>;

	spi-nand@0 {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		reg = <0x01>;
		use-default-sizes;
		spi-max-frequency = <0x17d7840>;
		compatible = "spi-nand";
	};

	m25p80@0 {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		reg = <0x00>;
		use-default-sizes;
		spi-max-frequency = <0x17d7840>;
		compatible = "m25p80";

		partition@0 {
			reg = <0x00 0x100000>;
			label = "RouterBoot";
		};
	};
};
*/

/* GigaDevice 25Q80ESIG - RouterBOOT */
&spi0 {
	compatible = "m25p80";
	partition@0 {
		reg = <0x00 0x100000>;
		label = "RouterBoot";

		compatible = "mikrotik,routerboot-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		hard_config {
			read-only;

			nvmem-layout {
				compatible = "mikrotik,routerboot-nvmem";
				macaddr: base-mac-address {
					#nvmem-cell-cells = <1>;
				};
			};
		};

		soft_config {};
	};
};

/* Winbond 25N01KVZEIR */
&nand {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		partition@0 {
			label = "firmware";
			reg = <0x0 0x8000000>;
		};
	};
};

&usb0 {
	status = "okay";
};

&i2c0 {
	status = "okay";
};

