/dts-v1/;

#include <dt-bindings/leds/common.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include "en7523.dtsi"

/ {
	model = "MikroTik E60iUGS (hEX S 2025)";
	compatible = "mikrotik,e60iugs", "airoha,en7523";

	chosen {
		bootargs = "console=ttyS0,115200 earlycon";
		stdout-path = "serial0:115200n8";
	};

	aliases {
		serial0 = &uart1;
		led-boot = &led_power;
		led-failsafe = &led_power;
		led-upgrade = &led_power;
		led-running = &led_power;
	};

	keys {
		compatible = "gpio-keys-polled";
		poll-interval = <100>;

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
			gpios = <&pinctrl 11 GPIO_ACTIVE_LOW>;
		};

		mode {
			label = "mode";
			linux,code = <KEY_MODE>;
			debounce-interval = <60>;
			gpios = <&pinctrl 15 GPIO_ACTIVE_LOW>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_power: led@0 {
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <0>;
			gpios = <&pinctrl 0 GPIO_ACTIVE_HIGH>;
		};

		// usb-power-off
		led@3 {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <3>;
			gpios = <&pinctrl 3 GPIO_ACTIVE_LOW>;
		};

		// sfp1
		led@12 {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			function-enumerator = <12>;
			gpios = <&pinctrl 12 GPIO_ACTIVE_LOW>;
		};
	};

	sfp: sfp {
		compatible = "sff,sfp";

		i2c-bus = <&i2c0>;
		module-present-gpios = <&pinctrl 27 GPIO_ACTIVE_LOW>;
		tx-fault-gpios = <&pinctrl 17 GPIO_ACTIVE_HIGH>;
		rx-lose-gpios = <&pinctrl 19 GPIO_ACTIVE_HIGH>;
		tx-disable-gpios = <&pinctrl 20 GPIO_ACTIVE_HIGH>;
		rate-select-gpios = <&pinctrl 0 GPIO_ACTIVE_HIGH>;
		// maximum-power-milliwatt = <3000>;
	};

	spi-0 {
		compatible = "spi-gpio";

		gpio-sck = <&pinctrl 5 GPIO_ACTIVE_HIGH>;
		gpio-miso = <&pinctrl 7 GPIO_ACTIVE_HIGH>;
		gpio-mosi = <&pinctrl 6 GPIO_ACTIVE_HIGH>;
		cs-gpios = <&pinctrl 4 GPIO_ACTIVE_HIGH>;
		num-chipselects = <1>;
		#address-cells = <1>;
		#size-cells = <0>;

		ts@0 {
			compatible = "rb-spi-ts";
			spi-max-frequency = <1000000>;
			reg = <0>;
			va2-label = "system";
			temp-label = "board";
		};
	};

	poe-out-simple {
		compatible = "rb,poe-out-simple";
		// eth_port = <&eth1>;
		gpo_on = <&pinctrl 13 GPIO_ACTIVE_HIGH>;
		gpi_status = <&pinctrl 10 GPIO_ACTIVE_HIGH>;
		has_low_current_sense = <1>;
		status = "ok";
	};
};

&pinctrl {
	gpio-ranges = <&pinctrl 0 0 32>;
};

