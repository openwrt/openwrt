&eth {
	status = "okay";
};

&gdm1 {
	status = "okay";
	nvmem-cells = <&macaddr 1>;
	nvmem-cell-names = "mac-address";
};

&switch {
	status = "okay";
	ports {
		port@1 {
			label = "lan2";
			status = "okay";
			nvmem-cells = <&macaddr 1>;
			nvmem-cell-names = "mac-address";
		};

		port@2 {
			label = "lan3";
			status = "okay";
			nvmem-cells = <&macaddr 2>;
			nvmem-cell-names = "mac-address";
		};

		port@3 {
			label = "lan4";
			status = "okay";
			nvmem-cells = <&macaddr 3>;
			nvmem-cell-names = "mac-address";
		};

		port@4 {
			label = "lan5";
			status = "okay";
			nvmem-cells = <&macaddr 4>;
			nvmem-cell-names = "mac-address";
		};
	};

	mdio {
		ethernet-phy@9 {
			status = "okay";
			leds {
				led0@0 {
					status = "okay";
				};
			};
		};

		ethernet-phy@10 {
			status = "okay";
			leds {
				led0@0 {
					status = "okay";
				};
			};
		};

		ethernet-phy@11 {
			status = "okay";
			leds {
				led0@0 {
					status = "okay";
				};
			};
		};

		ethernet-phy@12 {
			status = "okay";
			leds {
				led0@0 {
					status = "okay";
				};
			};
		};
	};
};
