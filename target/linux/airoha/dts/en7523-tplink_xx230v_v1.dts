#include "en7523-tplink-xx230v_xx530v_v1.dtsi"

/ {
	model = "TP-Link XX230V v1";
	compatible = "tplink,xx230v-v1", "airoha,en7523";
};

/* xx230v v1
	0x000000000000-0x000004000000 : "whole"
	0x000000000000-0x000000080000 : "boot"
	0x000000080000-0x0000000a0000 : "romfile"
	0x0000000a0000-0x0000001a0000 : "misc"
	0x0000001a0000-0x000002000000 : "firmware"
	0x000002000000-0x000003e60000 : "firmware_slave"
	0x000003fe0000-0x000004000000 : "reserve"
*/
&nand {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		partition@0 {
			label = "uboot-atf";
			reg = <0x00000000 0x00080000>;
			read-only;
		};

		partition@1 {
			label = "romfile";
			reg = <0x80000 0xa0000>;
			read-only;
		};

		partition@2 {
			label = "misc";
			reg = <0x0a0000 0x1a0000>;
			read-only;

			nvmem-layout {
				compatible = "fixed-layout";
				#address-cells = <1>;
				#size-cells = <1>;

				macaddr: macaddr@4f100 {
					#nvmem-cell-cells = <1>;
					compatible = "mac-base";
					reg = <0x4f100 0x6>;
				};

				eeprom0: eeprom@80000 {
					reg = <0x80000 0x1000>;
				};

				en7571_bob: en7571_bob@c0000 {
					reg = <0xc0000 0xff>;
				};
			};
		};

		// Fist 512 have header of kernel
		// flash write 0x01a0000 0x$filesize $loadaddr
		partition@3 {
			label = "chainloader";
			reg = <0x01a0000 0x0100000>;
			read-only;
		};

		/*
		bootm 0x81800200

		## flash chainload and boot
		tftpboot $loadaddr 192.168.1.10:openwrt-airoha-en7523-tplink_xx230v_v1-chainload-uboot.bin && flash write 0x01a0000 0x$filesize $loadaddr && boot

		# Start initramfs
		tftpboot 0x86a00000 192.168.1.10:openwrt-airoha-en7523-tplink_xx230v_v1-initramfs-kernel.bin && bootm 0x86a00000

		ubi create fit
		tftpboot $loadaddr 192.168.1.10:openwrt-airoha-en7523-tplink_xx230v_v1-squashfs-sysupgrade.bin
		ubi write $loadaddr fit 0x$filesize
		*/
		partition@4 {
			reg = <0x02a0000 0x7260000>;
			label = "ubi";
			compatible = "linux,ubi";

			volumes {
				ubi-volume-ubootenv {
					volname = "ubootenv";
					nvmem-layout {
						compatible = "u-boot,env-redundant-bool";
					};
				};

				ubi-volume-ubootenv2 {
					volname = "ubootenv2";
					nvmem-layout {
						compatible = "u-boot,env-redundant-bool";
					};
				};

				ubi_firmware: ubi-volume-fit {
					volname = "fit";
				};
			};
		};

		/* reserved for bad block table */
		partition@5 {
			label = "reserved_bmt";
			reg = <0x7500000 0x0b00000>;
			read-only;
		};
	};
};

&mt76 {
	nvmem-cells = <&eeprom0>;
	nvmem-cell-names = "eeprom";

	// 2.4 GHz
	band@0 {
		nvmem-cells = <&macaddr 0>;
		nvmem-cell-names = "mac-address";
	};

	// 5 GHz
	band@1 {
		nvmem-cells = <&macaddr 2>;
		nvmem-cell-names = "mac-address";
	};
};

&gdm1 {
	nvmem-cells = <&macaddr 0>;
	nvmem-cell-names = "mac-address";
};

&switch {
	ports {
		port@6 {
			nvmem-cells = <&macaddr 0>;
			nvmem-cell-names = "mac-address";
		};
	};
};