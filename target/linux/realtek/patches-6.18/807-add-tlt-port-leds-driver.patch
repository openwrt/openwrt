+config LEDS_TLT_TSW202
+	tristate "LED support for TSW202 device"
+	depends on LEDS_CLASS
+	select GPIO_SUPPORT
+	select LEDS_TRIGGERS
+	help
+	  This option enables support for ETH/SFP port LED management for TSW202
+	  devices with additional centralized "master" control LED and specialized
+	  "hw" led-trigger.
+
 comment "LED Triggers"
 source "drivers/leds/trigger/Kconfig"
 
