+#ifdef CONFIG_SWIOTLB
+/* Provide platform SWIOTLB setup. The RTL9313 has no I/O Coherence Unit
+ * (confirmed: CM_present=1 NUMIOCU=0), so DMA from HIGHMEM pages corrupts
+ * via broken cache flush. SWIOTLB bounces such transfers through a small
+ * lowmem pool. Size controllable via swiotlb=N kernel cmdline (N = slabs
+ * of IO_TLB_SHIFT bytes each, default 2KB; e.g. swiotlb=1024 → 2MB). */
+void __init plat_swiotlb_setup(void)
+{
+	swiotlb_init(true, SWIOTLB_VERBOSE);
+}
+#endif
