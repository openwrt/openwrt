+static int realtek_request(struct gpio_chip *chip, unsigned gpio_pin)
+{
+	if (gpio_pin < chip->ngpio) {
+		struct realtek_gpio_ctrl *ctrl = gpiochip_get_data(chip);
+		unsigned long flags;
+		u32 reg;
+
+		raw_spin_lock_irqsave(&ctrl->lock, flags);
+		reg = ctrl->bank_read(ctrl->enable_reg);
+		reg |= BIT(gpio_pin);
+		ctrl->bank_write(ctrl->enable_reg, reg);
+		raw_spin_unlock_irqrestore(&ctrl->lock, flags);
+		return 0;
+	}
+
+	return -EINVAL;
+}
+
+static void realtek_free(struct gpio_chip *chip, unsigned gpio_pin)
+{
+	if (gpio_pin < chip->ngpio) {
+		struct realtek_gpio_ctrl *ctrl = gpiochip_get_data(chip);
+		unsigned long flags;
+		u32 reg;
+
+		raw_spin_lock_irqsave(&ctrl->lock, flags);
+		reg = ctrl->bank_read(ctrl->enable_reg);
+		reg &= ~BIT(gpio_pin);
+		ctrl->bank_write(ctrl->enable_reg, reg);
+		raw_spin_unlock_irqrestore(&ctrl->lock, flags);
+	}
+}
