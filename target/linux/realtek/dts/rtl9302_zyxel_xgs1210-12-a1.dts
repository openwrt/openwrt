/dts-v1/;

#include "rtl9302_zyxel_xgs1210-12-common.dtsi"

/ {
	compatible = "zyxel,xgs1210-12-a1", "realtek,rtl838x-soc";
	model = "Zyxel XGS1210-12 A1 Switch";
};

&mdio_bus1 {
	PHY_C45_PAIR_ORDER(24, 8, 1)
};

&mdio_bus2 {
	PHY_C45_PAIR_ORDER(25, 9, 1)
};
