	};
	phy21: ethernet-phy@21 {
		reg = <21>;
		compatible = "ethernet-phy-ieee802.3-c22";
		rtl9300,smi-address = <0 21>;
	};
	phy22: ethernet-phy@22 {
		reg = <22>;
		compatible = "ethernet-phy-ieee802.3-c22";
