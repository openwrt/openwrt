/dts-v1/;

#include "rtl9302_zyxel_xmg1915.dtsi"

#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/leds/common.h>

/ {
	compatible = "zyxel,xmg1915-10ep", "realtek,rtl9302c-soc";
	model = "Zyxel XMG1915-10EP Switch";

	keys {
		compatible = "gpio-keys";

		led-mode {
			label = "led-mode";
			gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
			linux,code = <BTN_1>;
		};
	};
};

&uart1 {
	status = "okay";

	pse: pse@0 {
		compatible = "realtek,rtl8239c";
		current-speed = <115200>;

		enable-gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;

		pse-pis {
			pse_pi0: pse-pi@0 {
				reg = <0>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
			pse_pi1: pse-pi@1 {
				reg = <1>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
			pse_pi2: pse-pi@2 {
				reg = <2>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
			pse_pi3: pse-pi@3 {
				reg = <3>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
			pse_pi4: pse-pi@4 {
				reg = <4>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
			pse_pi5: pse-pi@5 {
				reg = <5>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
			pse_pi6: pse-pi@6 {
				reg = <6>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
			pse_pi7: pse-pi@7 {
				reg = <7>;
				max-power-milliwatt = <60000>;
				#pse-cells = <0>;
			};
		};
	};
};

&phy0 { pses = <&pse_pi0>; };
&phy1 { pses = <&pse_pi1>; };
&phy2 { pses = <&pse_pi2>; };
&phy3 { pses = <&pse_pi3>; };
&phy8 { pses = <&pse_pi4>; };
&phy9 { pses = <&pse_pi5>; };
&phy10 { pses = <&pse_pi6>; };
&phy11 { pses = <&pse_pi7>; };
