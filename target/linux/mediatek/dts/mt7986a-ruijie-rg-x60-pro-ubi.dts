/dts-v1/;
#include "mt7986a-ruijie-rg-x60-pro-common.dtsi"

/ {
	compatible = "ruijie,rg-x60-pro-ubi", "mediatek,mt7986a";
	model = "Ruijie RG-X60 Pro (UBI)";
};

&chosen {
	rootdisk = <&ubi_rootdisk>;
};

&partitions {
	partition@100000 {
		compatible = "linux,ubi";
		reg = <0x100000 0x7F00000>;
		label = "ubi";

		volumes {
			ubi_factory: ubi-volume-factory {
				volname = "factory";
			};

			ubi-volume-fip {
				volname = "fip";
			};

			ubi_rootdisk: ubi-volume-fit {
				volname = "fit";
			};

			ubi_ubootenv: ubi-volume-ubootenv {
				volname = "ubootenv";
			};

			ubi_ubootenv2: ubi-volume-ubootenv2 {
				volname = "ubootenv2";
			};
		};
	};
};

&ubi_factory {
	nvmem-layout {
		compatible = "fixed-layout";
		#address-cells = <1>;
		#size-cells = <1>;

		eeprom_factory_0: eeprom@0 {
			reg = <0x0 0x1000>;
		};

		macaddr_factory_24: macaddr@24 {
			compatible = "mac-base";
			reg = <0x24 0x6>;
			#nvmem-cell-cells = <1>;
		};
	};
};

&gmac0 {
	nvmem-cells = <&macaddr_factory_24 1>;
	nvmem-cell-names = "mac-address";
};

&gmac1 {
	nvmem-cells = <&macaddr_factory_24 0>;
	nvmem-cell-names = "mac-address";
};

&wifi {
	band@0 {
		reg = <0>;
		nvmem-cells = <&macaddr_factory_24 2>;
		nvmem-cell-names = "mac-address";
	};

	band@1 {
		reg = <1>;
		nvmem-cells = <&macaddr_factory_24 3>;
		nvmem-cell-names = "mac-address";
	};
};
