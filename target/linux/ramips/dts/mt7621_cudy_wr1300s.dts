/dts-v1/;

#include "mt7621.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	compatible = "cudy,wr1300s", "mediatek,mt7621-soc";
	model = "Cudy WR1300S";

	aliases {
		led-boot = &led_status;
		led-failsafe = &led_status;
		led-running = &led_status;
		led-upgrade = &led_status;
		label-mac-device = &ethernet;
	};

	usb_vbus: regulator {
		compatible = "regulator-fixed";
		regulator-name = "usb_vbus";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpios = <&gpio 7 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
		regulator-always-on;
		enable-active-high;
	};

	leds {
		compatible = "gpio-leds";
		led_status: status {
			label = "blue:status";
			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
		};

		led_net_blue: net_blue {
			label = "blue:net";
			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
		};

		led_net_red: net_red {
			label = "red:net";
			gpios = <&gpio 15 GPIO_ACTIVE_LOW>;
			default-state = "off";
		};

		led_wan: wan {
			label = "blue:wan";
			gpios = <&gpio 16 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "netdev";
		};

		led_lan: lan {
			label = "blue:lan";
			gpios = <&gpio 4 GPIO_ACTIVE_LOW>;
		};


		wlan2g: wlan2g {
			label = "blue:wlan2g";
			gpios = <&gpio 3 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy0tpt";
		};

		wlan5g: wlan5g {
			label = "blue:wlan5g";
			gpios = <&gpio 8 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy1tpt";
		};
	};

	keys {
		compatible = "gpio-keys";
		reset {
			label = "reset";
			gpios = <&gpio 10 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
		wps {
			label = "wps";
			gpios = <&gpio 12 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};
	};
};

&state_default {
        gpio {
                groups = "uart2", "uart3", "jtag", "wdt";
                function = "gpio";
        };
};

&spi0 {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <20000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x000000 0x030000>;
				read-only;
			};

			partition@30000 {
				label = "u-boot-env";
				reg = <0x030000 0x010000>;
				read-only;
			};

			factory: partition@40000 {
				label = "factory";
				reg = <0x040000 0x010000>;
				read-only;

				compatible = "nvmem-cells";
				#address-cells = <1>;
				#size-cells = <1>;

				macaddr_factory_4: macaddr@4 {
					reg = <0x4 0x6>;
				};
			};

			partition@50000 {
				compatible = "denx,uimage";
				label = "firmware";
				reg = <0x050000 0xfa0000>;
			};

			bdinfo: partition@ff0000 {
				label = "bdinfo";
				reg = <0xff0000 0x010000>;
				read-only;

		                compatible = "nvmem-cells";
		                #address-cells = <1>;
                		#size-cells = <1>;

		                macaddr_bdinfo_de00: macaddr@de00 {
					reg = <0xde00 0x6>;
				};
			};
		};
	};
};

&pcie {
	status = "okay";
};

&pcie0 {
	status = "okay";
	wifi@0,0 {
		compatible = "mediatek,mt7603";
		reg = <0x0000 0 0 0 0>;
		mediatek,mtd-eeprom = <&factory 0x0000>;
		nvmem-cells = <&macaddr_bdinfo_de00>;
		nvmem-cell-names = "mac-address";
	};
};

&pcie1 {
	status = "okay";
	wifi@0,0 {
		compatible = "mediatek,mt7615e";
		reg = <0x0000 0 0 0 0>;
		mediatek,mtd-eeprom = <&factory 0x8000>;
		mediatek,disable-aspm;
		nvmem-cells = <&macaddr_bdinfo_de00>;
		nvmem-cell-names = "mac-address";
	};
};

&ethernet {
	status = "okay";
	pinctrl-0 = <&rgmii1_pins &rgmii2_pins &mdio_pins>;
	pinctrl-names = "default";

	gmac0: mac@0 {
		compatible = "mediatek,eth-mac";
		reg = <0>;
		label = "cpu";

		nvmem-cells = <&macaddr_bdinfo_de00>;
		nvmem-cell-names = "mac-address";
	};

	fixed-link {
		speed = <1000>;
		full-duplex;
		pause;
	};
};

&switch0 {
	ports {
		port@0 {
			status = "okay";
			label = "wan";
		};
		port@1 {
			status = "okay";
			label = "lan1";
		};
		port@2 {
			status = "okay";
			label = "lan2";
		};
		port@3 {
			status = "okay";
			label = "lan3";
		};
		port@4 {
			status = "okay";
			label = "lan4";
		};
		port@6 {
			status = "okay";
			label = "cpu";
			ethernet = <&gmac0>;
			fixed-link {
				speed = <1000>;
				full-duplex;
				pause;
			};
		};
	};
};

&xhci {
	vbus-supply = <&usb_vbus>;
	status = "okay";
};
