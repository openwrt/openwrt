+/* SerDes indirect register write */
+static int rtl8365mb_sds_write(struct realtek_priv *priv, u16 addr, u16 data)
+{
+	int ret;
+
+	ret = regmap_write(priv->map, RTL8365MB_SDS_INDACS_DATA_REG, data);
+	if (ret)
+		return ret;
+
+	ret = regmap_write(priv->map, RTL8365MB_SDS_INDACS_ADDR_REG, addr);
+	if (ret)
+		return ret;
+
+	return regmap_write(priv->map, RTL8365MB_SDS_INDACS_CMD_REG, 0x00C0);
+}
+
+/* SerDes indirect register read */
+static int rtl8365mb_sds_read(struct realtek_priv *priv, u16 addr, u32 *data)
+{
+	int ret;
+
+	ret = regmap_write(priv->map, RTL8365MB_SDS_INDACS_ADDR_REG, addr);
+	if (ret)
+		return ret;
+
+	ret = regmap_write(priv->map, RTL8365MB_SDS_INDACS_CMD_REG, 0x0080);
+	if (ret)
+		return ret;
+
+	return regmap_read(priv->map, RTL8365MB_SDS_INDACS_DATA_REG, data);
+}
