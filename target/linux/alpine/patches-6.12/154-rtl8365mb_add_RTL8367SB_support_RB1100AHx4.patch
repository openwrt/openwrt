+/* Load firmware into the integrated 8051 microcontroller.
+ * The 8051 manages SerDes autoneg and link management for SGMII/HSGMII.
+ * Without this firmware, the SerDes TX will not transmit comma patterns.
+ */
+static int rtl8365mb_ext_init_sgmii_fw(struct realtek_priv *priv)
+{
+	const struct firmware *fw;
+	int ret;
+	int i;
+
+	ret = request_firmware(&fw, "rtl_switch/rtl8367s-sgmii.bin", priv->dev);
+	if (ret) {
+		dev_err(priv->dev,
+			"failed to load firmware rtl_switch/rtl8367s-sgmii.bin: %d\n",
+			ret);
+		return ret;
+	}
+
+	/* Reset 8051 */
+	ret = regmap_update_bits(priv->map, RTL8365MB_CHIP_RESET_REG,
+				 RTL8365MB_CHIP_RESET_DW8051,
+				 RTL8365MB_CHIP_RESET_DW8051);
+	if (ret)
+		goto release_fw;
+
+	/* Enable 8051 */
+	ret = regmap_update_bits(priv->map, RTL8365MB_DW8051_CFG_REG,
+				 RTL8365MB_DW8051_CFG_EN_MASK,
+				 RTL8365MB_DW8051_CFG_EN_MASK);
+	if (ret)
+		goto release_fw;
+
+	/* Enable IROM access */
+	ret = regmap_update_bits(priv->map, RTL8365MB_DW8051_RDY_REG,
+				 RTL8365MB_DW8051_RDY_ACS_IROM_EN_MASK,
+				 RTL8365MB_DW8051_RDY_ACS_IROM_EN_MASK);
+	if (ret)
+		goto release_fw;
+
+	/* Clear IROM MSB */
+	ret = regmap_update_bits(priv->map, RTL8365MB_DW8051_RDY_REG,
+				 RTL8365MB_DW8051_RDY_IROM_MSB_MASK, 0);
+	if (ret)
+		goto release_fw;
+
+	/* Write firmware data */
+	for (i = 0; i < fw->size; i++) {
+		ret = regmap_write(priv->map,
+				   RTL8365MB_DW8051_IROM_BASE + i,
+				   fw->data[i]);
+		if (ret)
+			goto release_fw;
+	}
+
+	/* Clear IROM MSB again */
+	ret = regmap_update_bits(priv->map, RTL8365MB_DW8051_RDY_REG,
+				 RTL8365MB_DW8051_RDY_IROM_MSB_MASK, 0);
+	if (ret)
+		goto release_fw;
+
+	/* Disable IROM access */
+	ret = regmap_update_bits(priv->map, RTL8365MB_DW8051_RDY_REG,
+				 RTL8365MB_DW8051_RDY_ACS_IROM_EN_MASK, 0);
+	if (ret)
+		goto release_fw;
+
+	/* Release 8051 from reset */
+	ret = regmap_update_bits(priv->map, RTL8365MB_CHIP_RESET_REG,
+				 RTL8365MB_CHIP_RESET_DW8051, 0);
+
+	dev_info(priv->dev, "8051 firmware loaded (%zu bytes)\n", fw->size);
+
+release_fw:
+	release_firmware(fw);
+
+	return ret;
+}
