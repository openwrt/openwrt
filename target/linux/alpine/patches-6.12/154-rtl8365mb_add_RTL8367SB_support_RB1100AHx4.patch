+static void rtl8365mb_dbg_dump_cpu_link(struct realtek_priv *priv, int port,
+					const char *tag, unsigned int mode,
+					phy_interface_t interface, int speed,
+					int duplex, bool tx_pause, bool rx_pause)
+{
+	const struct rtl8365mb_extint *extint =
+		rtl8365mb_get_port_extint(priv, port);
+	u32 di_select = 0, di_force = 0, sds_misc = 0, dw8051_cfg = 0, sds_reg3 = 0;
+
+	if (!extint) {
+		dev_info(priv->dev,
+			 "DBG rtl8365mb: %s port %d has no extint\n",
+			 tag, port);
+		return;
+	}
+
+	regmap_read(priv->map,
+		    RTL8365MB_DIGITAL_INTERFACE_SELECT_REG(extint->id),
+		    &di_select);
+	regmap_read(priv->map,
+		    RTL8365MB_DIGITAL_INTERFACE_FORCE_REG(extint->id),
+		    &di_force);
+
+	if (interface == PHY_INTERFACE_MODE_SGMII ||
+	    interface == PHY_INTERFACE_MODE_2500BASEX) {
+		regmap_read(priv->map, RTL8365MB_SDS_MISC_REG, &sds_misc);
+		regmap_read(priv->map, RTL8365MB_DW8051_CFG_REG, &dw8051_cfg);
+		rtl8365mb_sds_read(priv, 0x0003, &sds_reg3);
+	}
+
+	dev_info(priv->dev,
+		 "DBG rtl8365mb: %s port=%d extint=%d mode=%u iface=%s speed=%d duplex=%d tx_pause=%d rx_pause=%d\n",
+		 tag, port, extint->id, mode, phy_modes(interface), speed,
+		 duplex, tx_pause, rx_pause);
+	dev_info(priv->dev,
+		 "DBG rtl8365mb: %s regs select=0x%04x force=0x%04x sds_misc=0x%04x dw8051=0x%04x sds3=0x%04x\n",
+		 tag, di_select, di_force, sds_misc, dw8051_cfg, sds_reg3);
+}
