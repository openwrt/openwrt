+/* Full SGMII/HSGMII initialization sequence.
+ * Based on Hauke Mehrtens' patch and Realtek SDK rtl8367c_setAsicPortExtMode().
+ * Sequence: jam table -> SDS_MISC mode bits -> SELECT mode -> BYPASS_LINE_RATE
+ *           -> SDS 0x0003=0x7106 (release reset) -> load 8051 firmware
+ */
+static int rtl8365mb_ext_config_sgmii(struct realtek_priv *priv, int port,
+				      phy_interface_t interface)
+{
+	const struct rtl8365mb_extint *extint =
+		rtl8365mb_get_port_extint(priv, port);
+	const struct rtl8365mb_sds_entry *sds_jam;
+	struct rtl8365mb *mb = priv->chip_data;
+	int sds_jam_len;
+	int sds_mode;
+	int ext_mode;
+	u32 chip_option;
+	int ret;
+	int val;
+	int i;
+
+	if (!extint || extint->id != 1)
+		return -EINVAL;
+
+	/* Read chip option from register 0x1300 (unlocked via 0x13C2) */
+	regmap_write(priv->map, 0x13C2, 0x0249);
+	regmap_read(priv->map, 0x1300, &chip_option);
+	regmap_write(priv->map, 0x13C2, 0x0000);
+	/* option is determined by chip type category */
+	chip_option = (chip_option == 0x6367) ? 1 : 0;
+
+	if (interface == PHY_INTERFACE_MODE_SGMII) {
+		sds_mode = RTL8365MB_SDS_MISC_SEL_SGMII_MASK;
+		ext_mode = RTL8365MB_EXT_PORT_MODE_SGMII;
+
+		if (chip_option == 0) {
+			sds_jam = rtl8365mb_sds_jam_sgmii;
+			sds_jam_len = ARRAY_SIZE(rtl8365mb_sds_jam_sgmii);
+		} else {
+			sds_jam = rtl8365mb_sds_jam_sgmii_sb;
+			sds_jam_len = ARRAY_SIZE(rtl8365mb_sds_jam_sgmii_sb);
+		}
+	} else if (interface == PHY_INTERFACE_MODE_2500BASEX) {
+		sds_mode = RTL8365MB_SDS_MISC_SEL_HSGMII_MASK;
+		ext_mode = RTL8365MB_EXT_PORT_MODE_HSGMII;
+
+		if (chip_option == 0) {
+			switch (mb->chip_info->chip_ver & 0x00F0) {
+			case 0x0010:
+			case 0x0050:
+			case 0x0060:
+				sds_jam = rtl8365mb_sds_jam_hsgmii_1;
+				sds_jam_len = ARRAY_SIZE(rtl8365mb_sds_jam_hsgmii_1);
+				break;
+			case 0x0080:
+			case 0x0090:
+				sds_jam = rtl8365mb_sds_jam_hsgmii_8;
+				sds_jam_len = ARRAY_SIZE(rtl8365mb_sds_jam_hsgmii_8);
+				break;
+			default:
+				dev_err(priv->dev,
+					"unsupported chip_ver 0x%04x for HSGMII\n",
+					mb->chip_info->chip_ver);
+				return -EINVAL;
+			}
+		} else {
+			sds_jam = rtl8365mb_sds_jam_hsgmii_hb;
+			sds_jam_len = ARRAY_SIZE(rtl8365mb_sds_jam_hsgmii_hb);
+		}
+	} else {
+		return -EINVAL;
+	}
+
+	/* Step 1: Write SDS jam table via indirect access */
+	for (i = 0; i < sds_jam_len; i++) {
+		ret = rtl8365mb_sds_write(priv, sds_jam[i].addr,
+					  sds_jam[i].data);
+		if (ret)
+			return ret;
+	}
+
+	/* Step 2: Set SGMII/HSGMII mode in SDS_MISC register */
+	ret = regmap_update_bits(priv->map, RTL8365MB_SDS_MISC_REG,
+				 RTL8365MB_SDS_MISC_SEL_SGMII_MASK |
+				 RTL8365MB_SDS_MISC_SEL_HSGMII_MASK,
+				 sds_mode);
+	if (ret)
+		return ret;
+
+	/* Step 3: Set interface mode in DIGITAL_INTERFACE_SELECT */
+	val = ext_mode << RTL8365MB_DIGITAL_INTERFACE_SELECT_MODE_OFFSET(
+					extint->id);
+	ret = regmap_update_bits(priv->map,
+				 RTL8365MB_DIGITAL_INTERFACE_SELECT_REG(extint->id),
+				 RTL8365MB_DIGITAL_INTERFACE_SELECT_MODE_MASK(
+						extint->id),
+				 val);
+	if (ret)
+		return ret;
+
+	/* Step 4: Clear bypass line rate */
+	ret = regmap_write(priv->map, RTL8365MB_BYPASS_LINE_RATE_REG, 0x0);
+	if (ret)
+		return ret;
+
+	/* Step 5: Release SerDes from reset */
+	ret = rtl8365mb_sds_write(priv, 0x0003, 0x7106);
+	if (ret)
+		return ret;
+
+	/* Step 6: Load 8051 firmware for SerDes management */
+	ret = rtl8365mb_ext_init_sgmii_fw(priv);
+	if (ret)
+		return ret;
+
+	dev_info(priv->dev,
+		 "SGMII/HSGMII init done: port %d interface %s\n",
+		 port, phy_modes(interface));
+
+	return 0;
+}
+
+/* Configure SGMII/HSGMII in-band autoneg (nway) */
+static int rtl8365mb_ext_sgmii_nway(struct realtek_priv *priv, bool enable)
+{
+	u32 running;
+	u32 val;
+	int ret;
+
+	/* Pause 8051 if running */
+	ret = regmap_read(priv->map, RTL8365MB_DW8051_CFG_REG, &running);
+	if (ret)
+		return ret;
+
+	if (running & RTL8365MB_DW8051_CFG_EN_MASK) {
+		ret = regmap_update_bits(priv->map, RTL8365MB_DW8051_CFG_REG,
+					 RTL8365MB_DW8051_CFG_EN_MASK, 0);
+		if (ret)
+			return ret;
+	}
+
+	/* Read SDS reg 0x0002, set/clear nway bit, set restart bit */
+	ret = rtl8365mb_sds_read(priv, 0x0002, &val);
+	if (ret)
+		return ret;
+
+	if (enable)
+		val |= 0x0200;
+	else
+		val &= ~0x0200;
+	val |= 0x0100;
+
+	ret = rtl8365mb_sds_write(priv, 0x0002, val);
+	if (ret)
+		return ret;
+
+	/* Re-enable 8051 */
+	ret = regmap_update_bits(priv->map, RTL8365MB_DW8051_CFG_REG,
+				 RTL8365MB_DW8051_CFG_EN_MASK,
+				 RTL8365MB_DW8051_CFG_EN_MASK);
+	if (ret)
+		return ret;
+
+	return 0;
+}
