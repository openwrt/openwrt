+static int mv88e6185_pcs_validate(struct phylink_pcs *pcs,
+				  unsigned long *supported,
+				  const struct phylink_link_state *state)
+{
+	/* Internal PHY ports (no serdes): accept INTERNAL and GMII only */
+	if (state->interface == PHY_INTERFACE_MODE_INTERNAL ||
+	    state->interface == PHY_INTERFACE_MODE_GMII)
+		return 0;
+	return -EOPNOTSUPP;
+}
+
 static const struct phylink_pcs_ops mv88e6185_phylink_pcs_ops = {
 	.pcs_get_state = mv88e6185_pcs_get_state,
 	.pcs_config = mv88e6185_pcs_config,
