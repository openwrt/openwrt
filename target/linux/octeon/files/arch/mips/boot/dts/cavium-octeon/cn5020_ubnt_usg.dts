/*
 * Device tree source for Ubiquiti UniFi Security Gateway.
 *
 * Written for EdgeRouter Lite by: Aaro Koskinen <aaro.koskinen@iki.fi>
 * Adapted for USG by: Clemens Hopfer <openwrt@wireloss.net>
 */

#include "cn5020_ubnt_e100.dtsi"
#include <dt-bindings/gpio/gpio.h>

/ {
	/* E120 */
	compatible = "ubnt,usg", "ubnt,e100", "cavium,cn5020";
	model = "Ubiquiti UniFi Security Gateway (USG)";

	aliases {
		led-boot = &led_dome_white;
		led-failsafe = &led_dome_blue;
		led-running = &led_dome_blue;
		led-upgrade = &led_dome_blue;
	};

	leds {
		compatible = "gpio-leds";

		led_dome_white: led-0 {
			label = "white:dome";
			gpios = <&gpio 0 GPIO_ACTIVE_HIGH>;
		};

		led_dome_blue: led-1 {
			label = "blue:dome";
			gpios = <&gpio 1 GPIO_ACTIVE_HIGH>;
		};
	};
};

&flash0 {
	compatible = "Macronix,mx29lv640e", "cfi-flash";
	reg = <0 0 0x800000>;

	partitions {
		partition@100000 {
			/* 4k EEPROM */
			reg = <0x100000 0x1000>;
		};

		partition@101000 {
			reg = <0x101000 0x2000>;
			label = "u-boot_gd";
			read-only;
		};

		partition@7fe000 {
			reg = <0x7fe000 0x2000>;
			compatible = "u-boot,env";
			label = "u-boot_env";
		};
	};
};

&smi0 {
	phy2: ethernet-phy@5 {
		reg = <5>;
		compatible = "ethernet-phy-ieee802.3-c22";
	};
};

&eth0 {
	label = "eth0";
};

&eth1 {
	label = "eth1";
};

&pip {
	interface@0 {
		eth2: ethernet@2 {
			phy-handle = <&phy2>;
			rx-delay = <0>;
			tx-delay = <0x10>;

			label = "eth2";
			nvmem-cells = <&macaddr_eeprom_0 2>;
			nvmem-cell-names = "mac-address";
		};
	};
};
