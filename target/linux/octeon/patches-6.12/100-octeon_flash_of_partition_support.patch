+static void octeon_flash_remove(struct platform_device *pdev)
+{
+	struct octeon_flash_device *priv = platform_get_drvdata(pdev);
+	if (!priv || !priv->mtd)
+		return;
+
+	WARN_ON(mtd_device_unregister(priv->mtd));
+	map_destroy(priv->mtd);
+}
