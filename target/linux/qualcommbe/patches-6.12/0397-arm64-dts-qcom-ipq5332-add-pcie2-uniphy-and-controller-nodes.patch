From: Til Kaiser <mail@tk154.de>
Date: Sat, 19 Apr 2026 12:10:00 +0200
Subject: [PATCH] arm64: dts: qcom: ipq5332: add PCIe2 UNIPHY and controller
 nodes

Add the missing IPQ5332 PCIe2 device tree pieces by introducing:
- the pcie2 UNIPHY node
- reset-names for the existing PCIe PHY nodes
- the pcie2 controller node
- GCC external pipe clock wiring for all three PCIe pipe sources

The DTS wiring and resource layout are adapted from the downstream
Qualcomm/QSDK device tree.

Signed-off-by: Til Kaiser <mail@tk154.de>
---

--- a/arch/arm64/boot/dts/qcom/ipq5332.dtsi
+++ b/arch/arm64/boot/dts/qcom/ipq5332.dtsi
@@ -210,6 +210,10 @@
 				 <&gcc GCC_PCIE3X1_PHY_AHB_CLK_ARES>,
 				 <&gcc GCC_PCIE3X1_0_PHY_PHY_BCR>;
 
+			reset-names = "phy",
+				      "phy_ahb",
+				      "phy_phy";
+
 			#clock-cells = <0>;
 
 			#phy-cells = <0>;
@@ -230,6 +234,10 @@
 				 <&gcc GCC_PCIE3X2_PHY_AHB_CLK_ARES>,
 				 <&gcc GCC_PCIE3X2PHY_PHY_BCR>;
 
+			reset-names = "phy",
+				      "phy_ahb",
+				      "phy_phy";
+
 			#clock-cells = <0>;
 
 			#phy-cells = <0>;
@@ -239,6 +247,30 @@
 			status = "disabled";
 		};
 
+		pcie2_phy: phy@4b1800 {
+			compatible = "qcom,ipq5332-uniphy-pcie-phy";
+			reg = <0x004b1800 0x800>;
+
+			clocks = <&gcc GCC_PCIE3X1_1_PIPE_CLK>,
+				<&gcc GCC_SNOC_PCIE3_1LANE_1_M_CLK>,
+				<&gcc GCC_SNOC_PCIE3_1LANE_1_S_CLK>,
+				<&gcc GCC_PCIE3X2_PHY_AHB_CLK>;
+
+			resets = <&gcc GCC_PCIE3X1_1_PHY_BCR>,
+				 <&gcc GCC_PCIE3X2_PHY_AHB_CLK_ARES>;
+
+			reset-names = "phy",
+				      "phy_ahb";
+
+			#clock-cells = <0>;
+
+			#phy-cells = <0>;
+
+			num-lanes = <1>;
+
+			status = "disabled";
+		};
+
 		tlmm: pinctrl@1000000 {
 			compatible = "qcom,ipq5332-tlmm";
 			reg = <0x01000000 0x300000>;
@@ -298,8 +330,8 @@
 			clocks = <&xo_board>,
 				 <&sleep_clk>,
 				 <&pcie1_phy>,
-				 <&pcie0_phy>,
-				 <0>;
+				 <&pcie2_phy>,
+				 <&pcie0_phy>;
 		};
 
 		tcsr_mutex: hwlock@1905000 {
@@ -697,6 +729,92 @@
 			};
 		};
 
+		pcie2: pcie@10000000 {
+			compatible = "qcom,pcie-ipq5332", "qcom,pcie-ipq9574";
+			reg = <0x10000000 0xf1c>,
+		      <0x10000f20 0xa8>,
+		      <0x10001000 0x1000>,
+		      <0x000f0000 0x3000>,
+			      <0x10100000 0x1000>;
+			reg-names = "dbi",
+		    		"elbi",
+		    		"atu",
+		    		"parf",
+		    		"config";
+			device_type = "pci";
+			linux,pci-domain = <2>;
+			num-lanes = <1>;
+			#address-cells = <3>;
+			#size-cells = <2>;
+
+			ranges = <0x01000000 0x0 0x00000000 0x10200000 0x0 0x00100000>,
+				 <0x02000000 0x0 0x10300000 0x10300000 0x0 0x07d00000>;
+
+			msi-map = <0x0 &v2m0 0x0 0xffd>;
+
+			interrupts = <GIC_SPI 49 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "global";
+
+			#interrupt-cells = <1>;
+			interrupt-map-mask = <0 0 0 0x7>;
+			interrupt-map = <0 0 0 1 &intc 0 0 399 IRQ_TYPE_LEVEL_HIGH>,
+					<0 0 0 2 &intc 0 0 400 IRQ_TYPE_LEVEL_HIGH>,
+					<0 0 0 3 &intc 0 0 401 IRQ_TYPE_LEVEL_HIGH>,
+					<0 0 0 4 &intc 0 0 402 IRQ_TYPE_LEVEL_HIGH>;
+
+			clocks = <&gcc GCC_PCIE3X1_1_AXI_M_CLK>,
+				 <&gcc GCC_PCIE3X1_1_AXI_S_CLK>,
+				 <&gcc GCC_PCIE3X1_1_AXI_S_BRIDGE_CLK>,
+				 <&gcc GCC_PCIE3X1_1_RCHG_CLK>,
+				 <&gcc GCC_PCIE3X1_1_AHB_CLK>,
+				 <&gcc GCC_PCIE3X2_AUX_CLK>;
+			clock-names = "axi_m",
+				      "axi_s",
+				      "axi_bridge",
+				      "rchng",
+				      "ahb",
+				      "aux";
+
+			assigned-clocks = <&gcc GCC_PCIE3X2_AUX_CLK>;
+
+			assigned-clock-rates = <2000000>;
+
+			resets = <&gcc GCC_PCIE3X1_1_PIPE_ARES>,
+				 <&gcc GCC_PCIE3X1_1_CORE_STICKY_ARES>,
+				 <&gcc GCC_PCIE3X1_1_AXI_S_STICKY_ARES>,
+				 <&gcc GCC_PCIE3X1_1_AXI_S_CLK_ARES>,
+				 <&gcc GCC_PCIE3X1_1_AXI_M_STICKY_ARES>,
+				 <&gcc GCC_PCIE3X1_1_AXI_M_CLK_ARES>,
+				 <&gcc GCC_PCIE3X1_1_AUX_CLK_ARES>,
+				 <&gcc GCC_PCIE3X1_1_AHB_CLK_ARES>;
+			reset-names = "pipe",
+				      "sticky",
+				      "axi_s_sticky",
+				      "axi_s",
+				      "axi_m_sticky",
+				      "axi_m",
+				      "aux",
+				      "ahb";
+
+			phys = <&pcie2_phy>;
+			phy-names = "pciephy";
+
+			interconnects = <&gcc MASTER_SNOC_PCIE3_2_M &gcc SLAVE_SNOC_PCIE3_2_M>,
+					<&gcc MASTER_ANOC_PCIE3_2_S &gcc SLAVE_ANOC_PCIE3_2_S>;
+			interconnect-names = "pcie-mem", "cpu-pcie";
+
+			status = "disabled";
+
+			pcie@0 {
+				device_type = "pci";
+				reg = <0x0 0x0 0x0 0x0 0x0>;
+
+				#address-cells = <3>;
+				#size-cells = <2>;
+				ranges;
+			};
+		};
+
 		pcie1: pcie@18000000 {
 			compatible = "qcom,pcie-ipq5332", "qcom,pcie-ipq9574";
 			reg = <0x18000000 0xf1c>,
