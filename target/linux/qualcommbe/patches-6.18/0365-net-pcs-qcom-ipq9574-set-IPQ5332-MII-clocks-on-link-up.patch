From: Til Kaiser <mail@tk154.de>
Date: Thu, 23 Apr 2026 00:00:00 +0200
Subject: [PATCH] net: pcs: qcom-ipq9574: set IPQ5332 MII clocks on link up

Reuse the qcom-ipq9574 PCS driver for IPQ5332 with an explicit MII clock
rate request during link-up.

The PCS configures the exported USXGMII RX/TX clocks correctly, but the
derived NSSCC MII and PPE port clocks may otherwise remain on the 24 MHz
XO path until a consumer requests the negotiated link rate. When that
happens, link comes up but traffic does not pass.

Program the IPQ5332 MII clocks on link-up so the shared NSSCC divider
path switches to the correct derived rate. Use the same speed-to-clock
mapping as downstream QSDK for the IPQ5332 USXGMII clock path.

Signed-off-by: Til Kaiser <mail@tk154.de>
---
 drivers/net/pcs/pcs-qcom-ipq9574.c | 43 +++++++++++++++++++++++++++++++++++++
 1 file changed, 43 insertions(+)

--- a/drivers/net/pcs/pcs-qcom-ipq9574.c
+++ b/drivers/net/pcs/pcs-qcom-ipq9574.c
@@ -740,6 +740,43 @@ static void ipq_pcs_an_restart(struct ph
 	/* Currently not used */
 }
 
+static unsigned long ipq_pcs_mii_clk_rate_get(phy_interface_t interface,
+					       int speed)
+{
+	if (interface != PHY_INTERFACE_MODE_USXGMII &&
+	    interface != PHY_INTERFACE_MODE_10G_QXGMII)
+		return 0;
+
+	switch (speed) {
+	case SPEED_10:
+		return 1250000;
+	case SPEED_100:
+		return 12500000;
+	case SPEED_1000:
+		return 125000000;
+	case SPEED_2500:
+		return 78125000;
+	case SPEED_5000:
+		return 156250000;
+	case SPEED_10000:
+		return 312500000;
+	default:
+		return 0;
+	}
+}
+
+static int ipq_pcs_mii_clk_set_rate(struct ipq_pcs_mii *qpcs_mii,
+				    phy_interface_t interface, int speed)
+{
+	unsigned long rate = ipq_pcs_mii_clk_rate_get(interface, speed);
+
+	if (!rate)
+		return 0;
+
+	return clk_set_rate(qpcs_mii->rx_clk, rate) ?:
+	       clk_set_rate(qpcs_mii->tx_clk, rate);
+}
+
 static void ipq_pcs_link_up(struct phylink_pcs *pcs,
 			    unsigned int neg_mode,
 			    phy_interface_t interface,
@@ -750,6 +787,12 @@ static void ipq_pcs_link_up(struct phyli
 	int index = qpcs_mii->index;
 	int ret;
 
+	if (of_device_is_compatible(qpcs->dev->of_node, "qcom,ipq5332-pcs")) {
+		ret = ipq_pcs_mii_clk_set_rate(qpcs_mii, interface, speed);
+		if (ret)
+			goto err;
+	}
+
 	switch (interface) {
 	case PHY_INTERFACE_MODE_SGMII:
 	case PHY_INTERFACE_MODE_QSGMII:
@@ -772,6 +815,7 @@ static void ipq_pcs_link_up(struct phyli
 		return;
 	}
 
+err:
 	if (ret)
 		dev_err(qpcs->dev, "PCS link up fail for interface %s\n",
 			phy_modes(interface));
@@ -1048,6 +1092,7 @@ static int ipq9574_pcs_probe(struct plat
 }
 
 static const struct of_device_id ipq9574_pcs_of_mtable[] = {
+	{ .compatible = "qcom,ipq5332-pcs" },
 	{ .compatible = "qcom,ipq9574-pcs" },
 	{ /* sentinel */ },
 };
