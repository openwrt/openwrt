From: Til Kaiser <mail@tk154.de>
Date: Sun, 19 Apr 2026 00:00:00 +0200
Subject: [PATCH] arm64: dts: qcom: ipq5332: add upstream PPE and PCS nodes

Add common IPQ5332 PPE and PCS nodes to the shared DTSI.

This provides the base hardware description for boards that want to use
the PPE datapath and Ethernet PCS blocks.

Signed-off-by: Til Kaiser <mail@tk154.de>
---
 arch/arm64/boot/dts/qcom/ipq5332.dtsi | 127 ++++++++++++++++++++++++++
 1 file changed, 127 insertions(+)

--- a/arch/arm64/boot/dts/qcom/ipq5332.dtsi
+++ b/arch/arm64/boot/dts/qcom/ipq5332.dtsi
@@ -7,6 +7,7 @@
 
 #include <dt-bindings/clock/qcom,apss-ipq.h>
 #include <dt-bindings/clock/qcom,ipq5332-gcc.h>
+#include <dt-bindings/clock/qcom,ipq5332-nsscc.h>
 #include <dt-bindings/interconnect/qcom,ipq5332.h>
 #include <dt-bindings/interrupt-controller/arm-gic.h>
 
@@ -477,6 +478,128 @@
 			status = "disabled";
 		};
 
+		qcom_ppe: ethernet@3a000000 {
+			compatible = "qcom,ipq5332-ppe";
+			reg = <0x3a000000 0xbef800>;
+			ranges;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			clocks = <&nsscc NSS_CC_PPE_SWITCH_CLK>,
+				 <&nsscc NSS_CC_PPE_SWITCH_CFG_CLK>,
+				 <&nsscc NSS_CC_PPE_SWITCH_IPE_CLK>,
+				 <&nsscc NSS_CC_PPE_SWITCH_BTQ_CLK>,
+				 <&gcc GCC_IM_SLEEP_CLK>;
+			clock-names = "ppe",
+				      "ppe_cfg",
+				      "ppe_ipe",
+				      "ppe_btq",
+				      "gcc_im_sleep";
+			resets = <&nsscc NSS_CC_PPE_BCR>;
+			interconnects = <&nsscc MASTER_NSSNOC_PPE
+					 &nsscc SLAVE_NSSNOC_PPE>,
+					<&nsscc MASTER_NSSNOC_PPE_CFG
+					 &nsscc SLAVE_NSSNOC_PPE_CFG>,
+					<&gcc MASTER_NSSNOC_QOSGEN_REF
+					 &gcc SLAVE_NSSNOC_QOSGEN_REF>,
+					<&gcc MASTER_NSSNOC_TIMEOUT_REF
+					 &gcc SLAVE_NSSNOC_TIMEOUT_REF>;
+			interconnect-names = "ppe",
+					     "ppe_cfg",
+					     "qos_gen",
+					     "timeout_ref";
+			status = "disabled";
+
+			ethernet-dma {
+				compatible = "qcom,ipq5332-edma";
+				clocks = <&nsscc NSS_CC_PPE_EDMA_CLK>,
+					 <&nsscc NSS_CC_PPE_EDMA_CFG_CLK>;
+				clock-names = "sys",
+					      "apb";
+				resets = <&nsscc NSS_CC_PPE_EDMA_CLK_ARES>,
+					 <&nsscc NSS_CC_PPE_EDMA_CFG_CLK_ARES>;
+				reset-names = "edma_rst",
+					      "edma_cfg_rst";
+				interrupts = <GIC_SPI 163 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 164 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 165 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 166 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 167 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 168 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 169 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 170 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 171 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 172 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 173 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 139 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 140 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 141 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 142 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 191 IRQ_TYPE_LEVEL_HIGH>;
+				interrupt-names = "txcmpl_4",
+						  "txcmpl_5",
+						  "txcmpl_6",
+						  "txcmpl_7",
+						  "txcmpl_8",
+						  "txcmpl_9",
+						  "txcmpl_10",
+						  "txcmpl_11",
+						  "txcmpl_12",
+						  "txcmpl_13",
+						  "txcmpl_14",
+						  "txcmpl_15",
+						  "rxdesc_12",
+						  "rxdesc_13",
+						  "rxdesc_14",
+						  "rxdesc_15",
+						  "misc";
+			};
+		};
+
+		pcs0: ethernet-pcs@7a00000 {
+			compatible = "qcom,ipq5332-pcs";
+			reg = <0x7a00000 0x10000>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			clocks = <&gcc GCC_UNIPHY0_SYS_CLK>,
+				 <&gcc GCC_UNIPHY0_AHB_CLK>;
+			clock-names = "sys",
+				      "ahb";
+			resets = <&gcc GCC_UNIPHY0_XPCS_ARES>;
+			#clock-cells = <1>;
+			status = "disabled";
+
+			pcs0_ch0: pcs-mii@0 {
+				reg = <0>;
+				clocks = <&nsscc NSS_CC_UNIPHY_PORT1_RX_CLK>,
+					 <&nsscc NSS_CC_UNIPHY_PORT1_TX_CLK>;
+				clock-names = "rx",
+					      "tx";
+			};
+		};
+
+		pcs1: ethernet-pcs@7a10000 {
+			compatible = "qcom,ipq5332-pcs";
+			reg = <0x7a10000 0x10000>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			clocks = <&gcc GCC_UNIPHY1_SYS_CLK>,
+				 <&gcc GCC_UNIPHY1_AHB_CLK>;
+			clock-names = "sys",
+				      "ahb";
+			resets = <&gcc GCC_UNIPHY1_XPCS_ARES>;
+			#clock-cells = <1>;
+			status = "disabled";
+
+			pcs1_ch0: pcs-mii@0 {
+				reg = <0>;
+				clocks = <&nsscc NSS_CC_UNIPHY_PORT2_RX_CLK>,
+					 <&nsscc NSS_CC_UNIPHY_PORT2_TX_CLK>;
+				clock-names = "rx",
+					      "tx";
+			};
+		};
+
 		usb: usb@8af8800 {
 			compatible = "qcom,ipq5332-dwc3", "qcom,dwc3";
 			reg = <0x08af8800 0x400>;
@@ -866,10 +989,10 @@
 			clocks = <&cmn_pll_nss_200m_clk>,
 				 <&cmn_pll_nss_300m_clk>,
 				 <&gcc GPLL0_OUT_AUX>,
-				 <0>,
-				 <0>,
-				 <0>,
-				 <0>,
+				 <&pcs0 0>,
+				 <&pcs0 1>,
+				 <&pcs1 0>,
+				 <&pcs1 1>,
 				 <&xo_board>;
 			#clock-cells = <1>;
 			#reset-cells = <1>;
