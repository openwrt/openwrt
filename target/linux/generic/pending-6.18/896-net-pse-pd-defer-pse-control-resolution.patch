From: Carlo Szelinsky <github@szelinsky.de>
Subject: [PATCH] net: pse-pd: support module-based PSE controller drivers

When a PSE controller driver is built as a module, it may not be probed
yet when PHYs are registered. This causes of_pse_control_get() to
return -EPROBE_DEFER, destroying the PHY device. Later,
regulator_init_complete disables unclaimed PSE regulators, killing PoE.

Fix this by:
- Treating PSE -EPROBE_DEFER as non-fatal during PHY registration.
- Resolving PSE controls lazily on first ethtool access.
- Returning admin_state_enabled from pse_pi_is_enabled() so
  regulator_init_complete skips unclaimed PSE regulators.
- Syncing the regulator refcount when a PSE control is acquired.
- Re-enabling PIs from the event handler after hardware resets.

Signed-off-by: Carlo Szelinsky <github@szelinsky.de>
---
--- a/drivers/net/mdio/fwnode_mdio.c
+++ b/drivers/net/mdio/fwnode_mdio.c
@@ -166,8 +166,12 @@ int fwnode_mdiobus_register_phy(struct m
 
 	psec = fwnode_find_pse_control(child, phy);
 	if (IS_ERR(psec)) {
-		rc = PTR_ERR(psec);
-		goto unregister_phy;
+		if (PTR_ERR(psec) == -EPROBE_DEFER) {
+			psec = NULL;
+		} else {
+			rc = PTR_ERR(psec);
+			goto unregister_phy;
+		}
 	}
 
 	phy->psec = psec;
--- a/drivers/net/pse-pd/pse_core.c
+++ b/drivers/net/pse-pd/pse_core.c
@@ -412,26 +412,11 @@ static bool pse_pw_d_is_sw_pw_control(st
 static int pse_pi_is_enabled(struct regulator_dev *rdev)
 {
 	struct pse_controller_dev *pcdev = rdev_get_drvdata(rdev);
-	const struct pse_controller_ops *ops;
-	int id, ret;
-
-	ops = pcdev->ops;
-	if (!ops->pi_get_admin_state)
-		return -EOPNOTSUPP;
+	int id;
 
 	id = rdev_get_id(rdev);
-	mutex_lock(&pcdev->lock);
-	if (pse_pw_d_is_sw_pw_control(pcdev, pcdev->pi[id].pw_d)) {
-		ret = pcdev->pi[id].admin_state_enabled;
-		goto out;
-	}
-
-	ret = pse_pi_is_hw_enabled(pcdev, id);
-
-out:
-	mutex_unlock(&pcdev->lock);
 
-	return ret;
+	return pcdev->pi[id].admin_state_enabled;
 }
 
 /**
@@ -1291,6 +1276,21 @@ static irqreturn_t pse_isr(int irq, void
 		rnotifs = pse_to_regulator_notifs(notifs);
 		regulator_notifier_call_chain(pcdev->pi[i].rdev, rnotifs,
 					      NULL);
+
+		/* Recover from hardware reset: if software says this
+		 * PI should be enabled but hardware shows disabled,
+		 * re-enable it. Handles external events (e.g. SerDes
+		 * reconfiguration) that reset the PSE controller.
+		 */
+		if (pcdev->pi[i].admin_state_enabled &&
+		    pcdev->ops->pi_enable &&
+		    pcdev->ops->pi_get_admin_state) {
+			struct pse_admin_state as = {};
+
+			if (!pcdev->ops->pi_get_admin_state(pcdev, i, &as) &&
+			    as.c33_admin_state != ETHTOOL_C33_PSE_ADMIN_STATE_ENABLED)
+				pcdev->ops->pi_enable(pcdev, i);
+		}
 	}
 
 	mutex_unlock(&pcdev->lock);
--- a/net/ethtool/pse-pd.c
+++ b/net/ethtool/pse-pd.c
@@ -12,8 +12,33 @@
 #include <linux/ethtool_netlink.h>
 #include <linux/ethtool.h>
 #include <linux/export.h>
+#include <linux/of.h>
 #include <linux/phy.h>
 
+/*
+ * Attempt to resolve a PSE control that was deferred during MDIO bus
+ * registration because the PSE controller had not probed yet.
+ * Called under RTNL lock from ethtool PSE handlers.
+ */
+static void pse_try_resolve(struct phy_device *phydev)
+{
+	struct device_node *np;
+	struct pse_control *psec;
+
+	if (phydev->psec)
+		return;
+
+	np = phydev->mdio.dev.of_node;
+	if (!np || !of_property_present(np, "pses"))
+		return;
+
+	psec = of_pse_control_get(np, phydev);
+	if (IS_ERR(psec))
+		return;
+
+	phydev->psec = psec;
+}
+
 struct pse_req_info {
 	struct ethnl_req_info base;
 };
@@ -41,6 +66,8 @@ static int pse_get_pse_attributes(struct
 		return -EOPNOTSUPP;
 	}
 
+	pse_try_resolve(phydev);
+
 	if (!phydev->psec) {
 		NL_SET_ERR_MSG(extack, "No PSE is attached");
 		return -EOPNOTSUPP;
@@ -248,6 +275,8 @@ ethnl_set_pse_validate(struct phy_device
 		return -EOPNOTSUPP;
 	}
 
+	pse_try_resolve(phydev);
+
 	if (!phydev->psec) {
 		NL_SET_ERR_MSG(info->extack, "No PSE is attached");
 		return -EOPNOTSUPP;
