From: OpenWrt <openwrt@openwrt.org>
Subject: [PATCH] netfilter: nft_flow_offload: bridge offload dst on master (IPv6)

Upstream MediaTek fix (mtk-openwrt-feeds 999-ppe-15 v2): IPv6 bridge forwarding
could not be flow offloaded when the bridge master has no connected route for
the bridged prefix (no IPv6 on br or wrong subnet).

Replace nf_route()-based nft_flow_route_dir() bridging path with minimal IPv4/IPv6
dst entries allocated on the bridge master (rt_dst_alloc / ip6_dst_alloc), then
nft_default_forward_path() as in Linux 6.12 mediatek feed.

Requires 675-02 (L2 bridge offload) to be applied first.

Signed-off-by: Ported from Bo-Cun Chen <bc-bocun.chen@mediatek.com> / mtk_openwrt_feeds
---
--- a/net/netfilter/nft_flow_offload.c
+++ b/net/netfilter/nft_flow_offload.c
@@ -10,6 +10,8 @@
 #include <linux/netfilter/nf_tables.h>
 #include <net/ip.h>
 #include <net/flow.h>
+#include <net/route.h>
+#include <net/ip6_route.h>
 #include <net/netfilter/nf_tables.h>
 #include <net/netfilter/nf_tables_core.h>
 #include <net/netfilter/nf_conntrack_core.h>
@@ -374,80 +376,72 @@
 }
 
 static int
-nft_flow_route_dir(const struct nft_pktinfo *pkt,
-		   const struct nf_conn *ct,
-		   struct nf_flow_route *route,
-		   enum ip_conntrack_dir dir,
-		   int ifindex)
-{
-	struct dst_entry *other_dst = NULL;
-	struct flowi fl;
-
-	memset(&fl, 0, sizeof(fl));
-	switch (nft_pf(pkt)) {
-	case NFPROTO_IPV4:
-		fl.u.ip4.daddr = ct->tuplehash[!dir].tuple.src.u3.ip;
-		fl.u.ip4.flowi4_oif = ifindex;
-		fl.u.ip4.flowi4_dscp = ip4h_dscp(ip_hdr(pkt->skb));
-		fl.u.ip4.flowi4_mark = pkt->skb->mark;
-		fl.u.ip4.flowi4_flags = FLOWI_FLAG_ANYSRC;
-		break;
-	case NFPROTO_IPV6:
-		fl.u.ip6.saddr = ct->tuplehash[!dir].tuple.dst.u3.in6;
-		fl.u.ip6.daddr = ct->tuplehash[!dir].tuple.src.u3.in6;
-		fl.u.ip6.flowi6_oif = ifindex;
-		fl.u.ip6.flowlabel = ip6_flowinfo(ipv6_hdr(pkt->skb));
-		fl.u.ip6.flowi6_mark = pkt->skb->mark;
-		fl.u.ip6.flowi6_flags = FLOWI_FLAG_ANYSRC;
-		break;
-	}
-
-	nf_route(nft_net(pkt), &other_dst, &fl, false, nft_pf(pkt));
-	if (!other_dst)
-		return -ENOENT;
-
-	nft_default_forward_path(route, other_dst, dir);
-
-	return 0;
-}
-
-static int
 nft_flow_route_bridging(const struct nft_pktinfo *pkt,
 			const struct nf_conn *ct,
 			struct nf_flow_route *route,
 			enum ip_conntrack_dir dir,
 			struct nft_flowtable *ft)
 {
-	int ret;
+	struct dst_entry *dsts[IP_CT_DIR_MAX] = {};
+	struct net_bridge_port *port;
+	struct net_device *br_dev;
+	int i;
+
+	/* Allocate minimal dsts anchored to the bridge master device to
+	 * supply xmit_type and MTU for bridge forwarding.
+	 */
+	rcu_read_lock();
+	port = br_port_get_rcu(pkt->skb->dev);
+	if (!port) {
+		rcu_read_unlock();
+		return -ENOENT;
+	}
+	br_dev = port->br->dev;
+
+	for (i = 0; i < IP_CT_DIR_MAX; i++) {
+		switch (nft_pf(pkt)) {
+		case NFPROTO_IPV4: {
+			struct rtable *rt;
+
+			rt = rt_dst_alloc(br_dev, 0, RTN_UNICAST, true);
+			if (rt)
+				dsts[i] = &rt->dst;
+			break;
+		}
+		case NFPROTO_IPV6: {
+			struct rt6_info *rt;
 
-	ret = nft_flow_route_dir(pkt, ct, route, dir,
-				 nft_out(pkt)->ifindex);
-	if (ret)
-		return ret;
-
-	ret = nft_flow_route_dir(pkt, ct, route, !dir,
-				 nft_in(pkt)->ifindex);
-	if (ret)
-		goto err_route_dir1;
+			rt = ip6_dst_alloc(nft_net(pkt), br_dev, 0);
+			if (rt)
+				dsts[i] = &rt->dst;
+			break;
+		}
+		}
+	}
+	rcu_read_unlock();
+
+	if (!dsts[dir] || !dsts[!dir]) {
+		dst_release(dsts[dir]);
+		dst_release(dsts[!dir]);
+		return -ENOENT;
+	}
+
+	nft_default_forward_path(route, dsts[dir], dir);
+	nft_default_forward_path(route, dsts[!dir], !dir);
 
 	if (route->tuple[dir].xmit_type == FLOW_OFFLOAD_XMIT_NEIGH &&
 	    route->tuple[!dir].xmit_type == FLOW_OFFLOAD_XMIT_NEIGH) {
 		if (nft_dev_forward_path(pkt, true, route, ct, dir, ft) ||
 		    nft_dev_forward_path(pkt, true, route, ct, !dir, ft)) {
-			ret = -ENOENT;
-			goto err_route_dir2;
+			dst_release(route->tuple[dir].dst);
+			dst_release(route->tuple[!dir].dst);
+			return -ENOENT;
 		}
 	}
 
 	return 0;
-
-err_route_dir2:
-	dst_release(route->tuple[!dir].dst);
-err_route_dir1:
-	dst_release(route->tuple[dir].dst);
-	return ret;
 }
 
 static bool nft_flow_offload_skip(struct sk_buff *skb, int family)
 {
 	if (skb_sec_path(skb))
