From c1df6d11d28f16ca16af9df47650ffbc429f3a17 Mon Sep 17 00:00:00 2001
From: Til Kaiser <mail@tk154.de>
Date: Wed, 22 Apr 2026 12:50:00 +0200
Subject: [PATCH] block: fitblk: support larger inline FIT images

The original fitblk implementation only accepts FIT indexes up to
1024 pages and allocates the temporary FIT buffer using kmalloc().
That is too small for larger inline FIT images with embedded squashfs
payloads on eMMC systems.

Raise the maximum accepted size and use kvmalloc()/kvfree() for the
temporary FIT buffer.

Signed-off-by: Til Kaiser <mail@tk154.de>
---
 drivers/block/fitblk.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

--- a/drivers/block/fitblk.c
+++ b/drivers/block/fitblk.c
@@ -35,6 +35,7 @@
 #include <linux/platform_device.h>
 #include <linux/property.h>
 #include <linux/refcount.h>
+#include <linux/slab.h>
 #include <linux/task_work.h>
 #include <linux/types.h>
 #include <linux/libfdt.h>
@@ -44,8 +45,8 @@
 
 #define FIT_DEVICE_PREFIX	"fit"
 
-/* maximum number of pages used for the uImage.FIT index structure */
-#define FIT_MAX_PAGES		1024
+/* allow larger inline FIT images with embedded rootfs data */
+#define FIT_MAX_PAGES		8192
 
 /* minimum free sectors to map as read-write "remainder" volume */
 #define MIN_FREE_SECT		16
@@ -385,7 +386,7 @@ static int parse_fit_on_dev(struct devic
 		goto out_blkdev;
 	}
 
-	fit = kmalloc(size, GFP_KERNEL);
+	fit = kvmalloc(size, GFP_KERNEL);
 	if (!fit) {
 		ret = -ENOMEM;
 		folio_put(folio);
@@ -591,7 +592,7 @@ static int parse_fit_on_dev(struct devic
 
 out_bootconf:
 	kfree(bootconf);
-	kfree(fit);
+	kvfree(fit);
 out_blkdev:
 	if (!slot)
 		fput(bdev_file);
