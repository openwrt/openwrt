/dts-v1/;

#include "en7528_dasan_h660gm-a.dtsi"

/ {
	model = "DASAN H660GM-A (Generic)";
	compatible = "dasan,h660gm-a-generic", "econet,en7528";

	keys-polled {
		/* gpio22 has no interrupt (only GPIO0-15 do), so poll it */
		key-wlan {
			label = "wlan";
			gpios = <&en7528_pinctrl 22 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RFKILL>;
		};
	};

	leds {
		led_usb: usb {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_USB;
			gpios = <&en7528_pinctrl 8 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "usbport";
			trigger-sources = <&usb>;
		};

		led-lan1-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
			gpios = <&en7528_pinctrl 31 GPIO_ACTIVE_LOW>;
		};

		led-lan1-amber {
			color = <LED_COLOR_ID_AMBER>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <1>;
			gpios = <&en7528_pinctrl 23 GPIO_ACTIVE_LOW>;
		};

		led-lan2-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
			gpios = <&en7528_pinctrl 33 GPIO_ACTIVE_LOW>;
		};

		led-lan2-amber {
			color = <LED_COLOR_ID_AMBER>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <2>;
			gpios = <&en7528_pinctrl 24 GPIO_ACTIVE_LOW>;
		};

		led-lan3-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <3>;
			gpios = <&en7528_pinctrl 35 GPIO_ACTIVE_LOW>;
		};

		led-lan3-amber {
			color = <LED_COLOR_ID_AMBER>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <3>;
			gpios = <&en7528_pinctrl 25 GPIO_ACTIVE_LOW>;
		};

		led-lan4-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <4>;
			gpios = <&en7528_pinctrl 37 GPIO_ACTIVE_LOW>;
		};

		led-lan4-amber {
			color = <LED_COLOR_ID_AMBER>;
			function = LED_FUNCTION_LAN;
			function-enumerator = <4>;
			gpios = <&en7528_pinctrl 26 GPIO_ACTIVE_LOW>;
		};
	};
};

&partitions {
	partition@60c0000 {
		label = "unknown";
		reg = <0x60c0000 0xd00000>;
	};

	partition@6dc0000 {
		label = "reservearea";
		reg = <0x6dc0000 0x240000>;
		nvmem-layout {
			compatible = "fixed-layout";
			#address-cells = <1>;
			#size-cells = <1>;

			eeprom_reservearea_40000: eeprom@40000 {
				reg = <0x40000 0x4da8>;
			};

			eeprom_reservearea_1c0000: eeprom@1c0000 {
				reg = <0x1c0000 0x400>;
			};
		};
	};
};
